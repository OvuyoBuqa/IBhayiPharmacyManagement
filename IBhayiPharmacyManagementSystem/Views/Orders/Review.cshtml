@using IBhayiPharmacyManagementSystem.Enums
@model Order
@{
    ViewData["Title"] = $"Review Order #{Model.OrderId}";
    Layout = "_LayoutPharmacist";
}

<div class="container-fluid px-4 mt-4">
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-lg">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #0a1f14 0%, #1b4332 100%);">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="mb-0">
                            <i class="fas fa-search me-2"></i>@ViewData["Title"]
                        </h3>
                        <a href="@Url.Action("OrdersForCustomers")" class="btn btn-outline-light">
                            <i class="fas fa-arrow-left me-1"></i> Back to Orders
                        </a>
                    </div>
                </div>

                <div class="card-body">
                    <!-- Order Status Alert -->
                    @if (Model.OrderStatus == OrderStatusEnum.Pending)
                    {
                        <div class="alert alert-warning border-0 mb-4">
                            <i class="fas fa-clock me-2"></i>
                            <strong>Pending Review:</strong> This order is waiting to be processed. Review the details below and click "Start Processing" when ready.
                        </div>
                    }
                    else if (Model.OrderStatus == OrderStatusEnum.Processing)
                    {
                        <div class="alert alert-info border-0 mb-4">
                            <i class="fas fa-spinner fa-spin me-2"></i>
                            <strong>Currently Processing:</strong> This order is being processed by @(Model.Pharmacist?.Name ?? "a pharmacist").
                        </div>
                    }

                    <div class="row">
                        <!-- Order Information -->
                        <div class="col-lg-8">
                            <div class="card border-0 shadow-sm mb-4">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">
                                        <i class="fas fa-file-invoice me-2"></i>Order Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <p><strong>Order ID:</strong> #<span class="text-primary">@Model.OrderId</span></p>
                                            <p><strong>Order Date:</strong> @Model.OrderDate.ToString("g")</p>
                                            <p><strong>Status:</strong>
                                                <span class="badge bg-@(Model.OrderStatus switch {
                                                    OrderStatusEnum.Pending => "warning",
                                                    OrderStatusEnum.Processing => "info",
                                                    OrderStatusEnum.Ready => "success",
                                                    OrderStatusEnum.Cancelled => "danger",
                                                    _ => "secondary"
                                                })">
                                                    @Model.OrderStatus
                                                </span>
                                                @if (Model.OrderStatus == OrderStatusEnum.Pending)
                                                {
                                                    <button type="button" class="btn btn-sm btn-success ms-2" id="startProcessingBtn"
                                                            data-order-id="@Model.OrderId" title="Start Processing">
                                                        <i class="fas fa-play me-1"></i>Start Processing
                                                    </button>
                                                }
                                            </p>
                                            <p><strong>Total Amount:</strong> <span class="h5 text-success">@($"R{Model.TotalAmount:F2}")</span></p>
                                        </div>
                                        <div class="col-md-6">
                                            <p><strong>Payment Status:</strong>
                                                <span class="badge @(Model.OrderStatus == OrderStatusEnum.Collected || Model.PaymentStatus ? "bg-success" : "bg-warning")">
                                                    @(Model.OrderStatus == OrderStatusEnum.Collected || Model.PaymentStatus ? "Paid" : "Pending Payment")
                                                </span>
                                            </p>
                                            <p><strong>Last Updated:</strong> @Model.LastUpdated.ToString()</p>
                                            @if (Model.Pharmacist != null)
                                            {
                                                <p><strong>Assigned Pharmacist:</strong> @Model.Pharmacist.Name</p>
                                            }
                                            @if (!string.IsNullOrEmpty(Model.OrderNotes))
                                            {
                                                <p><strong>Order Notes:</strong> @Model.OrderNotes</p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Order Items -->
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">
                                        <i class="fas fa-pills me-2"></i>Order Items (@Model.OrderItems.Count)
                                    </h5>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-hover mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th class="ps-3">Medication</th>
                                                    <th class="text-center">Quantity</th>
                                                    <th class="text-end">Unit Price</th>
                                                    <th class="text-end">Subtotal</th>
                                                    <th class="text-center">Status</th>
                                                    @if (Model.OrderStatus == OrderStatusEnum.Processing)
                                                    {
                                                        <th class="text-center">Dispense Action</th>
                                                    }
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in Model.OrderItems)
                                                {
                                                    <tr>
                                                        <td class="ps-3">
                                                            <div class="d-flex align-items-center">
                                                                <div class="avatar-xs bg-light rounded-circle me-3 d-flex align-items-center justify-content-center">
                                                                    <i class="fas fa-pills text-primary"></i>
                                                                </div>
                                                                <div>
                                                                    <h6 class="mb-0">@item.Medication?.Name</h6>
                                                                    <small class="text-muted">@item.Medication?.Description</small>
                                                                    @if (item.Medication?.DosageForm != null)
                                                                    {
                                                                        <div class="text-muted small">@item.Medication.DosageForm.Type</div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td class="text-center">
                                                            <span class="badge bg-light text-dark">@item.QuantityOrdered</span>
                                                        </td>
                                                        <td class="text-end">@($"R{item.UnitPrice:F2}")</td>
                                                        <td class="text-end fw-bold">@($"R{(item.QuantityOrdered * item.UnitPrice):F2}")</td>
                                                        <td class="text-center">
                                                            <span class="badge bg-@(item.DispensingStatus switch {
                                                                DispensingStatusEnum.Filled => "success",
                                                                DispensingStatusEnum.Pending => "secondary",
                                                                DispensingStatusEnum.OutOfStock => "danger",
                                                                _ => "secondary"
                                                            })">
                                                                @item.DispensingStatus
                                                            </span>
                                                        </td>
                                                        @if (Model.OrderStatus == OrderStatusEnum.Processing)
                                                        {
                                                            <td class="text-center">
                                                                <div class="d-flex align-items-center justify-content-center">
                                                                    <select class="form-select form-select-sm dispense-status-select me-2" 
                                                                            data-item-id="@item.OrderItemId" 
                                                                            style="min-width: 140px;">
                                                                        @{
                                                                            var pendingValue = (int)DispensingStatusEnum.Pending;
                                                                            var filledValue = (int)DispensingStatusEnum.Filled;
                                                                            var outOfStockValue = (int)DispensingStatusEnum.OutOfStock;
                                                                        }
                                                                        <option value="@pendingValue" selected="@(item.DispensingStatus == DispensingStatusEnum.Pending)">
                                                                            Pending
                                                                        </option>
                                                                        <option value="@filledValue" selected="@(item.DispensingStatus == DispensingStatusEnum.Filled)">
                                                                            Filled
                                                                        </option>
                                                                        <option value="@outOfStockValue" selected="@(item.DispensingStatus == DispensingStatusEnum.OutOfStock)">
                                                                            Out of Stock
                                                                        </option>
                                                                    </select>
                                                                    <button type="button" 
                                                                            class="btn btn-sm btn-outline-success update-status-btn" 
                                                                            data-item-id="@item.OrderItemId"
                                                                            title="Update Status">
                                                                        <i class="fas fa-check"></i>
                                                                    </button>
                                                                </div>
                                                            </td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                            <tfoot class="table-light">
                                                <tr>
                                                    <td colspan="3" class="text-end fw-bold ps-3">Order Total:</td>
                                                    <td class="text-end fw-bold h5 text-success">@($"R{Model.TotalAmount:F2}")</td>
                                                    <td></td>
                                                    @if (Model.OrderStatus == OrderStatusEnum.Processing)
                                                    {
                                                        <td></td>
                                                    }
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                    @if (Model.OrderStatus == OrderStatusEnum.Processing)
                                    {
                                        <div class="card-footer bg-light">
                                            <div class="row align-items-center">
                                                <div class="col-md-8">
                                                    <small class="text-muted">
                                                        <i class="fas fa-info-circle me-1"></i>
                                                        Update dispense status for each medication and click "Save All Changes" to apply updates.
                                                    </small>
                                                </div>
                                                <div class="col-md-4 text-end">
                                                    <button type="button" class="btn btn-success" id="saveAllDispenseStatusBtn">
                                                        <i class="fas fa-save me-2"></i>Save All Changes
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Actions Section - Moved closer to table -->
                            <div class="card border-0 shadow-sm mt-4">
                                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #0a1f14 0%, #1b4332 100%);">
                                    <h5 class="mb-0">
                                        <i class="fas fa-tasks me-2"></i>Actions
                                    </h5>
                                </div>
                                <div class="card-body">
                                    @if (Model.OrderStatus == OrderStatusEnum.Processing)
                                    {
                                        <div class="alert alert-info border-info mb-3">
                                            <i class="fas fa-info-circle me-2"></i>
                                            <strong>Processing Order:</strong> Update dispense status for each medication in the table above.
                                        </div>

                                        @if (Model.OrderItems.All(oi => oi.DispensingStatus == DispensingStatusEnum.Filled))
                                        {
                                            <button type="button" class="btn btn-success btn-lg w-100 mb-3" id="completeOrderBtn"
                                                    data-order-id="@Model.OrderId">
                                                <i class="fas fa-check-circle me-2"></i>Mark as Ready
                                            </button>
                                        }
                                    }
                                    else if (Model.OrderStatus != OrderStatusEnum.Pending)
                                    {
                                        <div class="alert alert-info">
                                            <i class="fas fa-info-circle me-2"></i>
                                            This order is @Model.OrderStatus.ToString().ToLower().
                                        </div>
                                    }

                                    <hr>

                                    <div class="d-grid gap-2">
                                        <button type="button" class="btn btn-outline-secondary" onclick="window.print()">
                                            <i class="fas fa-print me-1"></i>Print Order
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Customer Information & Actions -->
                        <div class="col-lg-4">
                            <!-- Customer Details -->
                            <div class="card border-0 shadow-sm mb-4">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">
                                        <i class="fas fa-user me-2"></i>Customer Details
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="text-center mb-3">
                                        <div class="avatar-lg bg-primary rounded-circle mx-auto d-flex align-items-center justify-content-center mb-2">
                                            <i class="fas fa-user text-white fa-2x"></i>
                                        </div>
                                        <h6 class="mb-0">@Model.Customer?.Name</h6>
                                        <small class="text-muted">@Model.Customer?.User?.Email</small>
                                    </div>

                                    <hr>

                                    <div class="customer-info">
                                        <p><strong>Customer ID:</strong> #<span class="text-primary">@Model.Customer?.CustomerId</span></p>
                                        @if (Model.Customer != null)
                                        {
                                        <p><strong>Phone:</strong> @Model.Customer.CellPhoneNumber</p>
                                        <p><strong>Address:</strong></p>
                                        <address class="small text-muted">
                                                @Model.Customer.Street<br>
                                                @Model.Customer.City, @Model.Customer.Province<br>
                                                @Model.Customer.ZipCode
                                            </address>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Customer Allergies Section -->
                            <div class="card border-0 shadow-sm mb-4">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">
                                        <i class="fas fa-exclamation-triangle text-warning me-2"></i>Customer Allergies
                                    </h5>
                                </div>
                                <div class="card-body">
                                    @if (Model.Customer?.Allergies != null && Model.Customer.Allergies.Any())
                                    {
                                        <div class="alert alert-warning border-warning">
                                            <div class="d-flex align-items-center mb-2">
                                                <i class="fas fa-exclamation-triangle fa-lg me-2"></i>
                                                <strong>Known Allergies:</strong>
                                            </div>
                                            <div class="allergies-display-area">
                                                @foreach (var allergy in Model.Customer.Allergies)
                                                {
                                                    <div class="allergy-item-card @(allergy.Severity.ToLower() switch {
                                                        "mild" => "mild",
                                                        "moderate" => "moderate",
                                                        "severe" => "severe",
                                                        "life-threatening" => "life-threatening",
                                                        _ => "moderate" // default mapping for values like "medium"
                                                    })">
                                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                                            <span class="ingredient-badge">@allergy.ActiveIngredient?.Name</span>
                                                            <span class="severity-badge @allergy.Severity.ToLower()">@allergy.Severity</span>
                                                        </div>
                                                        @if (!string.IsNullOrEmpty(allergy.Description) && allergy.Description.StartsWith("CUSTOM_ALLERGEN:"))
                                                        {
                                                            var customDescription = allergy.Description.Replace("CUSTOM_ALLERGEN:", "").Trim();
                                                            <small class="text-muted">Custom: @customDescription</small>
                                                        }
                                                        else if (!string.IsNullOrEmpty(allergy.Description))
                                                        {
                                                            <small class="text-muted">@allergy.Description</small>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-info border-info">
                                            <i class="fas fa-info-circle me-2"></i>
                                            <strong>No known allergies recorded</strong> for this customer.
                                        </div>
                                    }
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        :root {
            --primary-color: #0a1f14; /* dashboard green */
            --primary-hover: #1b4332; /* lighter green */
            --success-color: #0a1f14; /* dashboard green */
            --info-color: #17a2b8;
            --warning-color: #ffc107;
            --danger-color: #dc3545;
            --light-color: #f8f9fa;
            --dark-color: #343a40;
            --border-radius: 0.5rem;
            --box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        .card {
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: var(--box-shadow);
            border: none;
        }

        .card-header {
            border-radius: 0 !important;
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-hover) 100%);
        }

        .avatar-lg {
            width: 80px;
            height: 80px;
        }

        .avatar-xs {
            width: 32px;
            height: 32px;
            font-size: 0.875rem;
        }

        .badge {
            font-weight: 500;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 0.5em 0.75em;
        }

        .btn {
            transition: var(--transition);
            font-weight: 500;
            border-radius: var(--border-radius);
        }

        .btn-lg {
            padding: 0.75rem 1.5rem;
            font-size: 1.1rem;
        }

        .table th {
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            color: #6c757d;
            border-top: none;
            background-color: var(--light-color);
            padding: 1rem;
            vertical-align: middle;
        }

        .table td {
            padding: 1rem;
            vertical-align: middle;
        }

        .alert {
            border-radius: var(--border-radius);
            border: none;
        }

        .form-select {
            border-radius: var(--border-radius);
            border: 1px solid #ced4da;
            transition: var(--transition);
        }

        .form-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(10, 31, 20, 0.25);
        }

        @@media print {
            .btn, .card-header, .alert {
                display: none !important;
            }

            .card {
                box-shadow: none;
                border: 1px solid #dee2e6;
            }
        }
        .allergies-display-area {
            display: flex;
            flex-wrap: wrap;
            gap: 12px; /* Increased gap for better spacing */
        }
        .allergy-item-card {
            flex: 1 1 calc(50% - 12px); /* Two cards per row on wider screens, adjust for gap */
            min-width: 280px; /* Minimum width to prevent squishing */
            max-width: calc(50% - 12px);
            background-color: #fff;
            border-left: 5px solid;
            padding: 1rem;
            border-radius: var(--border-radius);
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            transition: all 0.2s ease-in-out;
        }
        .allergy-item-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 .25rem .75rem rgba(0,0,0,.1);
        }
        /* Severity based border and text colors */
        .allergy-item-card .mild {
            border-color: #28a745; /* Green */
        }
        .allergy-item-card .moderate {
            border-color: #ffc107; /* Yellow */
        }
        .allergy-item-card .severe {
            border-color: #fd7e14; /* Orange */
        }
        .allergy-item-card ."life-threatening" {
            border-color: #dc3545; /* Red */
        }
        .ingredient-badge {
            background-color: #e9ecef;
            color: #495057;
            font-weight: 600;
            padding: 0.3em 0.6em;
            border-radius: 0.25rem;
            font-size: 0.9em;
        }
        .severity-badge {
            font-size: 0.75em;
            padding: 0.2em 0.5em;
            border-radius: 0.2rem;
            font-weight: 700;
            text-transform: uppercase;
        }
        .severity-badge.mild {
            background-color: #d4edda;
            color: #155724;
        }
        .severity-badge.moderate {
            background-color: #fff3cd;
            color: #856404;
        }
        .severity-badge.severe {
            background-color: #fce5d1;
            color: #8a3801;
        }
        .severity-badge."life-threatening" {
            background-color: #f8d7da;
            color: #721c24;
        }
        .text-muted {
            font-size: 0.8em;
        }

        @@media (max-width: 768px) {
            .allergy-item-card {
                flex: 1 1 100%;
                max-width: 100%;
            }
        }

        /* Enhanced styles for the integrated dispense functionality */
        .dispense-status-select {
            border-radius: 0.375rem;
            border: 1px solid #ced4da;
            transition: all 0.2s ease-in-out;
            font-size: 0.875rem;
        }

        .dispense-status-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(10, 31, 20, 0.25);
        }

        .update-status-btn {
            border-radius: 0.375rem;
            transition: all 0.2s ease-in-out;
            min-width: 36px;
            height: 36px;
        }

        .update-status-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        }

        .card-footer {
            background-color: rgba(248, 249, 250, 0.8) !important;
            border-top: 1px solid rgba(0, 0, 0, 0.125);
        }

        /* Responsive adjustments for dispense actions */
        @@media (max-width: 768px) {
            .dispense-status-select {
                margin-bottom: 0.5rem;
            }
            
            .update-status-btn {
                width: 100%;
            }
            
            .card-footer .col-md-4 {
                text-align: center !important;
                margin-top: 1rem;
            }
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            // Start Processing Button
            $('#startProcessingBtn').click(function(e) {
                e.preventDefault();
                const orderId = $(this).data('order-id');
                const button = $(this);

                // Use SweetAlert for confirmation if available
                if (window.confirmSwal) {
                    confirmSwal({ 
                        title: 'Start Processing Order?', 
                        html: `Are you sure you want to start processing Order #${orderId}?`,
                        icon: 'question',
                        confirmButtonText: 'Yes, Start Processing'
                    }).then(function(result) {
                        if (!result.isConfirmed) return;
                        processOrder();
                    });
                } else {
                    if (confirm(`Start processing Order #${orderId}?`)) {
                        processOrder();
                    }
                }

                function processOrder() {
                    button.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Processing...');

                    $.ajax({
                        url: '@Url.Action("Process", "Orders")',
                        type: 'POST',
                        data: {
                            id: orderId,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                // Show success message
                                if (window.showAlert) {
                                    showAlert('success', 'Order is now being processed');
                                } else {
                                    showToast('Order is now being processed', 'success');
                                }

                                // Update UI
                                setTimeout(function() {
                                    location.reload();
                                }, 1500);
                            } else {
                                if (window.showAlert) {
                                    showAlert('error', response.error || 'Failed to process order');
                                } else {
                                    showToast(response.error || 'Failed to process order', 'danger');
                                }
                                button.prop('disabled', false).html('<i class="fas fa-play me-2"></i>Start Processing');
                            }
                        },
                        error: function(xhr) {
                            if (window.showAlert) {
                                showAlert('error', 'An error occurred while processing the order');
                            } else {
                                showToast('An error occurred while processing the order', 'danger');
                            }
                            button.prop('disabled', false).html('<i class="fas fa-play me-2"></i>Start Processing');
                        }
                    });
                }
            });

            // Complete Order Button
            $('#completeOrderBtn').click(function(e) {
                e.preventDefault();
                const orderId = $(this).data('order-id');
                const button = $(this);

                button.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Completing...');

                $.ajax({
                    url: '@Url.Action("Complete", "Orders")',
                    type: 'POST',
                    data: {
                        id: orderId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            showToast('Order marked as ready for pickup', 'success');
                            setTimeout(function() {
                                location.reload();
                            }, 1500);
                        } else {
                            showToast(response.error || 'Failed to complete order', 'danger');
                            button.prop('disabled', false).html('<i class="fas fa-check-circle me-2"></i>Mark as Ready');
                        }
                    },
                    error: function(xhr) {
                        showToast('An error occurred while completing the order', 'danger');
                        button.prop('disabled', false).html('<i class="fas fa-check-circle me-2"></i>Mark as Ready');
                    }
                });
            });

            // Individual Update Status Button
            $('.update-status-btn').click(function(e) {
                e.preventDefault();
                const button = $(this);
                const itemId = button.data('item-id');
                const select = $(`.dispense-status-select[data-item-id="${itemId}"]`);
                const statusValue = parseInt(select.val());

                button.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');

                // Update single item
                const dispenseUpdates = [{
                    orderItemId: itemId,
                    dispensingStatus: statusValue
                }];

                updateDispenseStatus(dispenseUpdates, function(success) {
                    if (success) {
                        button.html('<i class="fas fa-check text-success"></i>');
                        setTimeout(function() {
                            location.reload();
                        }, 1000);
                    } else {
                        button.prop('disabled', false).html('<i class="fas fa-check"></i>');
                    }
                });
            });

            // Save All Dispense Status Button
            $('#saveAllDispenseStatusBtn').click(function(e) {
                e.preventDefault();
                const button = $(this);

                button.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Saving...');

                // Collect all dispense status updates
                const dispenseUpdates = [];
                $('.dispense-status-select').each(function() {
                    const itemId = $(this).data('item-id');
                    const statusValue = parseInt($(this).val());
                    dispenseUpdates.push({
                        orderItemId: itemId,
                        dispensingStatus: statusValue
                    });
                });

                updateDispenseStatus(dispenseUpdates, function(success) {
                    if (success) {
                        setTimeout(function() {
                            location.reload();
                        }, 1500);
                    } else {
                        button.prop('disabled', false).html('<i class="fas fa-save me-2"></i>Save All Changes');
                    }
                });
            });

            // Reusable function to update dispense status
            function updateDispenseStatus(dispenseUpdates, callback) {
                const orderId = @Model.OrderId;

                // Convert to proper format for ASP.NET Core
                const formData = new FormData();
                formData.append('orderId', orderId);
                formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

                // Add each dispense update
                dispenseUpdates.forEach(function(update, index) {
                    formData.append(`dispenseUpdates[${index}].orderItemId`, update.orderItemId);
                    formData.append(`dispenseUpdates[${index}].dispensingStatus`, update.dispensingStatus);
                });

                $.ajax({
                    url: '@Url.Action("UpdateDispenseStatus", "Orders")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        if (response.success) {
                            showToast('Dispense status updated successfully', 'success');
                            callback(true);
                        } else {
                            showToast(response.error || 'Failed to update dispense status', 'danger');
                            callback(false);
                        }
                    },
                    error: function(xhr, status, error) {
                        showToast('An error occurred while updating dispense status', 'danger');
                        callback(false);
                    }
                });
            }

            // Toast notification function
            function showToast(message, type) {
                const toast = $(`
                    <div class="toast align-items-center text-white bg-${type} border-0" role="alert" aria-live="assertive" aria-atomic="true">
                        <div class="d-flex">
                            <div class="toast-body">
                                ${message}
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                    </div>
                `);

                const toastContainer = $('#toastContainer') || $('body').append('<div id="toastContainer" class="position-fixed bottom-0 end-0 p-3" style="z-index: 11"></div>');
                $('#toastContainer').append(toast);

                const bsToast = new bootstrap.Toast(toast[0]);
                bsToast.show();

                toast.on('hidden.bs.toast', function() {
                    toast.remove();
                });
            }
        });
    </script>
}
