@using IBhayiPharmacyManagementSystem.Enums
@model IEnumerable<Order>
@{
    ViewData["Title"] = "Orders Management";
    Layout = "_LayoutPharmacist";
}

<div class="container-fluid px-4 mt-4">
    <div class="card border-0 shadow-lg">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #0a1f14 0%, #1b4332 100%);">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0">
                    <i class="fas fa-clipboard-list me-2"></i>@ViewData["Title"]
                </h3>
                <div class="btn-group btn-group-sm" role="group">
                    <a asp-action="OrdersForCustomers" 
                       class="btn @(ViewBag.StatusFilter == null ? "btn-light" : "btn-outline-light")">
                        All Orders
                    </a>
                    @foreach (OrderStatusEnum status in Enum.GetValues(typeof(OrderStatusEnum)))
                    {
                        <a asp-action="OrdersForCustomers" asp-route-status="@status"
                           class="btn @(ViewBag.StatusFilter == status ? "btn-light" : "btn-outline-light")">
                            @status
                        </a>
                    }
                </div>
            </div>
        </div>
        
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="alert alert-info rounded-0 m-0 border-0">
                    <i class="fas fa-info-circle me-2"></i>No orders matching your criteria were found.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Order #</th>
                                <th>Customer</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th class="text-end">Total</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr class="@(order.OrderStatus == OrderStatusEnum.Pending ? "table-warning" : 
                                           order.OrderStatus == OrderStatusEnum.Processing ? "table-info" : "")"
                                    data-order-id="@order.OrderId">
                                    <td class="ps-4 fw-bold">#@order.OrderId</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm bg-light rounded-circle me-2 d-flex align-items-center justify-content-center">
                                                <i class="fas fa-user text-primary"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0">@order.Customer?.Name</h6>
                                                <small class="text-muted">Customer</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="d-block">@order.OrderDate.ToString("g")</span>
                                        <small class="text-muted">@order.OrderDate.ToShortTimeString()</small>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-@GetStatusBadgeColor(order.OrderStatus) py-2 px-3" 
                                              id="status-badge-@order.OrderId">
                                            <i class="@GetStatusIcon(order.OrderStatus) me-1"></i>@order.OrderStatus
                                        </span>
                                    </td>
                                    <td class="text-end fw-bold">
                                        @($"R{order.TotalAmount:F2}")
                                    </td>
                                    <td class="text-end pe-4" id="actions-@order.OrderId">
                                        <div class="d-flex justify-content-end gap-1 align-items-center">
                                            @if (order.OrderStatus == OrderStatusEnum.Pending)
                                            {
                                                <a href="@Url.Action("Review", "Orders", new { id = order.OrderId })"
                                                   class="btn btn-sm btn-outline-primary rounded-circle"
                                                   data-bs-toggle="tooltip" title="Review Order">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            }
                                            else if (order.OrderStatus == OrderStatusEnum.Processing)
                                            {
                                                <a href="@Url.Action("Review", "Orders", new { id = order.OrderId })"
                                                   class="btn btn-sm btn-outline-primary rounded-circle"
                                                   data-bs-toggle="tooltip" title="Review Order">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <a href="@Url.Action("Review", "Orders", new { id = order.OrderId })"
                                                   class="btn btn-sm btn-outline-secondary rounded-circle"
                                                   data-bs-toggle="tooltip" title="View Order Details">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                
                                <!-- Hidden row for items -->
                                <tr class="items-row d-none" id="items-@order.OrderId">
                                    <td colspan="6" class="p-0">
                                        <div class="p-3 bg-light">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <h6 class="fw-bold mb-0"><i class="fas fa-list-ul me-2"></i>Order Items</h6>
                                                <button class="btn btn-sm btn-outline-secondary close-items" data-order-id="@order.OrderId">
                                                    <i class="fas fa-times"></i> Close
                                                </button>
                                            </div>
                                            <div class="table-responsive">
                                                <table class="table table-sm table-bordered">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>Medication</th>
                                                            <th class="text-end">Quantity</th>
                                                            <th class="text-end">Price</th>
                                                            <th class="text-end">Subtotal</th>
                                                            <th>Status</th>
                                                            <th>Actions</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var item in order.OrderItems)
                                                        {
                                                            <tr>
                                                                <td>
                                                                    <div class="d-flex align-items-center">
                                                                        <div class="avatar-xs bg-white rounded-circle me-2 d-flex align-items-center justify-content-center border">
                                                                            <i class="fas fa-pills text-primary"></i>
                                                                        </div>
                                                                        <div>
                                                                            @item.Medication?.Name
                                                                            <div class="text-muted small">@item.Medication?.Description</div>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                                <td class="text-end">@item.QuantityOrdered</td>
                                                                <td class="text-end">@($"R{item.UnitPrice:F2}")</td>
                                                                <td class="text-end fw-bold">@($"R{(item.QuantityOrdered * item.UnitPrice):F2}")</td>
                                                                <td>
                                                                    <span class="badge bg-@(item.DispensingStatus == DispensingStatusEnum.Filled ? "success" : "danger")">
                                                                        <i class="fas @(item.DispensingStatus == DispensingStatusEnum.Filled ? "fa-check" : "fa-times") me-1"></i>
                                                                        @item.DispensingStatus
                                                                    </span>
                                                                </td>
                                                                <td>
                                                                    @if (order.OrderStatus == OrderStatusEnum.Processing)
                                                                    {
                                                                        <button class="btn btn-sm btn-outline-primary dispense-item"
                                                                                data-item-id="@item.OrderItemId"
                                                                                data-order-id="@order.OrderId"
                                                                                data-bs-toggle="modal" 
                                                                                data-bs-target="#dispenseModal">
                                                                            <i class="fas fa-pills"></i> Dispense
                                                                        </button>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                    <tfoot>
                                                        <tr class="table-light">
                                                            <td colspan="3" class="text-end fw-bold">Order Total:</td>
                                                            <td class="text-end fw-bold" colspan="3">@($"R{order.TotalAmount:F2}")</td>
                                                        </tr>
                                                    </tfoot>
                                                </table>
                                            </div>
                                            @if (order.OrderStatus == OrderStatusEnum.Processing && order.OrderItems.All(oi => oi.DispensingStatus == DispensingStatusEnum.Filled))
                                            {
                                                <div class="text-end mt-3">
                                                    <button type="button" class="btn btn-success complete-order"
                                                            data-order-id="@order.OrderId">
                                                        <i class="fas fa-check-circle me-1"></i> Mark as Ready
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="card-footer bg-light d-flex justify-content-between align-items-center">
                    <div class="text-muted small">
                        Showing <strong>@Model.Count()</strong> orders
                    </div>
                    <div>
                        <button class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-download me-1"></i>Export
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Dispense Item Modal -->
<div class="modal fade" id="dispenseModal" tabindex="-1" aria-labelledby="dispenseModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="dispenseModalLabel">Dispense Medication</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="dispenseForm" method="post" asp-action="DispenseItem">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="orderItemId" name="id" />
                    <input type="hidden" id="orderId" name="orderId" />
                    
                    <div class="mb-3">
                        <label class="form-label">Dispensing Status</label>
                        <select class="form-select" name="DispensingStatus" required>
                            <option value="">Select Status</option>
                            <option value="@DispensingStatusEnum.Filled">Fully Filled</option>
                            <option value="@DispensingStatusEnum.OutOfStock">Out Of Stock</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Quantity Dispensed</label>
                        <input type="number" class="form-control" name="QuantityDispensed" min="0" required>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea class="form-control" name="DispensingNotes" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Toast Notifications Container -->
<div id="toastContainer" class="position-fixed bottom-0 end-0 p-3" style="z-index: 11"></div>

@functions {
    string GetStatusBadgeColor(OrderStatusEnum status)
    {
        return status switch
        {
            OrderStatusEnum.Pending => "warning",
            OrderStatusEnum.Processing => "info",
            OrderStatusEnum.Ready => "success",
            OrderStatusEnum.Cancelled => "danger",
            _ => "secondary"
        };
    }
    
    string GetStatusIcon(OrderStatusEnum status)
    {
        return status switch
        {
            OrderStatusEnum.Pending => "fas fa-clock",
            OrderStatusEnum.Processing => "fas fa-spinner fa-pulse",
            OrderStatusEnum.Ready => "fas fa-check-circle",
            OrderStatusEnum.Cancelled => "fas fa-times-circle",
            _ => "fas fa-question-circle"
        };
    }
}

@section Styles {
    <style>
        :root {
            --primary-color: #0a1f14; /* dashboard green */
            --primary-hover: #1b4332; /* lighter green */
            --secondary-color: #6c757d;
            --success-color: #0a1f14; /* dashboard green */
            --info-color: #17a2b8;
            --warning-color: #ffc107;
            --danger-color: #dc3545;
            --light-color: #f8f9fa;
            --dark-color: #343a40;
            --border-radius: 0.5rem;
            --box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            background-color: #f5f7fa;
        }
        
        .card {
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: var(--box-shadow);
            border: none;
        }
        
        .card-header {
            border-radius: 0 !important;
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-hover) 100%);
        }
        
        .table {
            margin-bottom: 0;
        }
        
        .table th {
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            color: var(--secondary-color);
            border-top: none;
            background-color: var(--light-color);
            padding: 1rem;
            vertical-align: middle;
        }
        
        .table td {
            padding: 1rem;
            vertical-align: middle;
        }
        
        .avatar-sm {
            width: 36px;
            height: 36px;
        }
        
        .avatar-xs {
            width: 24px;
            height: 24px;
            font-size: 0.75rem;
        }
        
        .badge {
            font-weight: 500;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 0.5em 0.75em;
        }
        
        .btn {
            transition: var(--transition);
            font-weight: 500;
            border-radius: var(--border-radius);
        }
        
        .btn-sm {
            padding: 0.35rem 0.75rem;
            font-size: 0.875rem;
        }
        
        .btn-rounded-circle {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50% !important;
        }
        
        .table-hover tr:not(.items-row) {
            cursor: pointer;
            transition: background-color 0.2s;
        }
        
        .table-hover tr:not(.items-row):hover {
            background-color: rgba(0, 0, 0, 0.02);
        }
        
        .items-row {
            background-color: #f8f9fa;
        }
        
        .items-row td {
            border-top: none;
            padding: 0 !important;
        }
        
        .items-row .table {
            background-color: white;
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        }
        
        .btn-group .btn {
            border-radius: 0.375rem !important;
        }
        
        .btn-group .btn:first-child {
            border-top-left-radius: 0.375rem !important;
            border-bottom-left-radius: 0.375rem !important;
        }
        
        .btn-group .btn:last-child {
            border-top-right-radius: 0.375rem !important;
            border-bottom-right-radius: 0.375rem !important;
        }
        
        .modal-header {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-hover) 100%);
        }
        
        .form-control, .form-select {
            border-radius: var(--border-radius);
            padding: 0.5rem 0.75rem;
            border: 1px solid #ced4da;
            transition: var(--transition);
        }
        
        .form-control:focus, .form-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.25rem rgba(58, 123, 213, 0.25);
        }
        
        .alert {
            border-radius: 0;
            border: none;
        }
        
        /* Status colors */
        .bg-warning {
            background-color: var(--warning-color) !important;
        }
        
        .bg-info {
            background-color: var(--info-color) !important;
        }
        
        .bg-success {
            background-color: var(--success-color) !important;
        }
        
        .bg-danger {
            background-color: var(--danger-color) !important;
        }
        
        /* Table row status colors */
        .table-warning {
            --bs-table-bg: rgba(255, 193, 7, 0.1);
        }
        
        .table-info {
            --bs-table-bg: rgba(23, 162, 184, 0.1);
        }
        
        /* Toast notifications */
        .toast {
            transition: opacity 0.3s ease;
        }
        
        /* Ensure items row is visible when not hidden */
        .items-row:not(.d-none) {
            display: table-row !important;
        }
        
        /* Modal z-index fix */
        #dispenseModal {
            z-index: 1060 !important;
        }

        /* Table loading animation */
        .table-loading {
            position: relative;
        }

        .table-loading::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(1px);
            z-index: 10;
            pointer-events: none;
        }

        .table-loading::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 20px;
            height: 20px;
            margin: -10px 0 0 -10px;
            border: 2px solid var(--primary-color);
            border-top: 2px solid transparent;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            z-index: 11;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        /* Responsive adjustments */
        @@media (max-width: 768px) {
            .card-header {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .btn-group {
                margin-top: 0.5rem;
                width: 100%;
                flex-wrap: wrap;
            }
            
            .btn-group .btn {
                margin-bottom: 0.25rem;
            }
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
            
            // Toggle order items visibility
            $(document).on('click', '.view-items', function(e) {
                e.stopPropagation();
                const orderId = $(this).data('order-id');
                const itemsRow = $('#items-' + orderId);
                
                if (itemsRow.length === 0) {
                    console.error('Items row not found for order:', orderId);
                    return;
                }
                
                // Hide all other item rows first
                $('.items-row').not(itemsRow).addClass('d-none');
                
                // Toggle current row
                itemsRow.toggleClass('d-none');
                
                // Update button tooltip
                const isVisible = !itemsRow.hasClass('d-none');
                $(this).attr('title', isVisible ? 'Hide Items' : 'View Items')
                       .tooltip('dispose').tooltip();
                
                // Change icon based on state
                const icon = $(this).find('i');
                if (isVisible) {
                    icon.removeClass('fa-list').addClass('fa-times');
                } else {
                    icon.removeClass('fa-times').addClass('fa-list');
                }
                
                // Scroll to the items if showing
                if (isVisible) {
                    $('html, body').animate({
                        scrollTop: itemsRow.offset().top - 20
                    }, 300);
                }
            });
            
            // Close items button
            $(document).on('click', '.close-items', function(e) {
                e.stopPropagation();
                const orderId = $(this).data('order-id');
                $('#items-' + orderId).addClass('d-none');
                $('.view-items[data-order-id="' + orderId + '"]')
                    .attr('title', 'View Items')
                    .tooltip('dispose').tooltip()
                    .find('i').removeClass('fa-times').addClass('fa-list');
            });
            
            // Dispense item modal setup
            $(document).on('click', '.dispense-item', function() {
                const itemId = $(this).data('item-id');
                const orderId = $(this).data('order-id');
                
                $('#orderItemId').val(itemId);
                $('#orderId').val(orderId);
                
                // Initialize the modal if not already shown
                var dispenseModal = new bootstrap.Modal(document.getElementById('dispenseModal'));
                dispenseModal.show();
                
                // Reset form fields when modal is shown
                $('#dispenseModal').on('shown.bs.modal', function() {
                    $('#dispenseForm')[0].reset();
                });
            });
            
            // Complete order button click handler
            $(document).on('click', '.complete-order', function(e) {
                e.preventDefault();
                const orderId = $(this).data('order-id');
                const button = $(this);
                
                if (window.confirmSwal){
                    confirmSwal({ title:'Mark order as Ready?', icon:'warning', confirmButtonText:'Yes, mark ready' }).then(function(r){ if(!r.isConfirmed){ return; }
                        doComplete();
                    });
                } else {
                    doComplete();
                }

                function doComplete(){
                    button.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i> Processing...');
                    $.ajax({
                        url: '@Url.Action("Complete", "Orders")',
                        type: 'POST',
                        data: { 
                            id: orderId,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() 
                        },
                        success: function(response) {
                            if (response.success) {
                                updateOrderUI(orderId, 'Ready');
                                if(window.showAlert){ showAlert('success','Order marked as ready'); } else { showToast('Order marked as ready', 'success'); }
                                $('#items-' + orderId).addClass('d-none');
                            } else {
                                if(window.showAlert){ showAlert('error', response.error || 'Failed to complete order'); } else { showToast(response.error || 'Failed to complete order', 'danger'); }
                            }
                            button.prop('disabled', false).html('<i class="fas fa-check-circle me-1"></i> Mark as Ready');
                        },
                        error: function(xhr) {
                            if(window.showAlert){ showAlert('error','An error occurred while completing the order'); } else { showToast('An error occurred while completing the order', 'danger'); }
                            button.prop('disabled', false).html('<i class="fas fa-check-circle me-1"></i> Mark as Ready');
                        }
                    });
                }
            });
            
            // Form submission handler for dispensing items
            $('#dispenseForm').submit(function(e) {
                e.preventDefault();
                const form = $(this);
                const submitBtn = form.find('button[type="submit"]');
                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i> Saving...');
                
                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: form.serialize(),
                    success: function(response) {
                        if (response.success) {
                            $('#dispenseModal').modal('hide');
                            showToast('Item dispensing status updated', 'success');
                            
                            // Refresh the items view if open
                            const orderId = $('#orderId').val();
                            if ($('#items-' + orderId).is(':visible')) {
                                // Reload the items section
                                $.get(window.location.href, function(data) {
                                    const newItemsRow = $(data).find('#items-' + orderId);
                                    if (newItemsRow.length) {
                                        $('#items-' + orderId).replaceWith(newItemsRow);
                                    }
                                });
                            }
                        } else {
                            showToast(response.error || 'Failed to update dispensing status', 'danger');
                        }
                        submitBtn.prop('disabled', false).html('Save Changes');
                    },
                    error: function() {
                        showToast('An error occurred while saving', 'danger');
                        submitBtn.prop('disabled', false).html('Save Changes');
                    }
                });
            });
            
            // Function to update order UI after status change
            function updateOrderUI(orderId, newStatus) {
                // Update status badge
                const statusBadge = $('#status-badge-' + orderId);
                statusBadge.removeClass('bg-warning bg-info bg-success bg-danger bg-secondary');
                
                // Update icon and text
                let iconClass, badgeClass;
                switch(newStatus) {
                    case 'Pending':
                        iconClass = 'fas fa-clock';
                        badgeClass = 'bg-warning';
                        break;
                    case 'Processing':
                        iconClass = 'fas fa-spinner fa-pulse';
                        badgeClass = 'bg-info';
                        break;
                    case 'Ready':
                        iconClass = 'fas fa-check-circle';
                        badgeClass = 'bg-success';
                        break;
                    case 'Cancelled':
                        iconClass = 'fas fa-times-circle';
                        badgeClass = 'bg-danger';
                        break;
                    default:
                        iconClass = 'fas fa-question-circle';
                        badgeClass = 'bg-secondary';
                }
                
                statusBadge.addClass(badgeClass);
                statusBadge.html(`<i class="${iconClass} me-1"></i>${newStatus}`);
                
                // Update row background
                const orderRow = $(`tr[data-order-id="${orderId}"]`);
                orderRow.removeClass('table-warning table-info table-success table-danger');
                
                if (newStatus === 'Pending') {
                    orderRow.addClass('table-warning');
                } else if (newStatus === 'Processing') {
                    orderRow.addClass('table-info');
                } else if (newStatus === 'Ready') {
                    orderRow.addClass('table-success');
                }
                
                // Update action buttons
                const actionsCell = $('#actions-' + orderId);
                if (newStatus === 'Processing') {
                    actionsCell.html(`
                        <div class="d-flex justify-content-end gap-1 align-items-center">
                            <button class="btn btn-sm btn-primary rounded-circle view-items"
                                    data-bs-toggle="tooltip" title="View Items"
                                    data-order-id="${orderId}">
                                <i class="fas fa-list"></i>
                            </button>
                        </div>
                    `);
                    
                    // Reinitialize tooltip for the new button
                    new bootstrap.Tooltip(actionsCell.find('.view-items')[0]);
                } else if (newStatus === 'Ready') {
                    actionsCell.html('<span class="text-muted">Completed</span>');
                }
            }
            
            // Function to show toast notifications
            function showToast(message, type) {
                const toast = $(`
                    <div class="toast align-items-center text-white bg-${type} border-0" role="alert" aria-live="assertive" aria-atomic="true">
                        <div class="d-flex">
                            <div class="toast-body">
                                ${message}
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                    </div>
                `);
                
                $('#toastContainer').append(toast);
                const bsToast = new bootstrap.Toast(toast[0]);
                bsToast.show();
                
                // Remove toast after it hides
                toast.on('hidden.bs.toast', function() {
                    toast.remove();
                });
            }
        });
    </script>
}