@model IBhayiPharmacyManagementSystem.Models.UnprocessedScript
@{
    ViewData["Title"] = "Prescription Details";
    Layout = "_LayoutCustomer";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Prescription Details</h1>
            </div>
            <div class="col-sm-6">
                @if (ViewBag.ReturnSource == "ProcessedScripts")
                {
                    <a asp-action="ProcessedScripts" class="btn btn-secondary float-right">
                        <i class="fas fa-arrow-left"></i> Back to Processed Scripts
                    </a>
                }
                else
                {
                    <a asp-action="UnprocessedScripts" class="btn btn-secondary float-right">
                        <i class="fas fa-arrow-left"></i> Back to Unprocessed Scripts
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                <h5><i class="icon fas fa-ban"></i> Error!</h5>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <!-- Prescription Information -->
            <div class="col-md-6">
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-prescription-bottle-alt"></i> Prescription Information
                        </h3>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Reference #:</dt>
                            <dd class="col-sm-8">
                                <span class="badge badge-primary">@Model.UnploadId</span>
                            </dd>

                            <dt class="col-sm-4">Upload Date:</dt>
                            <dd class="col-sm-8">@Model.UploadDate.ToString("dd MMMM yyyy")</dd>

                            <dt class="col-sm-4">Status:</dt>
                            <dd class="col-sm-8">
                                <span class="badge @GetStatusBadgeClass(Model.Status)">
                                    @Model.Status
                                </span>
                            </dd>

                            @if (Model.Status == UnprocessedScript.PrescriptionStatus.Rejected && !string.IsNullOrEmpty(Model.RejectionReason))
                            {
                                <dt class="col-sm-4">Rejection Reason:</dt>
                                <dd class="col-sm-8">
                                    <span class="text-danger">@Model.RejectionReason</span>
                                </dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.ProcessingNotes))
                            {
                                <dt class="col-sm-4">Processing Notes:</dt>
                                <dd class="col-sm-8">@Model.ProcessingNotes</dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.Comments))
                            {
                                <dt class="col-sm-4">Your Comments:</dt>
                                <dd class="col-sm-8">@Model.Comments</dd>
                            }

                            @if (Model.ProcessedDate.HasValue)
                            {
                                <dt class="col-sm-4">Processed Date:</dt>
                                <dd class="col-sm-8">@Model.ProcessedDate.Value.ToString("dd MMMM yyyy HH:mm")</dd>
                            }

                            @if (Model.ProcessedBy != null)
                            {
                                <dt class="col-sm-4">Processed By:</dt>
                                <dd class="col-sm-8">@Model.ProcessedBy.FullName</dd>
                            }
                        </dl>
                    </div>
                </div>
            </div>

            <!-- Prescription File Section -->
            <div class="col-md-6">
                <div class="card card-info">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-file-prescription"></i> Prescription Document
                        </h3>
                    </div>
                    <div class="card-body">
                        @if (Model.FileContent != null && Model.FileContent.Length > 0 || !string.IsNullOrEmpty(Model.ScriptImagePath))
                        {
                            var fileName = !string.IsNullOrEmpty(Model.FileName) ? Model.FileName : Model.ScriptImagePath;
                            var fileExtension = System.IO.Path.GetExtension(fileName ?? "").ToLower();
                            var isImage = new[] { ".jpg", ".jpeg", ".png", ".heic" }.Contains(fileExtension);
                            var displayUrl = Model.FileContent != null && Model.FileContent.Length > 0 
                                ? Url.Action("ServePrescriptionFile", "UnprocessedScripts", new { id = Model.UnploadId })
                                : Model.ScriptImagePath;

                            <div class="text-center mb-3">
                                @if (isImage)
                                {
                                    <img src="@displayUrl" class="img-fluid rounded border" 
                                         alt="Prescription image" style="max-height: 300px;" />
                                }
                                else if (fileExtension == ".pdf")
                                {
                                    <div class="pdf-container">
                                        <iframe src="@displayUrl" 
                                                style="width: 100%; height: 300px; border: 1px solid #dee2e6; border-radius: 0.375rem;"
                                                title="Prescription PDF">
                                            <p>Your browser does not support PDF viewing. 
                                            <a href="@displayUrl" target="_blank">Click here to view</a> the PDF.</p>
                                        </iframe>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-warning">
                                        <i class="far fa-file-alt fa-3x text-secondary mb-2"></i>
                                        <p>File type cannot be previewed.</p>
                                    </div>
                                }
                            </div>

                            <div class="text-center">
                                <a asp-action="DownloadPrescription" asp-route-id="@Model.UnploadId" 
                                   class="btn btn-primary">
                                    <i class="fas fa-download me-1"></i> Download File
                                </a>
                                <small class="d-block text-muted mt-2">
                                    File: @(!string.IsNullOrEmpty(Model.FileName) ? Model.FileName : System.IO.Path.GetFileName(Model.ScriptImagePath ?? "Unknown"))
                                </small>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning text-center">
                                <i class="fas fa-exclamation-triangle fa-2x mb-2"></i>
                                <p class="mb-0">No prescription file available.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Prescription Items Section (if available) -->
        @if (Model.Prescription?.PrescriptionLines != null && Model.Prescription.PrescriptionLines.Any())
        {
            <div class="row">
                <div class="col-12">
                    <div class="card card-success">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="fas fa-pills"></i> Prescription Items
                            </h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Medication</th>
                                        <th>Quantity</th>
                                        <th>Instructions</th>
                                        <th>Frequency</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Prescription.PrescriptionLines)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@item.Medication?.Name</strong>
                                                @if (!string.IsNullOrEmpty(item.Medication?.ActiveIngredients?.FirstOrDefault()?.Strength))
                                                {
                                                    <br><small class="text-muted">(@item.Medication?.ActiveIngredients?.FirstOrDefault()?.Strength)</small>
                                                }
                                            </td>
                                            <td>@item.Quantity</td>
                                            <td>@item.Instructions</td>
                                            <td>@item.Frequency</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Action Buttons -->
        <div class="row">
            <div class="col-12">
                <!-- Hidden anti-forgery token for JavaScript -->
                @Html.AntiForgeryToken()
                <div class="card">
                    <div class="card-body text-center">
                        @if (ViewBag.ReturnSource == "ProcessedScripts")
                        {
                            <a asp-action="ProcessedScripts" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back to Processed Scripts
                            </a>
                        }
                        else
                        {
                            <a asp-action="UnprocessedScripts" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back to Unprocessed Scripts
                            </a>
                        }
                        @if (Model.Status == UnprocessedScript.PrescriptionStatus.Pending)
                        {
                            <span class="mx-2">|</span>
                            <button type="button" class="btn btn-danger" id="deletePrescriptionBtn" data-prescription-id="@Model.UnploadId">
                                <i class="fas fa-trash"></i> Delete Prescription
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@functions {
    string GetStatusBadgeClass(UnprocessedScript.PrescriptionStatus status)
    {
        return status switch
        {
            UnprocessedScript.PrescriptionStatus.Pending => "badge-secondary",
            UnprocessedScript.PrescriptionStatus.Processing => "badge-warning",
            UnprocessedScript.PrescriptionStatus.Rejected => "badge-danger",
            UnprocessedScript.PrescriptionStatus.Completed => "badge-success",
            _ => "badge-info"
        };
    }
}

@section Scripts {
    <script>
        $(document).ready(function() {
            // Enable tooltips
            $('[title]').tooltip();
            
            // Handle delete prescription with SweetAlert2
            $('#deletePrescriptionBtn').on('click', function(e) {
                e.preventDefault();
                var prescriptionId = $(this).data('prescription-id');
                
                Swal.fire({
                    title: 'Delete Prescription?',
                    html: `
                        <div style="text-align: left; margin: 20px 0;">
                            <p style="margin-bottom: 15px; font-size: 16px;">Are you sure you want to delete prescription reference:</p>
                            <div style="background: #f8f9fa; padding: 15px; border-radius: 8px; border-left: 4px solid #dc3545;">
                                <strong style="color: #2c3e50; font-size: 18px;">#${prescriptionId}</strong>
                            </div>
                            <p style="margin-top: 15px; color: #6c757d; font-size: 14px;">
                                <i class="fas fa-exclamation-triangle mr-2"></i>
                                This action cannot be undone.
                            </p>
                        </div>
                    `,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fas fa-trash mr-2"></i>Yes, Delete',
                    cancelButtonText: '<i class="fas fa-times mr-2"></i>Cancel',
                    reverseButtons: true,
                    focusCancel: true,
                    customClass: {
                        popup: 'swal2-popup-custom',
                        title: 'swal2-title-custom',
                        confirmButton: 'swal2-confirm-custom',
                        cancelButton: 'swal2-cancel-custom'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Show loading modal
                        Swal.fire({
                            title: 'Deleting...',
                            html: '<div style="text-align: center; margin: 20px 0;"><i class="fas fa-spinner fa-spin" style="font-size: 48px; color: #007bff; margin-bottom: 15px;"></i><p style="font-size: 16px; color: #2c3e50;">Please wait while we delete the prescription.</p></div>',
                            allowOutsideClick: false,
                            allowEscapeKey: false,
                            showConfirmButton: false,
                            customClass: {
                                popup: 'swal2-popup-custom',
                                title: 'swal2-title-custom'
                            }
                        });
                        
                        // Create and submit form
                        var form = $('<form>', {
                            'method': 'POST',
                            'action': '@Url.Action("Delete", "UnprocessedScripts")'
                        });
                        
                        form.append($('<input>', {
                            'type': 'hidden',
                            'name': 'id',
                            'value': prescriptionId
                        }));
                        
                        form.append($('<input>', {
                            'type': 'hidden',
                            'name': '__RequestVerificationToken',
                            'value': $('input[name="__RequestVerificationToken"]').val()
                        }));
                        
                        $('body').append(form);
                        form.submit();
                    }
                });
            });
        });
    </script>
}
