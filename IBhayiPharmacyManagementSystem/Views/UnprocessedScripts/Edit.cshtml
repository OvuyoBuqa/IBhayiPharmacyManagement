@model IBhayiPharmacyManagementSystem.ViewModels.EditUnprocessedScriptViewModel
@{
    ViewData["Title"] = "Edit Prescription";
    Layout = "_LayoutCustomer";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Edit Prescription</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="UnprocessedScripts">Unprocessed Scripts</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                <h5><i class="icon fas fa-ban"></i> Error!</h5>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-md-8">
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Edit Prescription #@Model.UnploadId</h3>
                    </div>
                    <form asp-action="Edit" asp-route-id="@Model.UnploadId" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="card-body">
                            <div asp-validation-summary="All" class="text-danger"></div>
                            <input type="hidden" asp-for="UnploadId" />
                            <input type="hidden" asp-for="CustomerId" />
                            <input type="hidden" asp-for="UploadDate" />
                            <input type="hidden" asp-for="ScriptImagePath" />
                            <input type="hidden" asp-for="Status" />
                            <input type="hidden" asp-for="ProcessedById" />
                            <input type="hidden" asp-for="ProcessedDate" />

                            <div class="form-group">
                                <label asp-for="Comments" class="control-label">Comments</label>
                                <textarea asp-for="Comments" class="form-control" rows="3" placeholder="Enter any additional comments about this prescription..."></textarea>
                                <span asp-validation-for="Comments" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <div class="form-check">
                                    <input asp-for="RequestDispensation" class="form-check-input" type="checkbox" />
                                    <label asp-for="RequestDispensation" class="form-check-label">
                                        Request Dispensation
                                    </label>
                                </div>
                                <small class="form-text text-muted">Check this box if you need this prescription to be dispensed by the pharmacy.</small>
                                <span asp-validation-for="RequestDispensation" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label class="control-label">Current File</label>
                                @if (!string.IsNullOrEmpty(Model.ScriptImagePath) || Model.FileContent != null)
                                {
                                    <div class="mt-2">
                                        <a href="@Url.Action("ServePrescriptionFile", "UnprocessedScripts", new { id = Model.UnploadId })" target="_blank" class="btn btn-sm btn-outline-primary" title="View Current Prescription File" aria-label="View Current Prescription File">
                                            <i class="fas fa-external-link-alt" aria-hidden="true"></i> View Current File
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">No file available</p>
                                }
                            </div>

                            <div class="form-group">
                                <label for="newPrescriptionFile" class="control-label">Update Prescription File</label>
                                <div class="input-group">
                                    <div class="custom-file">
                                        <input type="file" class="custom-file-input" id="newPrescriptionFile" name="NewScriptImage" accept=".pdf,.jpg,.jpeg,.png,.heic">
                                        <label class="custom-file-label" for="newPrescriptionFile">Choose new file (optional)</label>
                                    </div>
                                </div>
                                <small class="form-text text-muted">Upload a new file to replace the current prescription. Leave empty to keep current file. Accepted formats: PDF, JPG, PNG, HEIC. Maximum size: 10MB</small>
                            </div>
                        </div>

                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary" title="Save all changes to this prescription" aria-label="Save Changes">
                                <i class="fas fa-save" aria-hidden="true"></i> Save Changes
                            </button>
                            <a asp-action="UnprocessedScripts" class="btn btn-secondary" title="Return to unprocessed scripts list" aria-label="Back to List">
                                <i class="fas fa-arrow-left" aria-hidden="true"></i> Back to List
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card card-info">
                    <div class="card-header">
                        <h3 class="card-title">Prescription Information</h3>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-5">Reference #:</dt>
                            <dd class="col-sm-7">@Model.UnploadId</dd>

                            <dt class="col-sm-5">Upload Date:</dt>
                            <dd class="col-sm-7">@Model.UploadDate.ToString("yyyy-MM-dd")</dd>

                            <dt class="col-sm-5">Status:</dt>
                            <dd class="col-sm-7">
                                <span class="badge badge-secondary">@Model.Status</span>
                            </dd>

                            <dt class="col-sm-5">Current Dispensation:</dt>
                            <dd class="col-sm-7">
                                @if (Model.RequestDispensation)
                                {
                                    <span class="badge badge-info">Yes</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">No</span>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>

                <div class="card card-warning">
                    <div class="card-header">
                        <h3 class="card-title">Important Notes</h3>
                    </div>
                    <div class="card-body">
                        <ul class="mb-0">
                            <li>Only pending prescriptions can be edited</li>
                            <li>You can update the prescription file if needed</li>
                            <li>Changes will be reviewed by our pharmacy team</li>
                            <li>File updates are seamless and transparent</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            // File input handling
            $('#newPrescriptionFile').on('change', function () {
                const file = this.files[0];
                if (file) {
                    // Check if file is PDF, JPG, JPEG, PNG, or HEIC
                    const allowedMimeTypes = ['application/pdf', 'image/jpeg', 'image/png', 'image/heic'];
                    if (!allowedMimeTypes.includes(file.type)) {
                        alert('Only PDF, JPG, PNG, or HEIC files are allowed. Please select a valid file type.');
                        this.value = '';
                        $(this).next('.custom-file-label').text('Choose new file (optional)');
                        return;
                    }
                    
                    // Check file size (10MB limit)
                    if (file.size > 10 * 1024 * 1024) {
                        alert('File size cannot exceed 10MB. Please select a smaller file.');
                        this.value = '';
                        $(this).next('.custom-file-label').text('Choose new file (optional)');
                        return;
                    }
                    
                    $(this).next('.custom-file-label').text(file.name);
                } else {
                    $(this).next('.custom-file-label').text('Choose new file (optional)');
                }
            });

            // Form submission handling
            $('form').on('submit', function(e) {
                console.log('Form submission started');
                
                // Show loading state
                $('button[type="submit"]').prop('disabled', true).html('<i class="fas fa-spinner fa-spin" aria-hidden="true"></i> Saving...');
                
                // Let the form submit naturally
                return true;
            });
        });
    </script>
}
