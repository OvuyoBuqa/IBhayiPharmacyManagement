@{
    ViewData["Title"] = "Registration Successful";
    Layout = "_LayoutPharmacyManger";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white text-center">
                    <h4 class="mb-0">
                        <i class="fas fa-check-circle me-2"></i>
                        Registration Successful
                    </h4>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="fas fa-user-check text-success" style="font-size: 4rem;"></i>
                    </div>
                    
                    <h5 class="text-success mb-3">Staff Member Registered Successfully!</h5>
                    
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Next Steps:</strong>
                        <ul class="list-unstyled mt-2 mb-0">
                            <li>• The new staff member will receive an email with their temporary password</li>
                            <li>• They should log in and change their password immediately</li>
                            <li>• The staff member can now access the system with their assigned role</li>
                        </ul>
                    </div>

                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a asp-controller="StaffRegistration" asp-action="Register" class="btn btn-pharmacy-primary">
                            <i class="fas fa-user-plus me-2"></i>Register Another Staff Member
                        </a>
                        <a asp-controller="Pharmacists" asp-action="Index" class="btn btn-pharmacy-info">
                            <i class="fas fa-users me-2"></i>View All Pharmacists
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-home me-2"></i>Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>