@model IBhayiPharmacyManagementSystem.Models.DosageForm

@{
    ViewData["Title"] = "Add Dosage Form";
    Layout = "_LayoutPharmacyManger";
}

<div class="container mt-4">
    <div class="pharmacy-table-container">
        <h2 class="pharmacy-table-header">
            <i class="fas fa-pills mr-2"></i> @ViewData["Title"]
        </h2>

        <div class="row">
            <div class="col-md-6">
                <form asp-action="AddDosageForm" id="dosageForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label for="dosageTypeSelect" class="control-label">Form Type</label>
                        <select class="form-control" required asp-items="ViewBag.DosageTypes" id="dosageTypeSelect">
                            <option value="">-- Select Form Type --</option>
                        </select>
                        <span asp-validation-for="Type" class="text-danger"></span>
                    </div>

                    <div class="form-group" id="customDosageTypeGroup" style="display: none;">
                        <label for="customDosageType" class="control-label">Custom Dosage Type</label>
                        <input type="text" id="customDosageType" class="form-control" placeholder="Enter custom dosage type" />
                        <span class="text-danger" id="customDosageTypeError"></span>
                    </div>
                    
                    <!-- Hidden input to store the actual type value -->
                    <input type="hidden" id="actualTypeValue" name="Type" />

                    <div class="form-group">
                        <label asp-for="Description" class="control-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Optional description"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <a asp-action="DosageForms" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                        <button type="submit" class="btn btn-pharmacy-primary">
                            <i class="fas fa-save"></i> Save
                        </button>
                    </div>
                </form>
            </div>
            <div class="col-md-6">
                <div class="card bg-light">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-info-circle mr-2"></i>Common Dosage Forms</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">Tablet - Solid dosage form</li>
                            <li class="list-group-item">Capsule - Gelatin shell containing medication</li>
                            <li class="list-group-item">Syrup - Liquid medication with sweetener</li>
                            <li class="list-group-item">Injection - Sterile liquid for parenteral use</li>
                            <li class="list-group-item">Ointment - Semi-solid for external application</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function() {
            // Handle "Other" option selection
            $('#dosageTypeSelect').change(function() {
                var selectedValue = $(this).val();
                var customGroup = $('#customDosageTypeGroup');
                var customInput = $('#customDosageType');
                var customError = $('#customDosageTypeError');
                var hiddenInput = $('#actualTypeValue');
                
                if (selectedValue === 'Other') {
                    customGroup.show();
                    customInput.prop('required', true);
                    customInput.focus();
                    // Clear the hidden input when "Other" is selected
                    hiddenInput.val('');
                } else {
                    customGroup.hide();
                    customInput.prop('required', false);
                    customInput.val('');
                    customError.text('');
                    customInput.removeClass('is-invalid');
                    // Set the selected value to the hidden input
                    hiddenInput.val(selectedValue);
                }
                
                // Remove invalid class when user selects an option
                if (selectedValue !== '') {
                    $(this).removeClass('is-invalid');
                }
            });

            // Form validation
            $('#dosageForm').submit(function(e) {
                var selectedType = $('#dosageTypeSelect').val();
                var customType = $('#customDosageType').val();
                var hiddenInput = $('#actualTypeValue');
                var isValid = true;
                
                // Clear previous errors
                $('#customDosageTypeError').text('');
                $('#customDosageType').removeClass('is-invalid');
                $('#dosageTypeSelect').removeClass('is-invalid');
                
                if (selectedType === '') {
                    e.preventDefault();
                    $('#dosageTypeSelect').addClass('is-invalid');
                    isValid = false;
                } else if (selectedType === 'Other') {
                    if (customType.trim() === '') {
                        e.preventDefault();
                        $('#customDosageType').addClass('is-invalid');
                        $('#customDosageTypeError').text('Please enter a custom dosage type.');
                        isValid = false;
                    } else if (customType.trim().length < 2) {
                        e.preventDefault();
                        $('#customDosageType').addClass('is-invalid');
                        $('#customDosageTypeError').text('Custom dosage type must be at least 2 characters long.');
                        isValid = false;
                    } else {
                        // Set the custom value to the hidden input
                        hiddenInput.val(customType.trim());
                    }
                } else {
                    // For predefined types, set the value to the hidden input
                    hiddenInput.val(selectedType);
                }
                
                return isValid;
            });

            // Real-time validation for custom input
            $('#customDosageType').on('input', function() {
                var value = $(this).val().trim();
                var errorSpan = $('#customDosageTypeError');
                
                if (value.length > 0 && value.length < 2) {
                    $(this).addClass('is-invalid');
                    errorSpan.text('Custom dosage type must be at least 2 characters long.');
                } else {
                    $(this).removeClass('is-invalid');
                    errorSpan.text('');
                }
            });
        });
    </script>
}