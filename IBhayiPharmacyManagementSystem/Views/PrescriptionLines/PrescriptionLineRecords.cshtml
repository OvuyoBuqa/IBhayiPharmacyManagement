@model IEnumerable<IBhayiPharmacyManagementSystem.Models.PrescriptionLine>
@{
    ViewData["Title"] = "Prescription Line Records";
    Layout = "_LayoutPharmacist";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

    <!-- DataTables CSS -->
    <link href="https://cdn.datatables.net/1.11.3/css/dataTables.bootstrap5.min.css" rel="stylesheet">

    <style>
        /* Custom CSS */
        .card {
            border-radius: 0.35rem;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
        }

        .card-header {
            background-color: #f8f9fc;
            border-bottom: 1px solid #e3e6f0;
        }

        .table th {
            position: sticky;
            top: 0;
            background-color: #5a5c69;
            color: white;
        }

        .table-striped tbody tr:nth-of-type(odd) {
            background-color: rgba(0, 0, 0, 0.02);
        }

        .table-hover tbody tr:hover {
            background-color: rgba(0, 0, 0, 0.075);
        }


        body {
            background-color: white !important;
            color: black !important;
            padding: 20px !important;
        }

        .table {
            border: 1px solid #dee2e6;
            width: 100% !important;
        }

            .table th {
                background-color: #5a5c69 !important;
                color: white !important;
                -webkit-print-color-adjust: exact;
            }

            .table td, .table th {
                padding: 8px !important;
            }

        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Prescription Line Records</h6>
                <button class="btn btn-primary no-print" onclick="window.print()">
                    <i class="fas fa-print"></i> Print Report
                </button>
            </div>
            <div class="card-body">
                <!-- Filter Section -->
                <div class="row mb-4 no-print">
                    <div class="col-md-12">
                        <form asp-action="PrescriptionLineRecords" method="get" class="form-inline">
                            <div class="form-group mr-3">
                                <label class="mr-2">Customer:</label>
                                <select name="customerId" asp-items="ViewBag.CustomerId" class="form-control">
                                    <option value="">All Customers</option>
                                </select>
                            </div>
                            <div class="form-group mr-3">
                                <label class="mr-2">From:</label>
                                <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" />
                            </div>
                            <div class="form-group mr-3">
                                <label class="mr-2">To:</label>
                                <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control" />
                            </div>
                            <button type="submit" class="btn btn-primary mr-2">
                                <i class="fas fa-filter"></i> Filter
                            </button>
                            <a asp-action="PrescriptionLineRecords" class="btn btn-secondary">
                                <i class="fas fa-sync-alt"></i> Reset
                            </a>
                        </form>
                    </div>
                </div>

                <!-- Records Table -->
                <div class="table-responsive">
                    <table class="table table-bordered table-striped table-hover" id="dataTable" width="100%" cellspacing="0">
                        <thead class="thead-dark">
                            <tr>
                                <th>Prescription Date</th>
                                <th>Customer</th>
                                <th>Medication</th>
                                <th>Quantity</th>
                                <th>Dosage</th>
                                <th>Instructions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Prescription?.PrescriptionDate.ToString("dd MMM yyyy")</td>
                                    <td>@item.Prescription?.Customer?.Name</td>
                                    <td>@item.Medication?.Name</td>
                                    <td class="text-right">@item.Quantity</td>
                                    <td>@item.Frequency</td>
                                    <td>@item.Instructions</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- jQuery and DataTables JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.3/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.3/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#dataTable').DataTable({
                "order": [[0, "desc"]], // Default sort by prescription date descending
                "pageLength": 25,
                "dom": '<"top"f>rt<"bottom"lip><"clear">',
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search records..."
                }
            });
        });
    </script>
</body>
</html>