@model IEnumerable<IBhayiPharmacyManagementSystem.Models.Prescription>

@{
    ViewData["Title"] = "Prescriptions";
    
    // Determine layout based on user role
    if (User.IsInRole("Customer"))
    {
        Layout = "_LayoutCustomer";
    }
    else if (User.IsInRole("Pharmacist"))
    {
        Layout = "_LayoutPharmacist";
    }
    else if (User.IsInRole("PharmacyManager"))
    {
        Layout = "_LayoutPharmacyManger";
    }
    else if (User.IsInRole("Admin"))
    {
        Layout = "_Layout";
    }
    else
    {
        Layout = "_Layout";
    }
}

<div class="container-fluid px-4 py-3">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom-0 py-3">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                <div class="mb-3 mb-md-0">
                    <h1 class="h4 mb-1">
                        <i class="fas fa-prescription-bottle-alt text-primary me-2"></i>Prescriptions
                    </h1>
                    <p class="text-muted mb-0">Manage and view all prescriptions</p>
                </div>
                
                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i> New Prescription
                    </a>
                    <a asp-action="PendingScripts" class="btn btn-outline-primary">
                        <i class="fas fa-clock me-1"></i> Pending Scripts
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible rounded-0 border-start-0 border-end-0 border-top-0 mb-0">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-check-circle me-2"></i>
                        <div>@TempData["SuccessMessage"]</div>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible rounded-0 border-start-0 border-end-0 border-top-0 mb-0">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <div>@TempData["ErrorMessage"]</div>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Prescription ID</th>
                            <th>Customer</th>
                            <th>Doctor</th>
                            <th>Pharmacist</th>
                            <th>Prescription Date</th>
                            <th>Items</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var prescription in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold text-primary">#@prescription.PrescriptionId</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm bg-light rounded-circle d-flex align-items-center justify-content-center me-2">
                                                <i class="fas fa-user text-muted"></i>
                                            </div>
                                            <div>
                                                <div class="fw-medium">@prescription.Customer?.Name</div>
                                                <small class="text-muted">ID: @prescription.Customer?.IDNumber</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (prescription.Doctor != null)
                                        {
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm bg-light-primary rounded-circle d-flex align-items-center justify-content-center me-2">
                                                    <i class="fas fa-user-md text-primary"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-medium">@prescription.Doctor.Name @prescription.Doctor.Surname</div>
                                                    <small class="text-muted">@prescription.Doctor.PracticeNumber</small>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not assigned</span>
                                        }
                                    </td>
                                    <td>
                                        @if (prescription.Pharmacist != null)
                                        {
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm bg-light-success rounded-circle d-flex align-items-center justify-content-center me-2">
                                                    <i class="fas fa-user-nurse text-success"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-medium">@prescription.Pharmacist.Name @prescription.Pharmacist.Surname</div>
                                                    <small class="text-muted">@prescription.Pharmacist.RegistrationNumber</small>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not assigned</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="text-nowrap">@prescription.PrescriptionDate.ToString("MMM dd, yyyy")</div>
                                        <small class="text-muted">@prescription.PrescriptionDate.ToString("h:mm tt")</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @(prescription.PrescriptionLines?.Count ?? 0) items
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a asp-action="Details" asp-route-id="@prescription.PrescriptionId" 
                                               class="btn btn-sm btn-outline-info rounded-pill px-3"
                                               data-bs-toggle="tooltip" title="View details">
                                                <i class="fas fa-eye me-1"></i> View
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@prescription.PrescriptionId" 
                                               class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                               data-bs-toggle="tooltip" title="Edit prescription">
                                                <i class="fas fa-edit me-1"></i> Edit
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 delete-btn"
                                                    data-id="@prescription.PrescriptionId" 
                                                    data-bs-toggle="tooltip" title="Delete prescription">
                                                <i class="fas fa-trash me-1"></i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="d-flex flex-column align-items-center">
                                        <i class="fas fa-prescription-bottle-alt text-muted mb-3" style="font-size: 3rem;"></i>
                                        <h5 class="text-muted">No prescriptions found</h5>
                                        <p class="text-muted mb-3">Get started by creating a new prescription or processing pending scripts.</p>
                                        <div class="d-flex gap-2">
                                            <a asp-action="Create" class="btn btn-primary">
                                                <i class="fas fa-plus me-1"></i> New Prescription
                                            </a>
                                            <a asp-action="PendingScripts" class="btn btn-outline-primary">
                                                <i class="fas fa-clock me-1"></i> Pending Scripts
                                            </a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="card-footer bg-white border-top-0 py-3">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
                    <div class="mb-2 mb-md-0">
                        <span class="text-muted">Showing <strong>@Model.Count()</strong> prescriptions</span>
                    </div>
                    <div>
                        <nav aria-label="Page navigation">
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item disabled">
                                    <a class="page-link" href="#" tabindex="-1" aria-disabled="true">Previous</a>
                                </li>
                                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                                <li class="page-item"><a class="page-link" href="#">2</a></li>
                                <li class="page-item"><a class="page-link" href="#">3</a></li>
                                <li class="page-item">
                                    <a class="page-link" href="#">Next</a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i> Confirm Delete
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-circle me-2"></i> 
                    This action cannot be undone. Are you sure you want to delete this prescription?
                </div>
                <p class="mb-0">This will permanently remove the prescription and all associated data.</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger rounded-pill px-4">
                        <i class="fas fa-trash me-1"></i> Delete Prescription
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .avatar-sm {
            width: 32px;
            height: 32px;
            font-size: 14px;
        }
        .badge-pill {
            border-radius: 50rem;
        }
        .table-light th {
            background-color: #f8f9fa;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            color: #6c757d;
        }
        .table-hover tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.05);
        }
        .rounded-pill {
            padding-left: 1rem;
            padding-right: 1rem;
        }
        .dropdown-menu {
            border: 0;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1);
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            // Enable tooltips
            $('[data-bs-toggle="tooltip"]').tooltip({
                trigger: 'hover'
            });

            // Delete button click handler
            $('.delete-btn').click(function() {
                var prescriptionId = $(this).data('id');
                $('#deleteForm').attr('action', '/Prescriptions/Delete/' + prescriptionId);
                $('#deleteModal').modal('show');
            });

            // Handle form submission
            $('#deleteForm').submit(function(e) {
                e.preventDefault();
                
                var form = $(this);
                var url = form.attr('action');
                
                $.ajax({
                    type: "POST",
                    url: url,
                    data: form.serialize(),
                    success: function(data) {
                        $('#deleteModal').modal('hide');
                        location.reload();
                    },
                    error: function() {
                        alert('An error occurred while deleting the prescription.');
                    }
                });
            });
        });
    </script>
}
