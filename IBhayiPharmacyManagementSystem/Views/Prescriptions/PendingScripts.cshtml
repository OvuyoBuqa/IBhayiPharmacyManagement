@model List<IBhayiPharmacyManagementSystem.Models.UnprocessedScript>
@using IBhayiPharmacyManagementSystem.Models
@using PrescriptionStatus = IBhayiPharmacyManagementSystem.Models.UnprocessedScript.PrescriptionStatus
@{
    ViewData["Title"] = "Prescription Management";
    Layout = "_LayoutPharmacist";
}

<div class="container-fluid px-4 py-3">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom-0 py-3">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                <div class="mb-3 mb-md-0">
                    <h1 class="h4 mb-1">
                        <i class="fas fa-prescription-bottle-alt text-primary me-2"></i>Prescription Management
                    </h1>
                    <p class="text-muted mb-0">Review and process patient prescriptions</p>
                </div>
                
                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="PendingScripts" 
                       class="btn btn-sm @(ViewBag.StatusFilter == null ? "btn-primary" : "btn-outline-primary")">
                        All Active
                    </a>
                    @foreach (PrescriptionStatus status in Enum.GetValues(typeof(PrescriptionStatus)))
                    {
                        <a asp-action="PendingScripts" asp-route-status="@status"
                           class="btn btn-sm @(ViewBag.StatusFilter == status ? GetStatusButtonClass(status, true) : GetStatusButtonClass(status, false))">
                            <i class="@GetStatusIcon(status) me-1"></i> @status
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            @{  
                // Determine the latest completed prescription on this page
                var latestCompletedDate = Model
                    .Where(m => m.Status == PrescriptionStatus.Completed)
                    .Select(m => m.UploadDate)
                    .DefaultIfEmpty()
                    .Max();
            }
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible rounded-0 border-start-0 border-end-0 border-top-0 mb-0">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-check-circle me-2"></i>
                        <div>@TempData["SuccessMessage"]</div>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Ref #</th>
                            <th>Patient</th>
                            <th>Prescription File</th>
                            <th>Dispensation Request</th>
                            <th>Status</th>
                            <th>Uploaded</th>
                            <th>Processed By</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var script in Model)
                        {
                            var isLatestCompleted = script.Status == PrescriptionStatus.Completed && script.UploadDate == latestCompletedDate;
                            <tr class="@(isLatestCompleted ? "latest-completed" : (script.Status == PrescriptionStatus.Rejected ? "table-danger-light" : ""))">
                                <td class="ps-4 fw-semibold text-primary">#@script.UnploadId</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-light rounded-circle d-flex align-items-center justify-content-center me-2">
                                            <i class="fas fa-user text-muted"></i>
                                        </div>
                                        <div>
                                            <div class="fw-medium">@script.Customer?.Name</div>
                                            <small class="text-muted">ID: @script.Customer?.IDNumber</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(script.ScriptImagePath))
                                    {
                                        <div class="d-flex align-items-center">
                                            <div class="me-2">
                                                @{
                                                    var fileExtension = System.IO.Path.GetExtension(script.ScriptImagePath).ToLower();
                                                    var iconClass = fileExtension switch {
                                                        ".pdf" => "far fa-file-pdf text-danger",
                                                        ".jpg" or ".jpeg" or ".png" or ".heic" => "far fa-file-image text-primary",
                                                        _ => "far fa-file text-secondary"
                                                    };
                                                }
                                                <i class="@iconClass fa-lg"></i>
                                            </div>
                                            <div>
                                                <a asp-action="DownloadPrescription" asp-route-id="@script.UnploadId" 
                                                   class="d-block text-primary fw-medium" title="Download prescription">
                                                    Download File
                                                </a>
                                                <small class="text-muted">@System.IO.Path.GetFileName(script.ScriptImagePath)</small>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No file</span>
                                    }
                                </td>
                                <td>
                                    @if (script.RequestDispensation)
                                    {
                                        <div class="d-flex flex-column">
                                            <span class="badge bg-success badge-pill py-1 px-2 mb-1">
                                                <i class="fas fa-check-circle me-1"></i> Dispensation Requested
                                            </span>
                                            <small class="text-success">
                                                <i class="fas fa-info-circle me-1"></i> Customer wants medication dispensed
                                            </small>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex flex-column">
                                            <span class="badge bg-secondary badge-pill py-1 px-2 mb-1">
                                                <i class="fas fa-clock me-1"></i> Review Only
                                            </span>
                                            <small class="text-muted">
                                                <i class="fas fa-info-circle me-1"></i> For review and consultation
                                            </small>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <span class="badge @GetStatusBadgeClass(script.Status) badge-pill py-1 px-2">
                                        <i class="@GetStatusIcon(script.Status) me-1"></i> @script.Status
                                    </span>
                                    @if (script.Status == PrescriptionStatus.Rejected && !string.IsNullOrEmpty(script.RejectionReason))
                                    {
                                        <small class="d-block text-danger mt-1">
                                            <i class="fas fa-info-circle me-1"></i> @script.RejectionReason
                                        </small>
                                    }
                                </td>
                                <td>
                                    <div class="text-nowrap">@script.UploadDate.ToString("MMM dd, yyyy")</div>
                                    @if (script.ProcessedDate.HasValue)
                                    {
                                        <small class="text-muted">Processed: @script.ProcessedDate.Value.ToString("MMM dd, yyyy")</small>
                                    }
                                </td>
                                <td>
                                    @if (script.ProcessedBy != null)
                                    {
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm bg-light-primary rounded-circle d-flex align-items-center justify-content-center me-2">
                                                <i class="fas fa-user-md text-primary"></i>
                                            </div>
                                            <div>
                                                <div>@script.ProcessedBy.FullName</div>
                                                @if (script.ProcessedDate.HasValue)
                                                {
                                                    <small class="text-muted">@script.ProcessedDate.Value.ToString("MMM dd, h:mm tt")</small>
                                                }
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        @{
                                            var isImage = !string.IsNullOrEmpty(script.ScriptImagePath) && 
                                                         new[] { ".jpg", ".jpeg", ".png", ".heic" }.Contains(
                                                             System.IO.Path.GetExtension(script.ScriptImagePath).ToLower());
                                        }
                                      
                                        
                                        @if (script.Status == PrescriptionStatus.Completed)
                                        {
                                            <a asp-action="ScriptDetails" asp-controller="Prescriptions" asp-route-id="@script.UnploadId" 
                                               class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                               data-bs-toggle="tooltip" title="View details">
                                                <i class="fas fa-eye me-1"></i> View Details
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-action="Process" asp-controller="Prescriptions" asp-route-id="@script.UnploadId" 
                                               class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                               data-bs-toggle="tooltip" title="Process prescription">
                                                <i class="fas fa-clipboard-check me-1"></i> Process 
                                            </a>
                                        }
                                        
                                        @if (script.Status == PrescriptionStatus.Pending)
                                        {
                                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@script.UnploadId" />
                                                <input type="hidden" name="status" value="@PrescriptionStatus.Processing" />
                                                <button type="submit" class="btn btn-sm btn-warning rounded-pill px-3"
                                                        data-bs-toggle="tooltip" title="Start processing">
                                                    <i class="fas fa-spinner"></i>
                                                </button>
                                            </form>
                                        }
                                        else if (script.Status == PrescriptionStatus.Processing)
                                        {
                                            <div class="dropdown d-inline">
                                                <button class="btn btn-sm btn-light rounded-pill px-3 dropdown-toggle"
                                                        type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                                        data-bs-toggle="tooltip" title="More actions">
                                                    <i class="fas fa-ellipsis-h"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                                    <li>
                                                        <form asp-action="UpdateStatus" method="post">
                                                            <input type="hidden" name="id" value="@script.UnploadId" />
                                                            <input type="hidden" name="status" value="@PrescriptionStatus.Completed" />
                                                            <button type="submit" class="dropdown-item">
                                                                <i class="fas fa-check-circle text-success me-2"></i> Complete
                                                            </button>
                                                        </form>
                                                    </li>
                                                    <li>
                                                        <button type="button" class="dropdown-item" 
                                                                data-bs-toggle="modal" data-bs-target="#rejectModal_@script.UnploadId">
                                                            <i class="fas fa-times-circle text-danger me-2"></i> Reject
                                                        </button>
                                                    </li>
                                                    <li>
                                                        <form asp-action="UpdateStatus" method="post">
                                                            <input type="hidden" name="id" value="@script.UnploadId" />
                                                            <input type="hidden" name="status" value="@PrescriptionStatus.Pending" />
                                                            <button type="submit" class="dropdown-item">
                                                                <i class="fas fa-undo text-secondary me-2"></i> Return to Pending
                                                            </button>
                                                        </form>
                                                    </li>
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>

                            <!-- Preview Modal for Images -->
                            @if (isImage)
                            {
                                var imageUrl = (script.FileContent != null && script.FileContent.Length > 0)
                                    ? Url.Action("ServePrescriptionFile", "UnprocessedScripts", new { id = script.UnploadId })
                                    : script.ScriptImagePath;
                                
                                <div class="modal fade" id="previewModal_@script.UnploadId" tabindex="-1" 
                                     aria-labelledby="previewModalLabel_@script.UnploadId" aria-hidden="true">
                                    <div class="modal-dialog modal-lg modal-dialog-centered">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title" id="previewModalLabel_@script.UnploadId">
                                                    Prescription Preview (#@script.UnploadId)
                                                </h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body text-center p-0">
                                                <img src="@imageUrl" class="img-fluid" 
                                                     alt="Prescription image" style="max-height: 70vh;">
                                            </div>
                                            <div class="modal-footer">
                                                <a asp-action="DownloadPrescription" asp-route-id="@script.UnploadId" 
                                                   class="btn btn-primary">
                                                    <i class="fas fa-download me-1"></i> Download
                                                </a>
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Reject Modal -->
                            <div class="modal fade" id="rejectModal_@script.UnploadId" tabindex="-1" 
                                 aria-labelledby="rejectModalLabel_@script.UnploadId" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 shadow">
                                        <div class="modal-header bg-danger text-white">
                                            <h5 class="modal-title" id="rejectModalLabel_@script.UnploadId">
                                                <i class="fas fa-exclamation-triangle me-2"></i> Reject Prescription
                                            </h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <form asp-action="UpdateStatus" method="post">
                                            <div class="modal-body">
                                                <div class="alert alert-warning">
                                                    <i class="fas fa-exclamation-circle me-2"></i> 
                                                    This action cannot be undone. Please provide a reason for rejection.
                                                </div>
                                                <input type="hidden" name="id" value="@script.UnploadId" />
                                                <input type="hidden" name="status" value="@PrescriptionStatus.Rejected" />
                                                <div class="mb-3">
                                                    <label class="form-label fw-medium">Reason for Rejection</label>
                                                    <textarea name="notes" class="form-control" rows="3" required
                                                              placeholder="Enter detailed reason for rejection..."></textarea>
                                                </div>
                                            </div>
                                            <div class="modal-footer border-0">
                                                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-danger rounded-pill px-4">
                                                    <i class="fas fa-ban me-1"></i> Confirm Rejection
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white border-top-0 py-3">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
                <div class="mb-2 mb-md-0">
                    <span class="text-muted">Showing <strong>@Model.Count</strong> prescriptions</span>
                </div>
                <div>
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="PendingScripts" asp-route-status="@ViewBag.StatusFilter" asp-route-page="1" asp-route-pageSize="@ViewBag.PageSize">First</a>
                            </li>
                            <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="PendingScripts" asp-route-status="@ViewBag.StatusFilter" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-pageSize="@ViewBag.PageSize">Previous</a>
                            </li>

                            @for (var i = Math.Max(1, (int)ViewBag.CurrentPage - 2); i <= Math.Min((int)ViewBag.TotalPages, (int)ViewBag.CurrentPage + 2); i++)
                            {
                                <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="PendingScripts" asp-route-status="@ViewBag.StatusFilter" asp-route-page="@i" asp-route-pageSize="@ViewBag.PageSize">@i</a>
                                </li>
                            }

                            <li class="page-item @((int)ViewBag.CurrentPage >= (int)ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="PendingScripts" asp-route-status="@ViewBag.StatusFilter" asp-route-page="@((int)ViewBag.CurrentPage + 1)" asp-route-pageSize="@ViewBag.PageSize">Next</a>
                            </li>
                            <li class="page-item @((int)ViewBag.CurrentPage >= (int)ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="PendingScripts" asp-route-status="@ViewBag.StatusFilter" asp-route-page="@ViewBag.TotalPages" asp-route-pageSize="@ViewBag.PageSize">Last</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(PrescriptionStatus status)
    {
        return status switch
        {
            PrescriptionStatus.Pending => "bg-secondary",
            PrescriptionStatus.Processing => "bg-warning text-dark",
            PrescriptionStatus.Rejected => "bg-danger",
            PrescriptionStatus.Completed => "bg-success",
            _ => "bg-info"
        };
    }
    
    string GetStatusButtonClass(PrescriptionStatus status, bool isActive)
    {
        var baseClass = isActive ? "btn-" : "btn-outline-";
        
        return status switch
        {
            PrescriptionStatus.Pending => baseClass + "secondary",
            PrescriptionStatus.Processing => baseClass + "warning",
            PrescriptionStatus.Rejected => baseClass + "danger",
            PrescriptionStatus.Completed => baseClass + "success",
            _ => baseClass + "info"
        };
    }

    string GetStatusIcon(PrescriptionStatus status)
    {
        return status switch
        {
            PrescriptionStatus.Pending => "fas fa-clock",
            PrescriptionStatus.Processing => "fas fa-spinner fa-pulse",
            PrescriptionStatus.Rejected => "fas fa-ban",
            PrescriptionStatus.Completed => "fas fa-check-circle",
            _ => "fas fa-info-circle"
        };
    }
}

@section Styles {
    <style>
        .latest-completed {
            background-color: #e6f7ff;
            box-shadow: inset 3px 0 0 #0d6efd;
        }
        .avatar-sm {
            width: 32px;
            height: 32px;
            font-size: 14px;
        }
        .badge-pill {
            border-radius: 50rem;
        }
        .table-light th {
            background-color: #f8f9fa;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            color: #6c757d;
        }
        .table-hover tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.05);
        }
        .table-danger-light {
            background-color: rgba(220, 53, 69, 0.03);
        }
        .rounded-pill {
            padding-left: 1rem;
            padding-right: 1rem;
        }
        .dropdown-menu {
            border: 0;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1);
        }
        .file-icon {
            font-size: 1.5rem;
        }
        .img-preview {
            max-height: 70vh;
            width: auto;
            margin: 0 auto;
            display: block;
        }
        .modal-body {
            overflow-y: auto;
            max-height: 80vh;
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            // Enable tooltips
            $('[data-bs-toggle="tooltip"]').tooltip({
                trigger: 'hover'
            });

            // Make table rows clickable (excluding buttons and forms)
            $('table tr').click(function(e) {
                if ($(e.target).is('button, a, input, .btn, .btn *, form, form *')) {
                    return;
                }
                const viewLink = $(this).find('a[href*="Process"]').attr('href');
                if (viewLink) {
                    window.location.href = viewLink;
                }
            }).css('cursor', 'pointer');
        });
    </script>
}