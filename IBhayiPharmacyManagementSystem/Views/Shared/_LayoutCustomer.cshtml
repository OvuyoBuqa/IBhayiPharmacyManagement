    <script>
        // Persist sidebar treeview open/closed state for customer via localStorage
        (function () {
            var storageKeyPrefix = 'customerSidebar-';

            function restoreState() {
                $("#customerSidebar a.has-arrow").each(function () {
                    var $link = $(this);
                    var key = $link.data('key');
                    if (!key) return;
                    var state = localStorage.getItem(storageKeyPrefix + key);
                    if (state === 'open') {
                        var parentLi = $link.closest('li.nav-item');
                        parentLi.addClass('menu-is-opening menu-open');
                        $link.addClass('active');
                        var child = parentLi.children('ul.nav-treeview');
                        child.stop(true, true).css('display','block');
                    }
                });
            }

            // Restore after AdminLTE initializes
            $(window).on('load', function () {
                // initial pass
                restoreState();
                // run again shortly after in case AdminLTE rebinds tree
                setTimeout(restoreState, 300);
                setTimeout(restoreState, 700);
            });

            // Save on toggle
            $(document).on('click', '#customerSidebar a.has-arrow', function () {
                var key = $(this).data('key');
                if (!key) return;
                var parentLi = $(this).closest('li.nav-item');
                setTimeout(function () {
                    var isOpen = parentLi.hasClass('menu-open');
                    localStorage.setItem(storageKeyPrefix + key, isOpen ? 'open' : 'closed');
                }, 160);
            });
        })();
    </script>
    <!-- Notification System -->
    <script>
        $(document).ready(function() {
            loadNotifications();
            
            // Refresh notifications every 30 seconds
            setInterval(loadNotifications, 30000);
        });

        function loadNotifications() {
            $.get('@Url.Action("GetNotifications", "Notifications")', function(data) {
                updateNotificationBadge(data.count);
                updateNotificationContent(data.notifications);
            }).fail(function() {
                console.log('Failed to load notifications');
            });
        }

        function updateNotificationBadge(count) {
            const badge = $('#notificationBadge');
            if (count > 0) {
                badge.text(count).show();
            } else {
                badge.hide();
            }
        }

        function updateNotificationContent(notifications) {
            const content = $('#notificationContent');
            const header = $('#notificationMenu .dropdown-header');
            
            if (notifications.length === 0) {
                content.html('<a href="#" class="dropdown-item"><i class="fas fa-info-circle mr-2"></i> No new notifications</a>');
                header.text('Notifications');
            } else {
                header.text(`${notifications.length} Notifications`);
                let html = '';
                notifications.forEach(function(notification) {
                    html += `<a href="${notification.link}" class="dropdown-item">
                        <i class="${notification.icon} mr-2"></i> ${notification.message}
                        <span class="float-right text-muted text-sm">${notification.time}</span>
                    </a><div class="dropdown-divider"></div>`;
                });
                content.html(html);
            }
        }

        function markAllAsRead() {
            $.post('@Url.Action("MarkAllAsRead", "Notifications")', function(data) {
                if (data.success) {
                    loadNotifications();
                }
            });
        }
    </script>

    <!-- Logout Loading Overlay -->
    <div class="logout-overlay" id="logoutOverlay">
        <div class="logout-overlay-content">
            <div class="logout-overlay-spinner">
                <i class="fas fa-spinner fa-spin"></i>
            </div>
            <div class="logout-overlay-text">Signing out...</div>
        </div>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize sidebar treeview
        $('[data-widget="treeview"]').Treeview('init');
        
        const logoutForms = document.querySelectorAll('.logout-form');
        
        logoutForms.forEach(function(form) {
            form.addEventListener('submit', function(e) {
                e.preventDefault(); // Prevent immediate form submission
                
                const button = form.querySelector('.logout-btn');
                const text = button.querySelector('.logout-text');
                const spinner = button.querySelector('.logout-spinner');
                const overlay = document.getElementById('logoutOverlay');
                
                // Show loading state
                button.disabled = true;
                button.classList.add('logout-loading');
                text.style.display = 'none';
                spinner.style.display = 'inline-block';
                overlay.classList.add('show');
                
                // Show loading for 2 seconds, then submit
                setTimeout(function() {
                    form.submit();
                }, 2000);
            });
        });
    });
    
    // Enhanced dropdown functionality for customer subsystem - Simple approach like UnprocessedScripts
    $(document).ready(function() {
        function initializeDropdowns() {
            // Simple dropdown handling - let Bootstrap handle the click, just prevent hover
            $('.dropdown-toggle').off('mouseenter.dropdown-custom mouseleave.dropdown-custom');
            $('.dropdown-toggle').on('mouseenter.dropdown-custom mouseleave.dropdown-custom', function(e) {
                e.preventDefault();
                e.stopPropagation();
            });
            
            // Ensure dropdowns close when clicking outside
            $(document).off('click.dropdown-custom');
            $(document).on('click.dropdown-custom', function(e) {
                if (!$(e.target).closest('.btn-group').length) {
                    $('.dropdown-menu').removeClass('show');
                    $('.btn-group').removeClass('show');
                    $('.dropdown-toggle').attr('aria-expanded', 'false');
                }
            });
        }
        
        // Initialize dropdowns when document is ready
        initializeDropdowns();
        
        // Re-initialize dropdowns after DataTable redraws
        $(document).on('draw.dt', function() {
            setTimeout(initializeDropdowns, 100);
        });
        
        // Re-initialize dropdowns after AJAX content loads
        $(document).ajaxComplete(function() {
            setTimeout(initializeDropdowns, 100);
        });
    });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
