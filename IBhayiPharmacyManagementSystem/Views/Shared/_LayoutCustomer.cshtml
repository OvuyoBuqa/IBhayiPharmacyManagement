
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Pharmacy Management System</title>

    <!-- Google Font: Source Sans Pro -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/fontawesome-free/css/all.min.css">
    <!-- Ionicons -->
    <link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
    <!-- Tempusdominus Bootstrap 4 -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css">
    <!-- iCheck -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
    <!-- JQVMap -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/jqvmap/jqvmap.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="~/AdminLTE/dist/css/adminlte.min.css">
    <!-- overlayScrollbars -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/overlayScrollbars/css/OverlayScrollbars.min.css">
    <!-- Daterange picker -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/daterangepicker/daterangepicker.css">
    <!-- summernote -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/summernote/summernote-bs4.min.css">
    <!-- DataTables -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
    <link rel="stylesheet" href="~/AdminLTE/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
    <!-- Removed missing HighCharts.css and hummingbird-treeview.css to avoid 404s -->
    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.12.4/dist/sweetalert2.min.css">
    <!-- ADD THIS LINE FOR YOUR STYLES SECTION -->
    @RenderSection("Styles", required: false)
    
    <style>
        /* System Colors - Brown/Black Theme */
        .bg-brown { background-color: #3e2a1f !important; }
        .text-brown { color: #3e2a1f !important; }
        .btn-brown { background-color: #3e2a1f !important; border-color: #3e2a1f !important; color: #fff !important; }
        .btn-brown:hover { background-color: #5d4e37 !important; border-color: #5d4e37 !important; }
        .btn-outline-brown { color: #3e2a1f !important; border-color: #3e2a1f !important; }
        .btn-outline-brown:hover { background-color: #3e2a1f !important; color: #fff !important; }

        /* Sidebar fixes */
        .sidebar { 
            height: 100vh; 
            overflow-y: auto; 
            padding-bottom: 60px; /* Space for logout button */
        }
        .sidebar .nav-sidebar { 
            padding-bottom: 20px; 
        }
        .logout-btn {
            position: sticky;
            bottom: 0;
            z-index: 1000;
            margin-top: auto;
        }
        
        /* Ensure logout button works in collapsed sidebar */
        .sidebar-collapse .logout-btn span {
            display: none;
        }
        
        .sidebar-collapse .logout-btn {
            text-align: center;
            padding: 0.5rem;
        }

        /* Modern Dashboard Styles */
        .stat-card-3d { transition: all .4s cubic-bezier(0.175,0.885,0.32,1.275); transform-style: preserve-3d; perspective: 1000px; border-radius: 15px; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,.1); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,.2); position: relative; }
        .stat-card-3d:hover { transform: translateY(-10px) rotateX(5deg) rotateY(5deg); box-shadow: 0 20px 40px rgba(0,0,0,.2); }
        .stat-card-3d::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,.1) 0%, rgba(255,255,255,.05) 100%); opacity: 0; transition: opacity .3s ease; pointer-events: none; }
        .stat-card-3d:hover::before { opacity: 1; }

        /* Glassmorphism Info Boxes */
        .info-box { background: rgba(255,255,255,.95); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,.2); border-radius: 15px; overflow: hidden; }
        .info-box-icon { border-radius: 15px 0 0 15px; }
        .info-box-number { font-size: 2.5rem; font-weight: 700; transition: all .3s ease; }
        .stat-card-3d:hover .info-box-number { transform: scale(1.1); color: #3e2a1f; }

        /* Progress Bars */
        .progress { height: 8px; border-radius: 10px; background: rgba(0,0,0,.1); overflow: hidden; }
        .progress-bar { background: linear-gradient(90deg, #3e2a1f 0%, #5d4e37 100%); border-radius: 10px; transition: width 1s ease; }

        /* Modern Cards */
        .modern-card { border: none; border-radius: 15px; box-shadow: 0 8px 32px rgba(0,0,0,.1); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,.2); transition: all .3s ease; overflow: hidden; }
        .modern-card:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(0,0,0,.15); }
        .modern-card .card-header { background: linear-gradient(135deg, #3e2a1f 0%, #5d4e37 100%); color: #fff; border-bottom: none; border-radius: 15px 15px 0 0; }
        .modern-card .card-header .card-title { color: #fff; font-weight: 600; }

        /* Buttons */
        .btn { border-radius: 10px; transition: all .3s ease; font-weight: 500; }
        .btn:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,.2); }

        /* Tables */
        .table { border-radius: 10px; overflow: hidden; }
        .table thead th { 
            background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%) !important; 
            color: white !important; 
            border: none !important; 
            font-weight: 600 !important; 
            padding: 15px 12px !important;
            text-transform: uppercase !important;
            letter-spacing: 0.5px !important;
            font-size: 0.85rem !important;
        }

        
        .alert { border-radius: 12px; border: none; box-shadow: 0 8px 24px rgba(0,0,0,.08); }
        .alert .icon { margin-right: .5rem; }
        .alert-success { background: linear-gradient(135deg, #e6f4ea 0%, #d4efdf 100%); color: #0a1f14; }
        .alert-danger { background: linear-gradient(135deg, #fdecea 0%, #f8d7da 100%); color: #58151c; }
        .alert-warning { background: linear-gradient(135deg, #fff4e5 0%, #ffe8cc 100%); color: #663c00; }
        .alert-info { background: linear-gradient(135deg, #e7f3ff 0%, #d0e7ff 100%); color: #0a2a66; }
        .alert-dismissible .close { color: inherit; text-shadow: none; opacity: .6; }
        .alert-dismissible .close:hover { opacity: 1; }

        /* Logout Loading Styles */
        .logout-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
            z-index: 9999;
            display: none;
            justify-content: center;
            align-items: center;
        }
        
        .logout-overlay.show {
            display: flex;
        }
        
        .logout-overlay-content {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }
        
        .logout-overlay-spinner {
            font-size: 2rem;
            color: #3e2a1f;
            margin: 0 auto 1rem;
        }
        
        .logout-overlay-text {
            font-size: 1.1rem;
            color: #3e2a1f;
            font-weight: 500;
        }
        
        .logout-loading {
            opacity: 0.7;
            cursor: not-allowed;
        }
        /* Fix text truncation issues */
        .user-name {
            white-space: nowrap;
            overflow: visible;
            text-overflow: unset;
            max-width: none;
            word-break: break-all;
        }
        
        .nav-link p {
            white-space: nowrap;
            overflow: visible;
            text-overflow: unset;
            max-width: none;
        }
        
        .nav-sidebar .nav-link {
            white-space: nowrap;
            overflow: visible;
        }
        
        
        /* Fix form field text truncation */
        .form-control, .form-select {
            white-space: nowrap;
            overflow: visible;
            text-overflow: unset;
        }
        
        .form-label, .control-label {
            white-space: nowrap;
            overflow: visible;
            text-overflow: unset;
        }
        
        /* Fix table text truncation */
        .table td, .table th {
            white-space: nowrap;
            overflow: visible;
            text-overflow: unset;
        }
        
        /* Fix breadcrumb truncation */
        .breadcrumb {
            white-space: nowrap;
            overflow: visible;
        }
        
        .breadcrumb-item {
            white-space: nowrap;
            overflow: visible;
        }
        
        /* Fix navbar text truncation */
        .navbar-brand {
            white-space: nowrap;
            overflow: visible;
        }
        
        /* Fix button text truncation */
        .btn {
            white-space: nowrap;
            overflow: visible;
        }
        
        /* Professional table styling for medication history */
        .table-enhanced {
            border-collapse: separate;
            border-spacing: 0;
        }
        
        .table-enhanced th {
            background: linear-gradient(135deg, #2c3e50, #34495e);
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
            padding: 15px 12px;
            border: none;
            position: sticky;
            top: 0;
            z-index: 10;
        }
        
        .table-enhanced td {
            padding: 12px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f3f4;
            transition: background-color 0.2s ease;
        }
        
        .table-enhanced tbody tr:hover {
            background-color: #f8f9fa;
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        
        /* Professional checkbox styling */
        .form-check-input {
            width: 18px;
            height: 18px;
            border: 2px solid #dee2e6;
            border-radius: 4px;
            transition: all 0.2s ease;
        }
        
        .form-check-input:checked {
            background-color: #007bff;
            border-color: #007bff;
            box-shadow: 0 2px 4px rgba(0, 123, 255, 0.3);
        }
        
        .form-check-input:indeterminate {
            background-color: #6c757d;
            border-color: #6c757d;
        }
        
        /* Enhanced dropdown styles for customer subsystem - Static positioning like UnprocessedScripts */
        .btn-group {
            position: relative !important;
            z-index: 10 !important;
            display: inline-block !important;
        }
        
        .btn-group.show {
            z-index: 99999 !important;
        }
        
        .btn-group .dropdown-toggle {
            position: relative !important;
            z-index: 99998 !important;
        }
        
        .btn-group.show .dropdown-toggle {
            z-index: 99998 !important;
        }
        
        .btn-group .dropdown-menu {
            position: absolute !important;
            top: 0 !important;
            left: auto !important;
            right: 100% !important;
            z-index: 99999 !important;
            border-radius: 8px !important;
            border: 1px solid #e9ecef !important;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
            min-width: 180px !important;
            padding: 0.5rem 0 !important;
            background: white !important;
            margin-right: 10px !important;
            display: none !important;
        }
        
        .btn-group .dropdown-menu.show {
            display: block !important;
        }
        
        .btn-group.show .dropdown-menu {
            display: block !important;
        }
        
        /* Ensure table containers allow dropdown overflow */
        .table-responsive {
            overflow: visible !important;
        }
        
        .card-body {
            overflow: visible !important;
        }
        
        .table {
            overflow: visible !important;
        }
        
        .table tbody {
            overflow: visible !important;
        }
        
        .table tbody tr {
            overflow: visible !important;
        }
        
        .table tbody tr td {
            overflow: visible !important;
        }
        
        /* Ensure Actions column allows overflow */
        .table tbody tr td:last-child {
            overflow: visible !important;
            position: relative !important;
            z-index: auto !important;
        }
        
        .btn-group .dropdown-item {
            padding: 0.75rem 1.25rem;
            transition: all 0.2s ease;
            font-weight: 500;
            color: #2c3e50;
            border-bottom: 1px solid #f1f3f4;
        }
        
        .btn-group .dropdown-item:last-child {
            border-bottom: none;
        }

        .btn-group .dropdown-item:hover,
        .btn-group .dropdown-item:focus {
            background-color: #f8f9fa;
            color: #007bff;
            transform: translateX(3px);
        }
        
        .btn-group .dropdown-item i {
            width: 20px;
            text-align: center;
            margin-right: 10px;
        }
        
        .btn-group .btn.dropdown-toggle {
            color: #007bff !important;
            background-color: white !important;
            border: 1px solid #007bff !important;
            border-radius: 6px !important;
            padding: 8px 16px !important;
            font-size: 0.875rem !important;
            font-weight: 500 !important;
            transition: all 0.2s ease !important;
        }
        
        .btn-group .btn.dropdown-toggle:hover {
            color: #0056b3 !important;
            background-color: #f8f9fa !important;
            border-color: #0056b3 !important;
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(0,123,255,0.2);
        }
        
        .btn-group .btn.dropdown-toggle:focus {
            color: #0056b3 !important;
            background-color: #f8f9fa !important;
            border-color: #0056b3 !important;
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,0.25);
        }
        
        .btn-group .btn.dropdown-toggle:active {
            color: #0056b3 !important;
            background-color: #f8f9fa !important;
            border-color: #0056b3 !important;
            transform: translateY(0);
        }
        
        /* Responsive fixes */
        @@media (max-width: 768px) {
            .btn-group .dropdown-menu {
                right: auto !important;
                left: 0 !important;
                min-width: 140px;
            }
            
            .table-responsive {
                border-radius: 10px;
                overflow: visible !important;
            }
        }
        
        /* Fix notification dropdown truncation */
        .dropdown-menu-lg {
            min-width: 350px !important;
            max-width: 400px !important;
        }
        
        .dropdown-item {
            white-space: normal !important;
            word-wrap: break-word !important;
            padding: 10px 15px !important;
            line-height: 1.4 !important;
        }
        
        .dropdown-item .float-right {
            white-space: nowrap !important;
            margin-left: 10px !important;
        }
        
        /* Fix user email truncation in sidebar */
        .user-panel .info {
            overflow: visible !important;
            white-space: normal !important;
        }
        
        .user-panel .info a {
            word-wrap: break-word !important;
            white-space: normal !important;
        }
    </style>
</head>

<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">

     @*    <!-- Preloader -->
        <div class="preloader flex-column justify-content-center align-items-center">
            <img class="animation__shake" src="~/AdminLTE/dist/img/avatar2.png" alt="CustomerAvatar" height="60" width="60">
        </div> *@

        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light fixed-top" style="background-image: linear-gradient(180deg, #3e2a1f 0%, #1f0d07 70%) !important; z-index: 1030;">



            <!-- Left navbar links -->
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>

                <li class="nav-link" style="color: white;">PHARMACY MANAGEMENT SYSTEM</li>

            </ul>

            <!-- Right navbar links -->
            <ul class="navbar-nav ml-auto">
                <!-- Notifications Dropdown Menu -->
                <li class="nav-item dropdown">
                    <a class="nav-link" data-toggle="dropdown" href="#" id="notificationDropdown" style="color: white !important;">
                        <i class="far fa-bell" style="color: white !important;"></i>
                        <span class="badge badge-warning navbar-badge" id="notificationBadge">0</span>
                    </a>
                    <div class="dropdown-menu dropdown-menu-lg dropdown-menu-right" id="notificationMenu">
                        <span class="dropdown-item dropdown-header">Notifications</span>
                        <div class="dropdown-divider"></div>
                        <div id="notificationContent">
                            <a href="#" class="dropdown-item">
                                <i class="fas fa-info-circle mr-2"></i> No new notifications
                            </a>
                        </div>
                        <div class="dropdown-divider"></div>
                        <a href="#" class="dropdown-item dropdown-footer" onclick="markAllAsRead()">Mark all as read</a>
                    </div>
                </li>

                <!-- Profile Dropdown Menu -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="profileDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" style="color: white !important;">
                        <i class="fas fa-user-circle" style="color: white !important;"></i>
                    </a>
                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="profileDropdown">
                        <div class="dropdown-header text-center">
                            <strong>@User.Identity?.Name</strong><br>
                            <small class="text-muted">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</small><br>
                            <small class="text-muted">Role: @(User.IsInRole("Customer") ? "Customer" : User.IsInRole("Pharmacist") ? "Pharmacist" : User.IsInRole("PharmacyManager") ? "Pharmacy Manager" : "Admin")</small>
                        </div>
                        <div class="dropdown-divider"></div>
                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                            <i class="fas fa-user-cog mr-2"></i> Profile Settings
                        </a>
                        <div class="dropdown-divider"></div>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                            <button type="submit" class="dropdown-item text-danger logout-btn">
                                <i class="fas fa-sign-out-alt mr-2"></i> 
                                <span class="logout-text">Logout</span>
                                <span class="logout-spinner" style="display: none;">
                                    <i class="fas fa-spinner fa-spin mr-2"></i>
                                </span>
                            </button>
                        </form>
                    </div>
                </li>

                <!-- Optional: Add role-based navigation if needed -->
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link text-light" asp-controller="Home" asp-action="Admin"></a>
                    </li>
                }
                @if (User.IsInRole("Customer"))
                {
                    <li class="nav-item">
                        <a class="nav-link text-light" asp-controller="Home" asp-action="Customer"></a>
                    </li>
                }
                @if (User.IsInRole("Pharmacist"))
                {
                    <li class="nav-item">
                        <a class="nav-link text-light" asp-controller="Home" asp-action="Pharmacist"></a>
                    </li>
                }
                @if (User.IsInRole("PharmacyManager"))
                {
                    <li class="nav-item">
                        <a class="nav-link text-light" asp-controller="Home" asp-action="PharmacyManager"></a>
                    </li>
                }

            </ul>
        </nav>

        <!-- /.navbar -->

     

        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4" style="background-image: linear-gradient(180deg, #3e2a1f 0%, #1f0d07 50%) !important">

            <!-- Brand Logo -->
            @*  <a href="index3.html" class="brand-link">
                    <img src="~/AdminLTE/dist/img/AdminLTELogo.png" alt="AdminLTE Logo" class="brand-image img-circle elevation-3" style="opacity: .8">
                    <span class="brand-text font-weight-light"> Pharmacy Management </span>
                </a> *@

            <!-- Sidebar -->
            <div class="sidebar">
                <!-- Sidebar user panel (optional) -->
                <div class="user-panel mt-3 pb-3 mb-3 d-flex">
                    <div class="image">
                        <img src="~/AdminLTE/dist/img/avatar2.png" class="img-circle elevation-2" alt="CustomerAvatar">
                    </div>
                    <div class="info">
                        <p class="user-name mb-0" style="color: white;">@User.Identity?.Name!</p>

                    </div>
                </div>
                <!-- Sidebar Menu -->
                <nav class="mt-2">
                    <ul id="customerSidebar" class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
                        <!-- Add icons to the links using the .nav-icon class
                             with font-awesome or any other icon font library -->

                        <li class="nav-item menu-open">
                            <a asp-controller="Home" asp-action="Customer" class="nav-link active" style="background-color: #d56d2f;">
                                <i class="nav-icon fas fa-tachometer-alt"></i>
                                <p>
                                    Dashboard

                                </p>
                            </a>

                        </li>

                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Profile" class="nav-link">
                                <i class="nav-icon fas fa-user"></i>
                                <p>My Profile</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a href="javascript:;" class="nav-link has-arrow" data-key="menu-prescriptions">
                                <i class="nav-icon fas fa-pills"></i>
                                <p>
                                    Prescriptions
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">

                                <li class="nav-item" style="background-color: #7b3804;">
                                    <a asp-area="Customer" asp-controller="UnprocessedScripts" asp-action="Load" class="nav-link">
                                        <i class="fas fa-upload nav-icon"></i>
                                        <p>Load Prescription</p>
                                    </a>
                                </li>

                                <li class="nav-item" style="background-color: #7b3804;">
                                    <a asp-area="Customer" asp-controller="UnprocessedScripts" asp-action="UnprocessedScripts" class="nav-link">
                                        <i class="fas fa-clock nav-icon"></i>
                                        <p>Unprocessed Scripts</p>
                                    </a>
                                </li>

                                <li class="nav-item" style="background-color: #7b3804;">
                                    <a asp-area="Customer" asp-controller="UnprocessedScripts" asp-action="ProcessedScripts" class="nav-link">
                                        <i class="fas fa-check-circle nav-icon"></i>
                                        <p>Processed Scripts</p>
                                    </a>
                                </li>

                            </ul>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="PrescriptionRepeats" asp-action="Index" class="nav-link">
                                <i class="nav-icon fas fa-redo"></i>
                                <p>Manage Repeats</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a href="javascript:;" class="nav-link has-arrow" data-key="menu-orders">
                                <i class="nav-icon fas fa-shopping-cart"></i>
                                <p>
                                    All Orders
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">

                                <li class="nav-item" style="background-color: #7b3804;">
                                    <a asp-area="Customer" asp-controller="Orders" asp-action="CreateCustomer" class="nav-link">
                                        <i class="fas fa-plus nav-icon"></i>
                                        <p>New Order</p>
                                    </a>
                                </li>

                 <li class="nav-item" style="background-color: #7b3804;">
                     <a asp-area="Customer" asp-controller="Orders" asp-action="Index" class="nav-link">
                         <i class="fas fa-list nav-icon"></i>
                         <p>My Orders</p>
                     </a>
                 </li>

