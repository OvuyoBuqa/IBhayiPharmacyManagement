    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.12.4/dist/sweetalert2.min.css">
    <style>
        :root {
            --clr-bg: #f8f9fa; /* light background */
            --clr-surface: #ffffff; /* white card surface */
            --clr-primary: #0a1f14; /* dashboard green */
            --clr-secondary: #1b4332; /* lighter green */
            --clr-success: #0a1f14; /* dashboard green */
            --clr-info: #748287;
            --clr-muted: #787475;
            --clr-olive: #0a1f14; /* dashboard green */
            --clr-tan: Tan;
            --clr-text: #020101; /* dark text for contrast */
        }
        /* Global background/text */
        body, .content-wrapper { background-color: var(--clr-bg); color: var(--clr-text); }
        a { color: var(--clr-info); }
        a:hover { color: var(--clr-text); }

        /* Navbar and Sidebar */
        .main-header.navbar { background-image: linear-gradient(180deg, var(--clr-primary) 0%, var(--clr-secondary) 70%) !important; color: #fff !important; }
        .main-header.navbar .nav-link { color: #fff !important; }
        .main-sidebar { background-image: linear-gradient(180deg, var(--clr-primary) 0%, var(--clr-secondary) 60%) !important; }
        .nav-sidebar .nav-link { color: #fff; }
        .nav-sidebar .nav-link.active { background-color: var(--clr-secondary) !important; color: #fff !important; }

        /* Cards and tables */
        .card { background-color: var(--clr-surface); color: var(--clr-text); border-color: var(--clr-secondary); }
        .card-header { background-color: var(--clr-primary) !important; color: #fff !important; border-bottom-color: var(--clr-secondary); }
        .table { color: var(--clr-text); }
        .table thead.table-light { background-color: #f8f9fa !important; color: var(--clr-text) !important; }
        .table-hover tbody tr:hover { background-color: rgba(10,31,20,.08); }

        /* Buttons */
        .btn-primary { background-color: var(--clr-primary); border-color: var(--clr-primary); }
        .btn-primary:hover { filter: brightness(1.1); }
        .btn-secondary { background-color: var(--clr-secondary); border-color: var(--clr-secondary); }
        .btn-success { background-color: var(--clr-success); border-color: var(--clr-success); }
        .btn-outline-primary { color: var(--clr-text); border-color: var(--clr-primary); }
        .btn-outline-primary:hover { background-color: var(--clr-primary); border-color: var(--clr-primary); }

        /* Badges */
        .badge.bg-info { background-color: var(--clr-info) !important; color: #fff; }
        .badge.bg-success { background-color: var(--clr-success) !important; color: #fff; }
        .badge.bg-warning { background-color: var(--clr-tan) !important; color: #000; }
        .badge.bg-secondary { background-color: var(--clr-secondary) !important; color: #fff; }
        .badge.bg-primary { background-color: var(--clr-primary) !important; color: #fff; }

        /* Alerts */
        .alert-info { background-color: #e9f3f6; color: var(--clr-text); border-color: var(--clr-info); }
        .alert-warning { background-color: #fff3e0; color: var(--clr-text); border-color: var(--clr-tan); }

        .swal2-popup { background: #ffffff !important; color: var(--clr-text) !important; border: 1px solid var(--clr-secondary); }
        .swal2-title { color: var(--clr-text) !important; }
        .swal2-html-container { color: var(--clr-text) !important; }
        .swal2-styled.swal2-confirm { background: var(--clr-primary) !important; }
        .swal2-styled.swal2-cancel { background: var(--clr-secondary) !important; }
    </style>

