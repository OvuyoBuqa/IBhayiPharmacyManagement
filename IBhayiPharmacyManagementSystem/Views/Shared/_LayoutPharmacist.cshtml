    <script>
        (function(){
            const palette = {
                bg: getComputedStyle(document.documentElement).getPropertyValue('--clr-bg').trim(),
                text: getComputedStyle(document.documentElement).getPropertyValue('--clr-text').trim(),
                primary: getComputedStyle(document.documentElement).getPropertyValue('--clr-primary').trim(),
                secondary: getComputedStyle(document.documentElement).getPropertyValue('--clr-secondary').trim()
            };
            const swalBase = Swal.mixin({
                background: palette.bg,
                color: palette.text,
                confirmButtonColor: palette.primary,
                cancelButtonColor: palette.secondary,
                buttonsStyling: true
            });
            function showAlert(type, message, title){
                const map = { success:'success', error:'error', danger:'error', warning:'warning', info:'info' };
                return swalBase.fire({ icon: map[type] || 'info', title: title || '', html: message, showCloseButton: true });
            }
            function confirmSwal(opts){
                return swalBase.fire(Object.assign({ title:'Are you sure?', icon:'warning', showCancelButton:true }, opts||{}));
            }
            window.showAlert = showAlert;
            window.confirmSwal = confirmSwal;
        })();
    </script>
