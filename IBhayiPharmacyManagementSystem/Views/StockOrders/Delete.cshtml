@model IBhayiPharmacyManagementSystem.Models.StockOrder

@{
    ViewData["Title"] = "Delete Stock Order";
    Layout = "_LayoutPharmacyManger";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <h4 class="card-title mb-0">Delete Stock Order: #@Model.StockOrderId</h4>
        </div>
        <div class="card-body">
            <h3 class="text-danger">Are you sure you want to delete this stock order?</h3>
            <div>
                <dl class="row">
                    <dt class="col-sm-3">
                        @Html.DisplayNameFor(model => model.StockOrderId)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.StockOrderId)
                    </dd>
                    <dt class="col-sm-3">
                        @Html.DisplayNameFor(model => model.Supplier)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.Supplier.Name)
                    </dd>
                    <dt class="col-sm-3">
                        @Html.DisplayNameFor(model => model.StockOrderDate)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.StockOrderDate)
                    </dd>
                    <dt class="col-sm-3">
                        @Html.DisplayNameFor(model => model.StockOrderStatus)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.StockOrderStatus)
                    </dd>
                    <dt class="col-sm-3">
                        Quote Amount
                    </dt>
                    <dd class="col-sm-9">
                        @(Model.QuoteAmount?.ToString("C") ?? "Pending Quote")
                    </dd>
                </dl>

                <h5>Order Items</h5>
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Medication</th>
                            <th>Quantity Ordered</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.StockOrderItems)
                        {
                            <tr>
                                <td>@item.Medication?.Name</td>
                                <td>@item.QuantityOrdered</td>
                                <td>@item.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="StockOrderId" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash-alt mr-2"></i> Delete
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                </form>
            </div>
        </div>
    </div>
</div>
