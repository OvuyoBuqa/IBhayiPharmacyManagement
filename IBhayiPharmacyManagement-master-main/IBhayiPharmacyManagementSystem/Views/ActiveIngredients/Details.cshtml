@model IBhayiPharmacyManagementSystem.Models.ActiveIngredients

@{
    ViewData["Title"] = "Details";

    Layout = "_LayoutPharmacyManger";
}
<style>
    .pharmacy-table-container {
        background-color: #ffffff;
        border-radius: 8px;
        box-shadow: 0 4px 12px rgba(0, 91, 187, 0.1);
        padding: 25px;
        border-top: 4px solid #1a6fc9;
    }

    .pharmacy-table-header {
        color: #1a6fc9;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid #e1f0ff;
    }

    .table thead th {
        background-color: #1a6fc9;
        color: white;
        border-color: #1560b0;
    }

    .btn-pharmacy-primary {
        background-color: #1a6fc9;
        border-color: #1560b0;
        color: white;
    }

        .btn-pharmacy-primary:hover {
            background-color: #145ba7;
            border-color: #12539a;
            color: white;
        }

    .btn-pharmacy-success {
        background-color: #28a745;
        border-color: #23923d;
        color: white;
    }

        .btn-pharmacy-success:hover {
            background-color: #218838;
            border-color: #1d7d33;
            color: white;
        }

    .btn-pharmacy-info {
        background-color: #17a2b8;
        border-color: #148a9c;
        color: white;
    }

        .btn-pharmacy-info:hover {
            background-color: #138496;
            border-color: #11707e;
            color: white;
        }

    .btn-pharmacy-danger {
        background-color: #dc3545;
        border-color: #c82333;
        color: white;
    }

        .btn-pharmacy-danger:hover {
            background-color: #c82333;
            border-color: #b21f2d;
            color: white;
        }

    .search-container {
        background-color: #e9f2ff;
        padding: 15px;
        border-radius: 5px;
        margin-bottom: 20px;
    }

    .badge-type {
        background-color: #6c757d;
        color: white;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 0.8rem;
    }

    .action-buttons .btn {
        margin-right: 5px;
    }

        .action-buttons .btn:last-child {
            margin-right: 0;
        }
</style>

<h1>Details</h1>

<div>
    <h4>ActiveIngredients</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Strength)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Strength)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.ActiveIngredientId">Edit</a> |
    <a asp-action="ActiveIngredientsList">Back to List</a>
</div>
