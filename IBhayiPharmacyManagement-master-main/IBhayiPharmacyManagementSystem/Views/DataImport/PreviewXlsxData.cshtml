@model IBhayiPharmacyManagementSystem.ViewModels.XlsxParsedData
@{
    ViewData["Title"] = "Preview Comprehensive Data Import";
    Layout = "_LayoutAdmin";
}

<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">Preview Data Import</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="#">Admin</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index")">Data Import</a></li>
                        <li class="breadcrumb-item active">Preview</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <div class="alert alert-info">
                <h5><i class="icon fas fa-info-circle"></i> Review Your Data</h5>
                <p class="mb-0">Please review all data below before importing. Total records to import:</p>
                <ul class="mb-0 mt-2">
                    <li><strong>Customers:</strong> @Model.Customers.Count</li>
                    <li><strong>Medication Orders:</strong> @Model.StockOrders.Count</li>
                    <li><strong>Prescriptions:</strong> @Model.Prescriptions.Count</li>
                    <li><strong>Customer Orders:</strong> @Model.Orders.Count</li>
                </ul>
            </div>

            <form asp-action="ExecuteImportXlsxData" method="post" id="importForm">
                @Html.AntiForgeryToken()
                
                <!-- Customers Section -->
                @if (Model.Customers.Any())
                {
                    <div class="card">
                        <div class="card-header bg-primary">
                            <h3 class="card-title"><i class="fas fa-users mr-2"></i> Customers (@Model.Customers.Count)</h3>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Full Name</th>
                                            <th>ID Number</th>
                                            <th>Email</th>
                                            <th>Phone</th>
                                            <th>Address</th>
                                            <th>Allergies</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var customer in Model.Customers)
                                        {
                                            <tr>
                                                <td>@customer.FullName</td>
                                                <td>@customer.IDNumber</td>
                                                <td>@customer.Email</td>
                                                <td>@customer.PhoneNumber</td>
                                                <td>
                                                    @if (!string.IsNullOrWhiteSpace(customer.Street) || !string.IsNullOrWhiteSpace(customer.City))
                                                    {
                                                        <span>@customer.Street@(string.IsNullOrEmpty(customer.Street) ? "" : ", ")@customer.City</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">No address</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (customer.AllergyList?.Any() == true)
                                                    {
                                                        @foreach (var allergy in customer.AllergyList)
                                                        {
                                                            <span class="badge badge-warning">@allergy</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">None</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }

                <!-- Medication Orders Section -->
                @if (Model.StockOrders.Any())
                {
                    <div class="card">
                        <div class="card-header bg-info">
                            <h3 class="card-title"><i class="fas fa-pills mr-2"></i> Medication Orders (@Model.StockOrders.Count)</h3>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Supplier</th>
                                            <th>Medication</th>
                                            <th>Quantity</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var order in Model.StockOrders)
                                        {
                                            <tr>
                                                <td>@order.Date.ToString("yyyy-MM-dd")</td>
                                                <td>@order.Supplier</td>
                                                <td>@order.Medication</td>
                                                <td>@order.Quantity</td>
                                                <td><span class="badge badge-secondary">@order.OrderStatus</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }

                <!-- Prescriptions Section -->
                @if (Model.Prescriptions.Any())
                {
                    <div class="card">
                        <div class="card-header bg-success">
                            <h3 class="card-title"><i class="fas fa-file-prescription mr-2"></i> Prescriptions (@Model.Prescriptions.Count)</h3>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Customer</th>
                                            <th>Doctor</th>
                                            <th>Medication</th>
                                            <th>Quantity</th>
                                            <th>Instructions</th>
                                            <th>Repeats</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var prescription in Model.Prescriptions)
                                        {
                                            <tr>
                                                <td>@prescription.Date.ToString("yyyy-MM-dd")</td>
                                                <td>@prescription.Customer</td>
                                                <td>@prescription.Doctor</td>
                                                <td>@prescription.Medication</td>
                                                <td>@prescription.Quantity</td>
                                                <td>@prescription.Instructions</td>
                                                <td>@prescription.Repeats</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }

                <!-- Customer Orders Section -->
                @if (Model.Orders.Any())
                {
                    <div class="card">
                        <div class="card-header bg-warning">
                            <h3 class="card-title"><i class="fas fa-shopping-cart mr-2"></i> Customer Orders (@Model.Orders.Count)</h3>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Order Date</th>
                                            <th>Customer</th>
                                            <th>Medications</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var order in Model.Orders)
                                        {
                                            <tr>
                                                <td>@(order.OrderDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                                                <td>@order.Customer</td>
                                                <td>
                                                    @foreach (var medication in order.MedicationList)
                                                    {
                                                        <span class="badge badge-info">@medication</span>
                                                    }
                                                </td>
                                                <td><span class="badge badge-secondary">@order.OrderStatus</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }

                <!-- Action Buttons -->
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <button type="submit" class="btn btn-success btn-lg" id="importBtn">
                                    <i class="fas fa-download mr-2"></i>
                                    Import All Data
                                </button>
                                <a href="@Url.Action("Index")" class="btn btn-secondary btn-lg ml-2">
                                    <i class="fas fa-arrow-left mr-2"></i>
                                    Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.table').DataTable({
                "pageLength": 10,
                "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]]
            });

            $('#importForm').on('submit', function() {
                $('#importBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-2"></i>Importing...');
            });
        });
    </script>
}


