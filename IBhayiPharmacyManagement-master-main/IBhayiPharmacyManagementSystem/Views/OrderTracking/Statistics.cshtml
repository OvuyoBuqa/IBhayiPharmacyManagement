@model IBhayiPharmacyManagementSystem.Controllers.OrderTrackingStatsViewModel
@{
    ViewData["Title"] = "Order Tracking Statistics";
    Layout = "_LayoutPharmacist";
}

<div class="container-fluid px-4 mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-lg">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #0a1f14 0%, #1b4332 100%);">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="mb-0">
                            <i class="fas fa-chart-bar me-2"></i>Order Tracking Statistics
                        </h3>
                        <a href="@Url.Action("Index", "OrderTracking")" class="btn btn-outline-light">
                            <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
                        </a>
                    </div>
                </div>

                <div class="card-body">
                    <!-- Statistics Cards -->
                    <div class="row mb-4">
                        <div class="col-md-2">
                            <div class="card bg-primary text-white text-center">
                                <div class="card-body">
                                    <i class="fas fa-shopping-cart fa-2x mb-2"></i>
                                    <h3>@Model.TotalOrders</h3>
                                    <p class="mb-0">Total Orders</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card bg-warning text-white text-center">
                                <div class="card-body">
                                    <i class="fas fa-clock fa-2x mb-2"></i>
                                    <h3>@Model.PendingCount</h3>
                                    <p class="mb-0">Pending</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card bg-info text-white text-center">
                                <div class="card-body">
                                    <i class="fas fa-cogs fa-2x mb-2"></i>
                                    <h3>@Model.ProcessingCount</h3>
                                    <p class="mb-0">Processing</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card bg-success text-white text-center">
                                <div class="card-body">
                                    <i class="fas fa-check-circle fa-2x mb-2"></i>
                                    <h3>@Model.ReadyCount</h3>
                                    <p class="mb-0">Ready</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card bg-secondary text-white text-center">
                                <div class="card-body">
                                    <i class="fas fa-hand-holding fa-2x mb-2"></i>
                                    <h3>@Model.CollectedCount</h3>
                                    <p class="mb-0">Collected</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card bg-danger text-white text-center">
                                <div class="card-body">
                                    <i class="fas fa-times-circle fa-2x mb-2"></i>
                                    <h3>@Model.CancelledCount</h3>
                                    <p class="mb-0">Cancelled</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Performance Metrics -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">
                                        <i class="fas fa-tachometer-alt me-2"></i>Performance Metrics
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-6">
                                            <div class="text-center">
                                                <h2 class="text-primary">@Model.AverageProcessingTime.ToString("F1")</h2>
                                                <p class="text-muted mb-0">Average Processing Time (Hours)</p>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="text-center">
                                                <h2 class="text-success">@((Model.ReadyCount + Model.CollectedCount).ToString())</h2>
                                                <p class="text-muted mb-0">Completed Orders</p>
                                            </div>
                                        </div>
                                    </div>
                                    <hr>
                                    <div class="row">
                                        <div class="col-6">
                                            <div class="text-center">
                                                <h2 class="text-info">@((Model.TotalOrders > 0 ? ((double)(Model.ReadyCount + Model.CollectedCount) / Model.TotalOrders * 100) : 0).ToString("F1"))%</h2>
                                                <p class="text-muted mb-0">Completion Rate</p>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="text-center">
                                                <h2 class="text-warning">@((Model.TotalOrders > 0 ? ((double)Model.PendingCount / Model.TotalOrders * 100) : 0).ToString("F1"))%</h2>
                                                <p class="text-muted mb-0">Pending Rate</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">
                                        <i class="fas fa-chart-pie me-2"></i>Order Status Distribution
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <canvas id="statusChart" width="400" height="200"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Orders by Day Chart -->
                    <div class="row">
                        <div class="col-12">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">
                                        <i class="fas fa-chart-line me-2"></i>Orders by Day (Last 30 Days)
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <canvas id="ordersByDayChart" width="800" height="300"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            // Status Distribution Chart
            const statusCtx = document.getElementById('statusChart').getContext('2d');
            new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Pending', 'Processing', 'Ready', 'Collected', 'Cancelled'],
                    datasets: [{
                        data: [@Model.PendingCount, @Model.ProcessingCount, @Model.ReadyCount, @Model.CollectedCount, @Model.CancelledCount],
                        backgroundColor: [
                            '#ffc107',
                            '#17a2b8',
                            '#28a745',
                            '#6c757d',
                            '#dc3545'
                        ],
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });

            // Orders by Day Chart
            const ordersByDayCtx = document.getElementById('ordersByDayChart').getContext('2d');
            const ordersByDayData = @Html.Raw(Json.Serialize(Model.OrdersByDay));
            const labels = Object.keys(ordersByDayData);
            const data = Object.values(ordersByDayData);

            new Chart(ordersByDayCtx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Orders',
                        data: data,
                        borderColor: '#0a1f14',
                        backgroundColor: 'rgba(10, 31, 20, 0.1)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        }
                    }
                }
            });
        });
    </script>
}
