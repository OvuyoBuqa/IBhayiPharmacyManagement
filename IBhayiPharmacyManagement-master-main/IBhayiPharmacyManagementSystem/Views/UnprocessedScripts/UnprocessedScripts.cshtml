    <script>
        $(document).ready(function() {
            // Enable tooltips
            $('[title]').tooltip();

            // Simple dropdown handling - let Bootstrap handle the click, just prevent hover
            $('.dropdown-toggle').on('mouseenter mouseleave', function(e) {
                e.preventDefault();
                e.stopPropagation();
            });
            
            // Ensure dropdowns close when clicking outside
            $(document).on('click', function(e) {
                if (!$(e.target).closest('.btn-group').length) {
                    $('.dropdown-menu').removeClass('show');
                    $('.btn-group').removeClass('show');
                    $('.dropdown-toggle').attr('aria-expanded', 'false');
                }
            });

            // Handle delete confirmation with proper event prevention
            $('form[action*="Delete"]').submit(function(e) {
                if (!confirm('Are you sure you want to delete this prescription?')) {
                    e.preventDefault();
                    e.stopPropagation();
                    return false;
                }
                return true;
            });

            // Live search functionality
            $('#liveSearchInput').on('input', function() {
                var searchTerm = $(this).val().toLowerCase().trim();
                var $rows = $('tbody tr[data-reference]');
                var matchCount = 0;
                
                if (searchTerm === '') {
                    // Remove all highlighting and show all rows
                    $rows.removeClass('search-highlight').show();
                    $('#noResultsMessage').hide();
                    $('#clearSearchBtn').hide();
                } else {
                    // Highlight matching rows and hide non-matching ones
                    $rows.each(function() {
                        var $row = $(this);
                        var reference = $row.data('reference').toString();
                        var date = $row.data('date').toLowerCase();
                        var dateAlt = $row.data('date-alt').toLowerCase();
                        var dateAlt2 = $row.data('date-alt2').toLowerCase();
                        var dateAlt3 = $row.data('date-alt3').toLowerCase();
                        var dateAlt4 = $row.data('date-alt4').toLowerCase();
                        var dateAlt5 = $row.data('date-alt5').toLowerCase();
                        var status = $row.data('status');
                        var dispensation = $row.data('dispensation');
                        var dispensationAlt = $row.data('dispensation-alt');
                        
                        // Check if search term matches any of the data attributes
                        var matches = 
                            reference.includes(searchTerm) ||
                            date.includes(searchTerm) ||
                            dateAlt.includes(searchTerm) ||
                            dateAlt2.includes(searchTerm) ||
                            dateAlt3.includes(searchTerm) ||
                            dateAlt4.includes(searchTerm) ||
                            dateAlt5.includes(searchTerm) ||
                            status.includes(searchTerm) ||
                            dispensation.includes(searchTerm) ||
                            dispensationAlt.includes(searchTerm);
                        
                        if (matches) {
                            $row.addClass('search-highlight').show();
                            matchCount++;
                        } else {
                            $row.removeClass('search-highlight').hide();
                        }
                    });
                    
                    // Show/hide no results message
                    if (matchCount === 0) {
                        $('#noResultsMessage').show();
                    } else {
                        $('#noResultsMessage').hide();
                    }
                    
                    // Show clear button
                    $('#clearSearchBtn').show();
                }
            });

            // Clear search functionality
            $('#clearSearchBtn, #clearSearchFromNoResults').click(function(e) {
                e.preventDefault();
                $('#liveSearchInput').val('').trigger('input');
            });

            // Initialize clear button visibility
            if ($('#liveSearchInput').val().trim() !== '') {
                $('#clearSearchBtn').show();
            }

            // Check for success message and show SweetAlert2 modal
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    title: 'Upload Successful!',
                    html: `
                        <div style="text-align: center; margin: 20px 0;">
                            <i class="fas fa-check-circle" style="font-size: 64px; color: #28a745; margin-bottom: 20px;"></i>
                            <p style="font-size: 18px; margin-bottom: 15px; color: #2c3e50;">@Html.Raw(TempData["SuccessMessage"])</p>
                            <div style="background: #f8f9fa; padding: 15px; border-radius: 8px; border-left: 4px solid #007bff; margin: 15px 0;">
                                <p style="margin: 0; color: #6c757d; font-size: 14px;">
                                    <i class="fas fa-info-circle mr-2"></i>
                                    Your prescription has been submitted for processing. You will be notified once it's reviewed.
                                </p>
                            </div>
                        </div>
                    `,
                    icon: 'success',
                    confirmButtonColor: '#28a745',
                    confirmButtonText: '<i class="fas fa-check mr-2"></i>OK',
                    customClass: {
                        popup: 'swal2-popup-custom',
                        title: 'swal2-title-custom',
                        confirmButton: 'swal2-confirm-custom'
                    }
                });
                </text>
            }

            // Check for error message and show SweetAlert2 modal
            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    title: 'Error!',
                    html: `
                        <div style="text-align: center; margin: 20px 0;">
                            <i class="fas fa-exclamation-triangle" style="font-size: 64px; color: #dc3545; margin-bottom: 20px;"></i>
                            <p style="font-size: 18px; margin-bottom: 15px; color: #2c3e50;">@Html.Raw(TempData["ErrorMessage"])</p>
                        </div>
                    `,
                    icon: 'error',
                    confirmButtonColor: '#dc3545',
                    confirmButtonText: '<i class="fas fa-times mr-2"></i>OK',
                    customClass: {
                        popup: 'swal2-popup-custom',
                        title: 'swal2-title-custom',
                        confirmButton: 'swal2-confirm-custom'
                    }
                });
                </text>
            }

            // Handle delete confirmation with SweetAlert2
            $('.delete-prescription').on('click', function(e) {
                e.preventDefault();
                var deleteUrl = $(this).attr('href');
                var prescriptionId = $(this).data('prescription-id');
                
                Swal.fire({
                    title: 'Delete Prescription?',
                    html: `
                        <div style="text-align: left; margin: 20px 0;">
                            <p style="margin-bottom: 15px; font-size: 16px;">Are you sure you want to delete prescription reference:</p>
                            <div style="background: #f8f9fa; padding: 15px; border-radius: 8px; border-left: 4px solid #dc3545;">
                                <strong style="color: #2c3e50; font-size: 18px;">#${prescriptionId}</strong>
                            </div>
                            <p style="margin-top: 15px; color: #6c757d; font-size: 14px;">
                                <i class="fas fa-exclamation-triangle mr-2"></i>
                                This action cannot be undone.
                            </p>
                        </div>
                    `,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fas fa-trash mr-2"></i>Yes, Delete',
                    cancelButtonText: '<i class="fas fa-times mr-2"></i>Cancel',
                    reverseButtons: true,
                    focusCancel: true,
                    customClass: {
                        popup: 'swal2-popup-custom',
                        title: 'swal2-title-custom',
                        confirmButton: 'swal2-confirm-custom',
                        cancelButton: 'swal2-cancel-custom'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Show loading modal
                        Swal.fire({
                            title: 'Deleting...',
                            html: '<div style="text-align: center; margin: 20px 0;"><i class="fas fa-spinner fa-spin" style="font-size: 48px; color: #007bff; margin-bottom: 15px;"></i><p style="font-size: 16px; color: #2c3e50;">Please wait while we delete the prescription.</p></div>',
                            allowOutsideClick: false,
                            allowEscapeKey: false,
                            showConfirmButton: false,
                            customClass: {
                                popup: 'swal2-popup-custom',
                                title: 'swal2-title-custom'
                            }
                        });
                        
                        // Redirect to delete URL
                        window.location.href = deleteUrl;
                    }
                });
            });
        });
    </script>
}
