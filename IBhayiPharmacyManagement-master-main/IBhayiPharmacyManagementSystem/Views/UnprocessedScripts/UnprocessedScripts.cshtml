@model IBhayiPharmacyManagementSystem.ViewModels.PrescriptionHistoryViewModel
@{
    ViewData["Title"] = "Unprocessed Scripts";
    Layout = "_LayoutCustomer";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <a asp-controller="Home" asp-action="Customer" class="btn btn-outline-secondary btn-sm mr-2">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                    Unprocessed Scripts
                </h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <a asp-action="ProcessedScripts" class="btn btn-success mr-2">
                        <i class="fas fa-check-circle"></i> View Processed Scripts
                    </a>
                    <a asp-action="Load" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Upload New Prescription
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        <div class="row">
            <div class="col-12">
                <div class="card card-primary shadow-lg">
                    <div class="card-header bg-gradient-primary">
                        <h3 class="card-title text-white">
                            <i class="fas fa-clock mr-2"></i>Your Unprocessed Prescription Records
                        </h3>
                        <div class="card-tools">
                            <div class="input-group input-group-sm" style="width: 400px;">
                                <input type="text" id="liveSearchInput" class="form-control" 
                                       placeholder="Search by reference, date, status, dispensation..." 
                                       value="@Model.SearchTerm">
                                <div class="input-group-append">
                                    <button type="button" id="clearSearchBtn" class="btn btn-outline-light" style="display: none;">
                                        <i class="fas fa-times"></i>
                                    </button>
                                    <button type="button" class="btn btn-light" disabled>
                                        <i class="fas fa-search"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-body table-responsive p-0">
                        @if (Model.Prescriptions.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover table-striped">
                                    <thead class="thead-dark">
                                        <tr>
                                            <th class="text-center">
                                                <i class="fas fa-hashtag mr-1"></i>Reference #
                                            </th>
                                            <th class="text-center">
                                                <i class="fas fa-calendar mr-1"></i>Upload Date
                                            </th>
                                            <th class="text-center">
                                                <i class="fas fa-info-circle mr-1"></i>Status
                                            </th>
                                            <th class="text-center">
                                                <i class="fas fa-pills mr-1"></i>Dispensation
                                            </th>
                                            <th class="text-center">
                                                <i class="fas fa-cogs mr-1"></i>Actions
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.Prescriptions)
                                        {
                                            <tr class="align-middle" 
                                                data-reference="@item.UnploadId"
                                                data-date="@item.UploadDate.ToString("MMM dd, yyyy")"
                                                data-date-alt="@item.UploadDate.ToString("yyyy-MM-dd")"
                                                data-date-alt2="@item.UploadDate.ToString("dd/MM/yyyy")"
                                                data-date-alt3="@item.UploadDate.ToString("MM/dd/yyyy")"
                                                data-date-alt4="@item.UploadDate.ToString("dd-MM-yyyy")"
                                                data-date-alt5="@item.UploadDate.ToString("MM-dd-yyyy")"
                                                data-status="@item.Status.ToString().ToLower()"
                                                data-dispensation="@(item.RequestDispensation ? "yes" : "no")"
                                                data-dispensation-alt="@(item.RequestDispensation ? "true" : "false")">
                                                <td class="text-center font-weight-bold">#@item.UnploadId</td>
                                                <td class="text-center">@item.UploadDate.ToString("MMM dd, yyyy")</td>
                                                <td class="text-center">
                                                    <span class="badge @GetStatusBadgeClass(item.Status) badge-lg">
                                                        @item.Status
                                                    </span>
                                                    @if (item.Status == UnprocessedScript.PrescriptionStatus.Rejected && !string.IsNullOrEmpty(item.RejectionReason))
                                                    {
                                                        <small class="d-block text-danger mt-1">@item.RejectionReason</small>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    @if (item.RequestDispensation)
                                                    {
                                                        <span class="badge badge-info badge-lg">
                                                            <i class="fas fa-check mr-1"></i>Yes
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-secondary badge-lg">
                                                            <i class="fas fa-times mr-1"></i>No
                                                        </span>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    <div class="btn-group" role="group">
                                                        <button type="button" class="btn btn-outline-primary btn-sm dropdown-toggle" 
                                                                data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                            <i class="fas fa-cog"></i> Actions
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-right shadow">
                                                            <a class="dropdown-item" asp-action="ViewDetails" asp-route-id="@item.UnploadId" asp-route-source="UnprocessedScripts">
                                                                <i class="fas fa-eye text-info mr-2"></i>View Details
                                                            </a>
                                                            @if (item.Status == UnprocessedScript.PrescriptionStatus.Pending)
                                                            {
                                                                <div class="dropdown-divider"></div>
                                                                <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.UnploadId">
                                                                    <i class="fas fa-edit text-warning mr-2"></i>Edit
                                                                </a>
                                                                <a href="@Url.Action("Delete", new { id = item.UnploadId })" 
                                                                   class="dropdown-item text-danger delete-prescription" 
                                                                   data-prescription-id="@item.UnploadId">
                                                                    <i class="fas fa-trash mr-2"></i>Delete
                                                                </a>
                                                            }
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <div id="noResultsMessage" class="text-center py-5" style="display: none;">
                                <i class="fas fa-search fa-3x text-muted mb-3"></i>
                                <h5 class="text-muted">No matching prescriptions found</h5>
                                <p class="text-muted">Try adjusting your search criteria.</p>
                                <button type="button" id="clearSearchFromNoResults" class="btn btn-outline-primary">
                                    <i class="fas fa-times mr-2"></i>Clear Search
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                                {
                                    <div class="mb-4">
                                        <i class="fas fa-search fa-4x text-muted mb-3"></i>
                                        <h4 class="text-muted">No unprocessed prescriptions found</h4>
                                        <p class="text-muted">No prescriptions match your search term "@Model.SearchTerm"</p>
                                    </div>
                                    <a asp-action="UnprocessedScripts" class="btn btn-outline-primary">
                                        <i class="fas fa-arrow-left mr-2"></i>View All Unprocessed Scripts
                                    </a>
                                }
                                else
                                {
                                    <div class="mb-4">
                                        <i class="fas fa-clock fa-4x text-primary mb-3"></i>
                                        <h4 class="text-muted">No unprocessed prescriptions</h4>
                                        <p class="text-muted">You don't have any pending or processing prescriptions at the moment.</p>
                                    </div>
                                    <a asp-action="Load" class="btn btn-primary btn-lg">
                                        <i class="fas fa-plus mr-2"></i>Upload Your First Prescription
                                    </a>
                                }
                            </div>
                        }
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <div class="card-footer bg-light border-top">
                            <div class="row align-items-center">
                                <div class="col-md-6">
                                    <div class="pagination-info">
                                        <i class="fas fa-info-circle text-primary mr-2"></i>
                                        <span class="text-muted">
                                            Showing <strong>@((Model.CurrentPage - 1) * Model.PageSize + 1)</strong> to 
                                            <strong>@Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalItems)</strong> of 
                                            <strong>@Model.TotalItems</strong> prescriptions
                                        </span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <nav aria-label="Prescription pagination" class="d-flex justify-content-end">
                                        <ul class="pagination pagination-sm mb-0">
                                            @if (Model.HasPreviousPage)
                                            {
                                                <li class="page-item">
                                                    <a class="page-link" asp-action="UnprocessedScripts" asp-route-page="1" asp-route-searchTerm="@Model.SearchTerm" 
                                                       title="First Page" aria-label="First Page">
                                                        <i class="fas fa-angle-double-left"></i>
                                                    </a>
                                                </li>
                                                <li class="page-item">
                                                    <a class="page-link" asp-action="UnprocessedScripts" asp-route-page="@(Model.CurrentPage - 1)" asp-route-searchTerm="@Model.SearchTerm" 
                                                       title="Previous Page" aria-label="Previous Page">
                                                        <i class="fas fa-angle-left"></i>
                                                    </a>
                                                </li>
                                            }
                                            else
                                            {
                                                <li class="page-item disabled">
                                                    <span class="page-link">
                                                        <i class="fas fa-angle-double-left"></i>
                                                    </span>
                                                </li>
                                                <li class="page-item disabled">
                                                    <span class="page-link">
                                                        <i class="fas fa-angle-left"></i>
                                                    </span>
                                                </li>
                                            }

                                            @for (int i = Model.StartPage; i <= Model.EndPage; i++)
                                            {
                                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                                    <a class="page-link" asp-action="UnprocessedScripts" asp-route-page="@i" asp-route-searchTerm="@Model.SearchTerm" 
                                                       title="Page @i" aria-label="Page @i">@i</a>
                                                </li>
                                            }

                                            @if (Model.HasNextPage)
                                            {
                                                <li class="page-item">
                                                    <a class="page-link" asp-action="UnprocessedScripts" asp-route-page="@(Model.CurrentPage + 1)" asp-route-searchTerm="@Model.SearchTerm" 
                                                       title="Next Page" aria-label="Next Page">
                                                        <i class="fas fa-angle-right"></i>
                                                    </a>
                                                </li>
                                                <li class="page-item">
                                                    <a class="page-link" asp-action="UnprocessedScripts" asp-route-page="@Model.TotalPages" asp-route-searchTerm="@Model.SearchTerm" 
                                                       title="Last Page" aria-label="Last Page">
                                                        <i class="fas fa-angle-double-right"></i>
                                                    </a>
                                                </li>
                                            }
                                            else
                                            {
                                                <li class="page-item disabled">
                                                    <span class="page-link">
                                                        <i class="fas fa-angle-right"></i>
                                                    </span>
                                                </li>
                                                <li class="page-item disabled">
                                                    <span class="page-link">
                                                        <i class="fas fa-angle-double-right"></i>
                                                    </span>
                                                </li>
                                            }
                                        </ul>
                                    </nav>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</section>

@functions {
    string GetStatusBadgeClass(UnprocessedScript.PrescriptionStatus status)
    {
        return status switch
        {
            UnprocessedScript.PrescriptionStatus.Pending => "badge-secondary",
            UnprocessedScript.PrescriptionStatus.Processing => "badge-warning",
            UnprocessedScript.PrescriptionStatus.Rejected => "badge-danger",
            UnprocessedScript.PrescriptionStatus.Completed => "badge-success",
            _ => "badge-info"
        };
    }
}

@section Scripts {
    <!-- SweetAlert2 CDN -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
