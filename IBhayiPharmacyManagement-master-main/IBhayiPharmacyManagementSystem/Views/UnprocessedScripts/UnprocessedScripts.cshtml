        }
        
        .card-body {
            overflow: visible !important;
        }
        
        .table {
            overflow: visible !important;
        }
        
        .table tbody {
            overflow: visible !important;
        }
        
        .table tbody tr {
            overflow: visible !important;
        }
        
        .table tbody tr td {
            overflow: visible !important;
        }
        
        /* Ensure dropdown button group has proper positioning and stacking */
        
        /* Button group positioning already defined above */
        
        .btn-group .dropdown-menu {
            position: absolute !important;
            top: 0 !important;
            left: auto !important;
            right: 100% !important;
            z-index: 99999 !important;
            border-radius: 8px;
            border: 1px solid #e9ecef;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
