        }
        
        .dropdown-item i {
            width: 20px;
            text-align: center;
        }
        
        .bg-gradient-primary {
            background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        }
        
        .bg-gradient-info {
            background: linear-gradient(135deg, var(--info-color), #17a2b8);
        }
        
        .bg-gradient-warning {
            background: linear-gradient(135deg, var(--warning-color), #fd7e14);
        }
        
        /* Professional status badges */
        .badge-secondary {
            background: linear-gradient(135deg, #7f8c8d, #6c7b7d);
            color: white;
        }
        
        .badge-warning {
            background: linear-gradient(135deg, #f39c12, #e67e22);
            color: white;
        }
        
        .badge-success {
            background: linear-gradient(135deg, #27ae60, #229954);
            color: white;
        }
        
        .badge-danger {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
            color: white;
        }
        
        .badge-info {
            background: linear-gradient(135deg, #3498db, #2980b9);
            color: white;
        }
        
        /* Button improvements */
        .btn-primary {
            background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
            border: none;
            border-radius: 6px;
            padding: 0.5rem 1.25rem;
            font-weight: 500;
            transition: all 0.2s ease;
        }
        
        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(74, 108, 247, 0.3);
        }
        
        .btn-success {
            background: linear-gradient(135deg, var(--success-color), #1e7e34);
            border: none;
            border-radius: 6px;
            padding: 0.5rem 1.25rem;
            font-weight: 500;
        }
        
        .btn-warning {
            background: linear-gradient(135deg, var(--warning-color), #e55a00);
            border: none;
            border-radius: 6px;
            padding: 0.5rem 1.25rem;
            font-weight: 500;
            color: white;
        }
        
        .btn-outline-secondary {
            border: 1px solid #dee2e6;
            border-radius: 6px;
            padding: 0.4rem 1rem;
            font-weight: 500;
            transition: all 0.2s ease;
            color: var(--muted-text);
        }
        
        /* Actions button hover styling */
        .btn-outline-primary:hover {
            background-color: transparent !important;
            border-color: #007bff !important;
            color: #000000 !important;
        }
        
        .btn-outline-primary:focus {
            background-color: transparent !important;
            border-color: #007bff !important;
            color: #000000 !important;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25) !important;
        }
        
        .btn-outline-primary:active {
            background-color: transparent !important;
            border-color: #007bff !important;
            color: #000000 !important;
        }
        
        /* Search bar improvements */
        .input-group .form-control {
            border-radius: 6px 0 0 6px;
            border: 1px solid #ced4da;
            padding: 0.5rem 1rem;
        }
        
        .input-group .btn {
            border-radius: 0 6px 6px 0;
            border: 1px solid #ced4da;
            border-left: none;
        }
        
        /* Content header */
        .content-header h1 {
            color: var(--dark-text);
            font-weight: 600;
        }
        
        /* Search highlighting */
        .search-highlight {
            background-color: #fff3cd !important;
            border-left: 4px solid #ffc107 !important;
            box-shadow: 0 2px 8px rgba(255, 193, 7, 0.3) !important;
        }
        
        .search-highlight td {
            background-color: transparent !important;
        }
        
        /* Enhanced pagination styling */
        .pagination .page-link {
            color: var(--primary-color);
            border: 1px solid #dee2e6;
            border-radius: 6px;
            margin: 0 2px;
            padding: 0.5rem 0.75rem;
            font-weight: 500;
            transition: all 0.2s ease;
        }
        
        .pagination .page-link:hover {
            color: white;
            background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
            border-color: var(--primary-color);
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(44, 62, 80, 0.3);
        }
        
        .pagination .page-item.active .page-link {
            background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
            border-color: var(--primary-color);
            color: white;
            font-weight: 600;
        }
        
        .pagination .page-item.disabled .page-link {
            color: #6c757d;
            background-color: #f8f9fa;
            border-color: #dee2e6;
            cursor: not-allowed;
        }
        
        .pagination-info {
            display: flex;
            align-items: center;
            font-size: 0.9rem;
        }
        
        .pagination-info strong {
            color: var(--primary-color);
            font-weight: 600;
        }
        
        /* Responsive fixes */
        @@media (max-width: 768px) {
            .btn-group .dropdown-menu {
                right: auto !important;
                left: 0 !important;
                min-width: 160px;
            }
        }
    </style>
    
    <script>
        $(document).ready(function() {
            // Enable tooltips
            $('[title]').tooltip();

            // Simple dropdown handling - let Bootstrap handle the click, just prevent hover
            $('.dropdown-toggle').on('mouseenter mouseleave', function(e) {
                e.preventDefault();
                e.stopPropagation();
            });
            
            // Ensure dropdowns close when clicking outside
            $(document).on('click', function(e) {
                if (!$(e.target).closest('.btn-group').length) {
                    $('.dropdown-menu').removeClass('show');
                    $('.btn-group').removeClass('show');
                    $('.dropdown-toggle').attr('aria-expanded', 'false');
                }
            });

            // Live search functionality
            $('#liveSearchInput').on('input', function() {
                var searchTerm = $(this).val().toLowerCase().trim();
                var $rows = $('tbody tr[data-reference]');
                var matchCount = 0;
                
                if (searchTerm === '') {
                    // Remove all highlighting and show all rows
                    $rows.removeClass('search-highlight').show();
                    $('#noResultsMessage').hide();
                    $('#clearSearchBtn').hide();
                } else {
                    // Highlight matching rows and hide non-matching ones
                    $rows.each(function() {
                        var $row = $(this);
                        var reference = $row.data('reference').toString();
                        var date = $row.data('date').toLowerCase();
                        var dateAlt = $row.data('date-alt').toLowerCase();
                        var dateAlt2 = $row.data('date-alt2').toLowerCase();
                        var dateAlt3 = $row.data('date-alt3').toLowerCase();
                        var dateAlt4 = $row.data('date-alt4').toLowerCase();
                        var dateAlt5 = $row.data('date-alt5').toLowerCase();
                        var doctor = $row.data('doctor').toLowerCase();
                        var status = $row.data('status');
                        var dispensation = $row.data('dispensation');
                        var dispensationAlt = $row.data('dispensation-alt');
                        
                        // Check if search term matches any of the data attributes
                        var matches = 
                            reference.includes(searchTerm) ||
                            date.includes(searchTerm) ||
                            dateAlt.includes(searchTerm) ||
                            dateAlt2.includes(searchTerm) ||
                            dateAlt3.includes(searchTerm) ||
                            dateAlt4.includes(searchTerm) ||
                            dateAlt5.includes(searchTerm) ||
                            doctor.includes(searchTerm) ||
                            status.includes(searchTerm) ||
                            dispensation.includes(searchTerm) ||
                            dispensationAlt.includes(searchTerm);
                        
                        if (matches) {
                            $row.addClass('search-highlight').show();
                            matchCount++;
                        } else {
                            $row.removeClass('search-highlight').hide();
                        }
                    });
                    
                    // Show/hide no results message
                    if (matchCount === 0) {
                        $('#noResultsMessage').show();
                    } else {
                        $('#noResultsMessage').hide();
                    }
                    
                    // Show clear button
                    $('#clearSearchBtn').show();
                }
            });

            // Clear search functionality
            $('#clearSearchBtn, #clearSearchFromNoResults').click(function(e) {
                e.preventDefault();
                $('#liveSearchInput').val('').trigger('input');
            });

            // Initialize clear button visibility
            if ($('#liveSearchInput').val().trim() !== '') {
                $('#clearSearchBtn').show();
            }
        });
    </script>
}
