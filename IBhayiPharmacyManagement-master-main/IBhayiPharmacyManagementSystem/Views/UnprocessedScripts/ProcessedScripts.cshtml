@model IBhayiPharmacyManagementSystem.ViewModels.PrescriptionHistoryViewModel
@{
    ViewData["Title"] = "Processed Scripts";
    Layout = "_LayoutCustomer";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <a asp-controller="Home" asp-action="Customer" class="btn btn-outline-secondary btn-sm mr-2">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                    Processed Scripts
                </h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <a asp-controller="Prescriptions" asp-action="DispensedPrescriptions" class="btn btn-success mr-2">
                        <i class="fas fa-pills"></i> Dispensed Prescriptions
                    </a>
                    <a asp-action="UnprocessedScripts" class="btn btn-warning mr-2">
                        <i class="fas fa-clock"></i> View Unprocessed Scripts
                    </a>
                    <a asp-action="Load" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Upload New Prescription
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                <h5><i class="icon fas fa-check"></i> Success!</h5>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="row">
            <div class="col-12">
                <div class="card card-primary shadow-lg">
                    <div class="card-header bg-gradient-primary">
                        <h3 class="card-title text-white">
                            <i class="fas fa-check-circle mr-2"></i>Your Processed Prescription Records
                        </h3>
                        <div class="card-tools">
                            <div class="input-group input-group-sm" style="width: 400px;">
                                <input type="text" id="liveSearchInput" class="form-control" 
                                       placeholder="Search by reference, date, doctor, status, dispensation..." 
                                       value="@Model.SearchTerm">
                                <div class="input-group-append">
                                    <button type="button" id="clearSearchBtn" class="btn btn-outline-light" style="display: none;">
                                        <i class="fas fa-times"></i>
                                    </button>
                                    <button type="button" class="btn btn-light" disabled>
                                        <i class="fas fa-search"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-body table-responsive p-0">
                        @if (Model.Prescriptions.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover table-striped">
                                    <thead class="thead-dark">
                                        <tr>
                                            <th class="text-center">
                                                <i class="fas fa-hashtag mr-1"></i>Reference #
                                            </th>
                                            <th class="text-center">
                                                <i class="fas fa-calendar mr-1"></i>Upload Date
                                            </th>
                                            <th class="text-center">
                                                <i class="fas fa-user-md mr-1"></i>Doctor
                                            </th>
                                            <th class="text-center">
                                                <i class="fas fa-info-circle mr-1"></i>Status
                                            </th>
                                            <th class="text-center">
                                                <i class="fas fa-pills mr-1"></i>Dispensation
                                            </th>
                                            <th class="text-center">
                                                <i class="fas fa-cogs mr-1"></i>Actions
                                            </th>
                                        </tr>
                                    </thead>
                                <tbody>
                                    @foreach (var item in Model.Prescriptions)
                                    {
                                        <tr class="align-middle" 
                                            data-reference="@item.UnploadId"
                                            data-date="@item.UploadDate.ToString("MMM dd, yyyy")"
                                            data-date-alt="@item.UploadDate.ToString("yyyy-MM-dd")"
                                            data-date-alt2="@item.UploadDate.ToString("dd/MM/yyyy")"
                                            data-date-alt3="@item.UploadDate.ToString("MM/dd/yyyy")"
                                            data-date-alt4="@item.UploadDate.ToString("dd-MM-yyyy")"
                                            data-date-alt5="@item.UploadDate.ToString("MM-dd-yyyy")"
                                            data-doctor="@(item.Doctor?.Name ?? "N/A")"
                                            data-status="@item.Status.ToString().ToLower()"
                                            data-dispensation="@(item.RequestDispensation ? "yes" : "no")"
                                            data-dispensation-alt="@(item.RequestDispensation ? "true" : "false")">
                                            <td class="text-center font-weight-bold">#@item.UnploadId</td>
                                            <td class="text-center">@item.UploadDate.ToString("MMM dd, yyyy")</td>
                                            <td class="text-center">
                                                @if (item.Doctor != null)
                                                {
                                                    <span class="badge badge-primary badge-lg">
                                                        <i class="fas fa-user-md mr-1"></i>@item.Doctor.Name
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-secondary badge-lg">
                                                        <i class="fas fa-question-circle mr-1"></i>Not Assigned
                                                    </span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @GetStatusBadgeClass(item.Status) badge-lg">
                                                    @item.Status
                                                </span>
                                                @if (item.Status == UnprocessedScript.PrescriptionStatus.Rejected && !string.IsNullOrEmpty(item.RejectionReason))
                                                {
                                                    <small class="d-block text-danger mt-1">@item.RejectionReason</small>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (item.RequestDispensation)
                                                {
                                                    <span class="badge badge-info badge-lg">
                                                        <i class="fas fa-check mr-1"></i>Yes
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-secondary badge-lg">
                                                        <i class="fas fa-times mr-1"></i>No
                                                    </span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <button type="button" class="btn btn-outline-primary btn-sm dropdown-toggle" 
                                                            data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                        <i class="fas fa-cog"></i> Actions
                                                    </button>
                                                    <div class="dropdown-menu dropdown-menu-right shadow">
                                                        <a class="dropdown-item" asp-action="ViewDetails" asp-route-id="@item.UnploadId" asp-route-source="ProcessedScripts">
                                                            <i class="fas fa-eye text-info mr-2"></i>View Details
                                                        </a>
                                                        @if ((item.FileContent != null && item.FileContent.Length > 0) || !string.IsNullOrEmpty(item.ScriptImagePath))
                                                        {
                                                            <div class="dropdown-divider"></div>
                                                            <a class="dropdown-item" asp-action="DownloadPrescription" asp-route-id="@item.UnploadId">
                                                                <i class="fas fa-download text-success mr-2"></i>Download File
                                                            </a>
                                                            var viewFileUrl = item.FileContent != null && item.FileContent.Length > 0
                                                                ? Url.Action("ServePrescriptionFile", "UnprocessedScripts", new { id = item.UnploadId })
                                                                : item.ScriptImagePath;
                                                            
                                                            <a class="dropdown-item" href="@viewFileUrl" target="_blank">
                                                                <i class="fas fa-external-link-alt text-primary mr-2"></i>View File
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <div class="dropdown-divider"></div>
                                                            <span class="dropdown-item disabled">
                                                                <i class="fas fa-exclamation-triangle text-warning mr-2"></i>No File Available
                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            <div id="noResultsMessage" class="text-center py-5" style="display: none;">
                                <i class="fas fa-search fa-3x text-muted mb-3"></i>
                                <h5 class="text-muted">No matching prescriptions found</h5>
                                <p class="text-muted">Try adjusting your search criteria.</p>
                                <button type="button" id="clearSearchFromNoResults" class="btn btn-outline-primary">
                                    <i class="fas fa-times mr-2"></i>Clear Search
                                </button>
                            </div>
                        </div>
                        }
                        else
                        {
                            <div class="text-center py-4">
                                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                                {
                                    <i class="fas fa-search fa-3x text-muted mb-3"></i>
                                    <h5 class="text-muted">No processed prescriptions found matching "@Model.SearchTerm"</h5>
                                    <p class="text-muted">Try adjusting your search terms or <a asp-action="ProcessedScripts">view all processed prescriptions</a></p>
                                }
                                else
                                {
                                    <i class="fas fa-prescription-bottle-alt fa-3x text-muted mb-3"></i>
                                    <h5 class="text-muted">No processed prescriptions found</h5>
                                    <p class="text-muted">You don't have any completed or rejected prescriptions yet.</p>
                                    <a asp-action="Load" class="btn btn-primary">
                                        <i class="fas fa-plus"></i> Upload Your First Prescription
                                    </a>
                                }
                            </div>
                        }
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <div class="card-footer bg-light border-top">
                            <div class="row align-items-center">
                                <div class="col-md-6">
                                    <div class="pagination-info">
                                        <i class="fas fa-info-circle text-primary mr-2"></i>
                                        <span class="text-muted">
                                            Showing <strong>@((Model.CurrentPage - 1) * Model.PageSize + 1)</strong> to 
                                            <strong>@Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalItems)</strong> of 
                                            <strong>@Model.TotalItems</strong> prescriptions
                                        </span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <nav aria-label="Processed prescription pagination" class="d-flex justify-content-end">
                                        <ul class="pagination pagination-sm mb-0">
                                            @if (Model.HasPreviousPage)
                                            {
                                                <li class="page-item">
                                                    <a class="page-link" asp-action="ProcessedScripts" asp-route-page="1" asp-route-searchTerm="@Model.SearchTerm" 
                                                       title="First Page" aria-label="First Page">
                                                        <i class="fas fa-angle-double-left"></i>
                                                    </a>
                                                </li>
                                                <li class="page-item">
                                                    <a class="page-link" asp-action="ProcessedScripts" asp-route-page="@(Model.CurrentPage - 1)" asp-route-searchTerm="@Model.SearchTerm" 
                                                       title="Previous Page" aria-label="Previous Page">
                                                        <i class="fas fa-angle-left"></i>
                                                    </a>
                                                </li>
                                            }
                                            else
                                            {
                                                <li class="page-item disabled">
                                                    <span class="page-link">
                                                        <i class="fas fa-angle-double-left"></i>
                                                    </span>
                                                </li>
                                                <li class="page-item disabled">
                                                    <span class="page-link">
                                                        <i class="fas fa-angle-left"></i>
                                                    </span>
                                                </li>
                                            }

                                            @for (int i = Model.StartPage; i <= Model.EndPage; i++)
                                            {
                                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                                    <a class="page-link" asp-action="ProcessedScripts" asp-route-page="@i" asp-route-searchTerm="@Model.SearchTerm" 
                                                       title="Page @i" aria-label="Page @i">@i</a>
                                                </li>
                                            }

                                            @if (Model.HasNextPage)
                                            {
                                                <li class="page-item">
                                                    <a class="page-link" asp-action="ProcessedScripts" asp-route-page="@(Model.CurrentPage + 1)" asp-route-searchTerm="@Model.SearchTerm" 
                                                       title="Next Page" aria-label="Next Page">
                                                        <i class="fas fa-angle-right"></i>
                                                    </a>
                                                </li>
                                                <li class="page-item">
                                                    <a class="page-link" asp-action="ProcessedScripts" asp-route-page="@Model.TotalPages" asp-route-searchTerm="@Model.SearchTerm" 
                                                       title="Last Page" aria-label="Last Page">
                                                        <i class="fas fa-angle-double-right"></i>
                                                    </a>
                                                </li>
                                            }
                                            else
                                            {
                                                <li class="page-item disabled">
                                                    <span class="page-link">
                                                        <i class="fas fa-angle-right"></i>
                                                    </span>
                                                </li>
                                                <li class="page-item disabled">
                                                    <span class="page-link">
                                                        <i class="fas fa-angle-double-right"></i>
                                                    </span>
                                                </li>
                                            }
                                        </ul>
                                    </nav>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</section>

@functions {
    string GetStatusBadgeClass(UnprocessedScript.PrescriptionStatus status)
    {
        return status switch
        {
            UnprocessedScript.PrescriptionStatus.Pending => "badge-secondary",
            UnprocessedScript.PrescriptionStatus.Processing => "badge-warning",
            UnprocessedScript.PrescriptionStatus.Rejected => "badge-danger",
            UnprocessedScript.PrescriptionStatus.Completed => "badge-success",
            _ => "badge-info"
        };
    }
}

@section Scripts {
    <style>
    /* Professional, warm beige color palette */
    :root {
        --primary-color: #d4b896;
        --primary-dark: #b8a082;
        --secondary-color: #8b7355;
        --success-color: #27ae60;
        --warning-color: #f39c12;
        --danger-color: #e74c3c;
        --info-color: #d4b896;
        --light-bg: #f8f9fa;
        --dark-text: #2c3e50;
        --muted-text: #7f8c8d;
    }

        .badge-lg {
            font-size: 0.85em;
            padding: 0.5em 0.8em;
            border-radius: 15px;
            font-weight: 500;
        }
        
        .table th {
            background: linear-gradient(135deg, #34495e, #2c3e50);
            color: white;
            font-weight: 600;
            border: none;
            text-transform: uppercase;
            font-size: 0.8em;
            letter-spacing: 0.5px;
        }
        
        .table td {
            vertical-align: middle;
            border-color: #e9ecef;
            padding: 1rem 0.75rem;
        }
        
        .table-striped tbody tr:nth-of-type(odd) {
            background-color: rgba(73, 80, 87, 0.02);
        }
        
        .table-hover tbody tr:hover {
            background-color: rgba(74, 108, 247, 0.08);
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        
        /* Ensure dropdown button group has proper positioning and stacking */
        .btn-group {
            position: relative;
            z-index: 10;
        }
        
        .btn-group.show {
            z-index: 99999 !important;
        }
        
        .btn-group .dropdown-toggle {
            position: relative;
            z-index: 99998 !important;
        }
        
        .btn-group.show .dropdown-toggle {
            z-index: 99998 !important;
        }
        
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }
        
        .card-header {
            border-radius: 12px 12px 0 0 !important;
            border: none;
            padding: 1.25rem 1.5rem;
        }
        
        /* Ensure table containers allow dropdown overflow */
        .table-responsive {
            overflow: visible !important;
        }
        
        .card-body {
            overflow: visible !important;
        }
        
        .table {
            overflow: visible !important;
        }
        
        .table tbody {
            overflow: visible !important;
        }
        
        .table tbody tr {
            overflow: visible !important;
        }
        
        .table tbody tr td {
            overflow: visible !important;
        }
        
        /* Ensure dropdown button group has proper positioning and stacking */
        
        /* Button group positioning already defined above */
        
        .btn-group .dropdown-menu {
            position: absolute !important;
            top: 0 !important;
            left: auto !important;
            right: 100% !important;
            z-index: 99999 !important;
            border-radius: 8px;
            border: 1px solid #e9ecef;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            min-width: 180px;
            padding: 0.5rem 0;
            background: white;
            margin-right: 10px;
        }
        
        .btn-group .dropdown-menu.show {
            display: block !important;
        }
        
        .btn-group.show .dropdown-menu {
            display: block !important;
        }
        
        .dropdown-item {
            padding: 0.75rem 1.25rem;
            transition: all 0.2s ease;
            font-weight: 500;
            color: var(--dark-text);
        }
        
        .dropdown-item:hover {
            background-color: #f8f9fa;
            color: var(--primary-color);
