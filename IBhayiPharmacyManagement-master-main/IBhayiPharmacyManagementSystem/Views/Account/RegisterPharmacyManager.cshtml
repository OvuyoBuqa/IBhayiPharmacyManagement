@model IBhayiPharmacyManagementSystem.ViewModels.RegisterPharmacyManagerViewModel
@using IBhayiPharmacyManagementSystem.Models
@using Microsoft.EntityFrameworkCore
@inject IBhayiPharmacyManagementSystem.Data.AppDbContext _context

@{ ViewData["Title"] = "Register Pharmacy Manager";
    Layout = "_LayoutAdmin";

    var pharmacies = ViewBag.Pharmacies as List<Pharmacy>;

}

<style>
    .pm-container { background: #f8f9fa; padding: 20px; border-radius: 12px; }
    .content-card { background: #fff; border-radius: 12px; box-shadow: 0 8px 30px rgba(0,0,0,0.08); border: 1px solid #e9ecef; margin-bottom: 24px; overflow: hidden; }
    .card-header { background: linear-gradient(135deg, #6c757d, #5a6268); color: #fff; padding: 18px 22px; }
    .card-title { margin: 0; font-weight: 700; font-size: 1.1rem; display: flex; align-items: center; }
    .card-title i { margin-right: 10px; color: #27ae60; }
    .form-control, .form-select { border: 2px solid #e9ecef; border-radius: 10px; padding: 10px 14px; }
    .form-control:focus, .form-select:focus { border-color: #3498db; box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.25); }
    .btn-primary { background: linear-gradient(135deg, #6c757d, #5a6268); border: 1px solid #5a6268; }
    .btn-outline-primary { border: 2px solid #3498db; color: #3498db; }
    .btn-outline-danger { border: 2px solid #e74c3c; color: #e74c3c; }
    .table thead th { background: linear-gradient(135deg, #6c757d, #5a6268); color: #fff; border: none; }
    .badge-active { background: #27ae60; }
    .badge-inactive { background: #e74c3c; }
    .alert-success { border-left: 5px solid #27ae60; }
    .toggle-password i { pointer-events: none; }
   
    .page-title { font-size: 1.5rem; font-weight: 700; color: #2c3e50; }
    .help-text { font-size: .9rem; color: #6c757d; }
</style>

<div class="pm-container">
    <div class="content-card">
        <div class="card-header">
            <h5 class="card-title"><i class="fas fa-user-shield"></i><span class="page-title">Register Pharmacy Manager</span></h5>
        </div>
        <div class="p-4">
            <form asp-action="RegisterPharmacyManager" method="post">
                <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success" role="alert">
                        @Html.Raw(TempData["SuccessMessage"])
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Surname" class="form-label fw-bold"></label>
                        <input asp-for="Surname" class="form-control" />
                        <span asp-validation-for="Surname" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BranchName" class="form-label fw-bold"></label>
                        <input asp-for="BranchName" class="form-control" />
                        <span asp-validation-for="BranchName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ContactNumber" class="form-label fw-bold"></label>
                        <input asp-for="ContactNumber" class="form-control" />
                        <span asp-validation-for="ContactNumber" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-bold"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PharmacyId" class="form-label fw-bold"></label>
                        <select asp-for="PharmacyId" class="form-select" asp-items="new SelectList(pharmacies, nameof(Pharmacy.PharmacyId), nameof(Pharmacy.Name))">
                            <option value="">-- Select Pharmacy --</option>
                        </select>
                        <span asp-validation-for="PharmacyId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <input asp-for="Password" class="form-control" id="passwordField" />
                            <button class="btn btn-outline-secondary toggle-password" type="button"><i class="fas fa-eye"></i></button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <input asp-for="ConfirmPassword" class="form-control" id="confirmPasswordField" />
                            <button class="btn btn-outline-secondary toggle-password" type="button"><i class="fas fa-eye"></i></button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-user-plus me-2"></i>Register
                    </button>
                </div>
            </form>
        </div>
    </div>

    @{
        var managers = _context.PharmacyManagers
            .Include(pm => pm.User)
            .Include(pm => pm.Pharmacy)
            .OrderBy(pm => pm.Surname).ThenBy(pm => pm.Name)
            .ToList();
    }

    <div class="content-card">
        <div class="card-header">
            <h5 class="card-title"><i class="fas fa-users-cog"></i><span class="page-title">Pharmacy Managers</span></h5>
        </div>
        <div class="p-3">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Branch</th>
                            <th>Contact</th>
                            <th>Email</th>
                            <th>Pharmacy</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (managers.Any())
                        {
                            foreach (var m in managers)
                            {
                                <tr>
                                    <td>@m.Name @m.Surname</td>
                                    <td>@m.BranchName</td>
                                    <td>@m.ContactNumber</td>
                                    <td>@m.Email</td>
                                    <td>@(m.Pharmacy?.Name ?? "-")</td>
                                    <td>
                                        @if (m.IsActive)
                                        {
                                            <span class="badge badge-active">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-inactive">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            <a class="btn btn-sm btn-outline-primary disabled" title="Edit (backend pending)"><i class="fas fa-edit"></i></a>
                                            <button class="btn btn-sm btn-outline-danger" disabled title="Delete (backend pending)"><i class="fas fa-trash"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center muted">No pharmacy managers found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="help-text">Edit/Delete actions are shown for consistency with the customer design language and will work once corresponding endpoints exist.</div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            // Toggle password visibility
            $('.toggle-password').click(function() {
                const input = $(this).siblings('input');
                const icon = $(this).find('i');
                const type = input.attr('type') === 'password' ? 'text' : 'password';
                input.attr('type', type);
                icon.toggleClass('fa-eye fa-eye-slash');
            });
        });
    </script>
}
