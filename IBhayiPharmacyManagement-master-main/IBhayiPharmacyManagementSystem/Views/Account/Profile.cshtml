@section Scripts {
    <!-- jQuery Validation -->
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
    <!-- SweetAlert2 CDN -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        $(document).ready(function() {
            // Show/Hide password toggles
            document.querySelectorAll('.toggle-password').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var targetId = btn.getAttribute('data-target');
                    var input = document.getElementById(targetId);
                    if (!input) return;
                    var icon = btn.querySelector('i');
                    if (input.type === 'password') {
                        input.type = 'text';
                        if (icon) { icon.classList.remove('fa-eye'); icon.classList.add('fa-eye-slash'); }
                    } else {
                        input.type = 'password';
                        if (icon) { icon.classList.remove('fa-eye-slash'); icon.classList.add('fa-eye'); }
                    }
                });
            });
            
            // Phone number validation for profile edit form
            $('input[name="phoneNumber"]').on('input', function () {
                const phone = $(this).val().replace(/\D/g, ''); // Remove non-digits
                $(this).val(phone); // Update the field with only digits
                
                // Validate length
                if (phone.length > 10) {
                    $(this).val(phone.substring(0, 10)); // Limit to 10 digits
                }
            });

            // Show success message with SweetAlert2
            function showSuccessMessage(message) {
                Swal.fire({
                    title: 'Success!',
                    html: `
                        <div style="text-align: center; margin: 20px 0;">
                            <i class="fas fa-check-circle" style="font-size: 64px; color: #28a745; margin-bottom: 20px;"></i>
                            <p style="font-size: 18px; margin-bottom: 15px; color: #2c3e50;">${message}</p>
                        </div>
                    `,
                    icon: 'success',
                    confirmButtonColor: '#28a745',
                    confirmButtonText: '<i class="fas fa-check mr-2"></i>OK',
                    customClass: {
                        popup: 'swal2-popup-custom',
                        title: 'swal2-title-custom',
                        confirmButton: 'swal2-confirm-custom'
                    }
                });
            }

            // Show error message with SweetAlert2
            function showErrorMessage(message) {
                Swal.fire({
                    title: 'Error!',
                    html: `
                        <div style="text-align: center; margin: 20px 0;">
                            <i class="fas fa-exclamation-triangle" style="font-size: 64px; color: #dc3545; margin-bottom: 20px;"></i>
                            <p style="font-size: 18px; margin-bottom: 15px; color: #2c3e50;">${message}</p>
                        </div>
                    `,
                    icon: 'error',
                    confirmButtonColor: '#dc3545',
                    confirmButtonText: '<i class="fas fa-times mr-2"></i>OK',
                    customClass: {
                        popup: 'swal2-popup-custom',
                        title: 'swal2-title-custom',
                        confirmButton: 'swal2-confirm-custom'
                    }
                });
            }

            // Check for TempData messages and show SweetAlert2 modals
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    title: 'Success!',
                    html: `
                        <div style="text-align: center; margin: 20px 0;">
                            <i class="fas fa-check-circle" style="font-size: 64px; color: #28a745; margin-bottom: 20px;"></i>
                            <p style="font-size: 18px; margin-bottom: 15px; color: #2c3e50;">@Html.Raw(TempData["SuccessMessage"])</p>
                        </div>
                    `,
                    icon: 'success',
                    confirmButtonColor: '#28a745',
                    confirmButtonText: '<i class="fas fa-check mr-2"></i>OK',
                    customClass: {
                        popup: 'swal2-popup-custom',
                        title: 'swal2-title-custom',
                        confirmButton: 'swal2-confirm-custom'
                    }
                });
                </text>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    title: 'Error!',
                    html: `
                        <div style="text-align: center; margin: 20px 0;">
                            <i class="fas fa-exclamation-triangle" style="font-size: 64px; color: #dc3545; margin-bottom: 20px;"></i>
                            <p style="font-size: 18px; margin-bottom: 15px; color: #2c3e50;">@Html.Raw(TempData["ErrorMessage"])</p>
                        </div>
                    `,
                    icon: 'error',
                    confirmButtonColor: '#dc3545',
                    confirmButtonText: '<i class="fas fa-times mr-2"></i>OK',
                    customClass: {
                        popup: 'swal2-popup-custom',
                        title: 'swal2-title-custom',
                        confirmButton: 'swal2-confirm-custom'
                    },
                    didClose: () => {
                        // Clear password fields after error
                        $('#OldPassword').val('');
                        $('#NewPassword').val('');
                        $('#ConfirmNewPassword').val('');
                    }
                });
                </text>
            }

            // Handle edit profile form submission
            $('#editProfileForm').on('submit', function(e) {
                e.preventDefault();
                var form = $(this);
                var submitBtn = form.find('button[type="submit"]');

                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Saving...');

                $.ajax({
                    url: '@Url.Action("UpdateProfile", "Account")',
                    type: 'POST',
                    data: form.serialize(),
                    success: function(response) {
                        if (response.success) {
                            showSuccessMessage('Profile updated successfully!');
                            $('#editProfileModal').modal('hide');
                            
                            // Update the display fields
                            $('#fullName').val(response.data.fullName);
                            $('#phoneNumber').val(response.data.phoneNumber);
                            $('#fullAddress').val(response.data.fullAddress);
                            
                            // Update initials avatar
                            $('.initials-text').text(response.data.initials);
                            
                            // Update the model data
                            $('input[name="fullName"]').val(response.data.fullName);
                            $('input[name="phoneNumber"]').val(response.data.phoneNumber);
                        } else {
                            showErrorMessage(response.message || 'Failed to update profile');
                        }
                    },
                    error: function() {
                        showErrorMessage('An error occurred while updating profile');
                    },
                    complete: function() {
                        submitBtn.prop('disabled', false).html('<i class="fas fa-save me-2"></i>Save Changes');
                    }
                });
            });

            // Handle edit medical info form submission
            $('#editMedicalInfoForm').on('submit', function(e) {
                e.preventDefault();
                var form = $(this);
                var submitBtn = form.find('button[type="submit"]');

                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Saving...');

                $.ajax({
                    url: '@Url.Action("UpdateMedicalInfo", "Account")',
                    type: 'POST',
                    data: form.serialize(),
                    success: function(response) {
                        if (response.success) {
                            showSuccessMessage('Medical information updated successfully!');
                            $('#editMedicalInfoModal').modal('hide');

                            // Update the display fields in the Medical Information card
                            $('#chronicConditionsDisplay').text(response.data.chronicConditions || 'N/A');
                            $('#medicalNotesDisplay').text(response.data.medicalNotes || 'N/A');
                            $('#emergencyContactNameDisplay').text(response.data.emergencyContactName || 'N/A');
                            $('#emergencyContactPhoneDisplay').text(response.data.emergencyContactPhone || 'N/A');
                            $('#bloodTypeDisplay').text(response.data.bloodType || 'N/A');
                            $('#medicalAidNumberDisplay').text(response.data.medicalAidNumber || 'N/A');
                            $('#medicalAidSchemeDisplay').text(response.data.medicalAidScheme || 'N/A');

                        } else {
                            showErrorMessage(response.message || 'Failed to update medical information');
                        }
                    },
                    error: function() {
                        showErrorMessage('An error occurred while updating medical information');
                    },
                    complete: function() {
                        submitBtn.prop('disabled', false).html('<i class="fas fa-save me-2"></i>Save Medical Info');
                    }
                });
            });


            // Remove AJAX change password; now handled by server post


            // Handle two-factor authentication toggle
            $('#twoFactorSwitch').on('change', function() {
                var enabled = $(this).is(':checked');
                var action = enabled ? 'enable' : 'disable';
                
                $.ajax({
                    url: '@Url.Action("ToggleTwoFactor", "Account")',
                    type: 'POST',
                    data: { enabled: enabled },
                    success: function(response) {
                        if (response.success) {
                            showSuccessMessage(`Two-factor authentication ${action}d successfully!`);
                        } else {
                            showErrorMessage(response.message || `Failed to ${action} two-factor authentication`);
                            // Revert the toggle if it failed
                            $('#twoFactorSwitch').prop('checked', !enabled);
                        }
                    },
                    error: function() {
                        showErrorMessage(`An error occurred while ${action}ing two-factor authentication`);
                        // Revert the toggle if it failed
                        $('#twoFactorSwitch').prop('checked', !enabled);
                    }
                });
            });

            // Handle login notifications toggle
            $('#loginNotificationsSwitch').on('change', function() {
                var enabled = $(this).is(':checked');
                var action = enabled ? 'enabled' : 'disabled';
                
                $.ajax({
                    url: '@Url.Action("ToggleLoginNotifications", "Account")',
                    type: 'POST',
                    data: { enabled: enabled },
                    success: function(response) {
                        if (response.success) {
                            showSuccessMessage(`Login notifications ${action} successfully!`);
                        } else {
                            showErrorMessage(response.message || `Failed to ${action} login notifications`);
                            // Revert the toggle if it failed
                            $('#loginNotificationsSwitch').prop('checked', !enabled);
                        }
                    },
                    error: function() {
                        showErrorMessage(`An error occurred while ${action}ing login notifications`);
                        // Revert the toggle if it failed
                        $('#loginNotificationsSwitch').prop('checked', !enabled);
                    }
                });
            });

            // Load active ingredients when allergies modal opens
            $('#allergiesModal').on('show.bs.modal', function() {
                loadActiveIngredients();
            });

            // Load active ingredients for the dropdown
            function loadActiveIngredients() {
                $.ajax({
                    url: '@Url.Action("GetActiveIngredients", "Account")',
                    type: 'GET',
                    success: function(data) {
                        var select = $('.ingredient-select');
                        select.empty();
                        select.append('<option value="">Select Active Ingredient</option>');
                        
                        if (data && data.length > 0) {
                            data.forEach(function(ingredient) {
                                select.append(`<option value="${ingredient.activeIngredientId}">${ingredient.name}</option>`);
                            });
                        }
                    },
                    error: function() {
                        showErrorMessage('Failed to load active ingredients');
                    }
                });
            }

            // Handle adding new allergy from database
            $('.add-allergy').on('click', function() {
                var ingredientId = $('select[name="newAllergyIngredientId"]').val();
                var severity = $('select[name="newAllergySeverity"]').val();
                var description = $('input[name="newAllergyDescription"]').val();

                if (!ingredientId || !severity) {
                    showErrorMessage('Please select both ingredient and severity');
                    return;
                }

                var ingredientName = $('select[name="newAllergyIngredientId"] option:selected').text();
                
                // Add to the current allergies container
                var allergyHtml = `
                    <div class="allergy-item temp-allergy" data-temp-id="temp-${Date.now()}" data-active-ingredient-id="${ingredientId}">
                        <input type="hidden" name="newAllergies" value="DB_${ingredientId}|${severity}|${description || ''}">
                        <input type="hidden" name="AllergyIds" value="0" />
                        <div class="row">
                            <div class="col-md-4">
                                <label class="form-label">Ingredient</label>
                                <input type="text" class="form-control" value="${ingredientName}" readonly />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Severity</label>
                                <select name="AllergySeverities" class="form-control">
                                    <option value="Mild">Mild</option>
                                    <option value="Moderate">Moderate</option>
                                    <option value="Severe">Severe</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Description</label>
                                <input type="text" name="AllergyDescriptions" class="form-control" value="${description || ''}" placeholder="Description (optional)">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">&nbsp;</label>
                                <button type="button" class="btn btn-sm btn-danger remove-temp-allergy">
                                    <i class="fas fa-trash"></i> Remove
                                </button>
                            </div>
                        </div>
                    </div>
                `;
                
                $('.current-allergies-container').append(allergyHtml);
                $('#noAllergiesMessage').hide();
                
                // Set the selected severity in the newly added dropdown
                $('.current-allergies-container').find(`[data-active-ingredient-id="${ingredientId}"] select[name="AllergySeverities"]`).val(severity);
                
                // Clear the form
                $('select[name="newAllergyIngredientId"]').val('');
                $('select[name="newAllergySeverity"]').val('');
                $('input[name="newAllergyDescription"]').val('');
            });

            // Handle adding custom allergy
            $('.add-custom-allergy').on('click', function() {
                var ingredientName = $('input[name="newCustomAllergyName"]').val();
                var severity = $('select[name="newCustomAllergySeverity"]').val();
                var description = $('input[name="newCustomAllergyDescription"]').val();

                if (!ingredientName || !severity) {
                    showErrorMessage('Please enter an ingredient name and select severity');
                    return;
                }

                // Add to the current allergies container
                var allergyHtml = `
                    <div class="allergy-item temp-allergy" data-temp-id="temp-${Date.now()}" data-active-ingredient-id="0">
                        <input type="hidden" name="newAllergies" value="CUSTOM_${ingredientName}|${severity}|${description || ''}">
                        <input type="hidden" name="AllergyIds" value="0" />
                        <div class="row">
                            <div class="col-md-4">
                                <label class="form-label">Ingredient</label>
                                <input type="text" class="form-control" value="${ingredientName}" readonly />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Severity</label>
                                <select name="AllergySeverities" class="form-control">
                                    <option value="Mild">Mild</option>
                                    <option value="Moderate">Moderate</option>
                                    <option value="Severe">Severe</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Description</label>
                                <input type="text" name="AllergyDescriptions" class="form-control" value="${description || ''}" placeholder="Description (optional)">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">&nbsp;</label>
                                <button type="button" class="btn btn-sm btn-danger remove-temp-allergy">
                                    <i class="fas fa-trash"></i> Remove
                                </button>
                            </div>
                        </div>
                    </div>
                `;
                
                $('.current-allergies-container').append(allergyHtml);
                $('#noAllergiesMessage').hide();
                
                // Set the selected severity in the newly added dropdown
                $('.current-allergies-container').find(`[data-temp-id="temp-${Date.now()}"] select[name="AllergySeverities"]`).val(severity);
                
                // Clear the form
                $('input[name="newCustomAllergyName"]').val('');
                $('select[name="newCustomAllergySeverity"]').val('');
                $('input[name="newCustomAllergyDescription"]').val('');
            });

            // Handle removing existing allergies
            $(document).on('click', '.remove-allergy', function() {
                var allergyId = $(this).data('allergy-id');
                var allergyItem = $(this).closest('.allergy-item');
                
                Swal.fire({
                    title: 'Remove Allergy',
                    text: 'Are you sure you want to remove this allergy?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Yes, remove it!',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Mark this allergy for deletion by adding a data attribute
                        allergyItem.attr('data-marked-for-deletion', allergyId);
                        allergyItem.hide(); // Hide instead of removing to preserve the data
                        
                        // Show no allergies message if no visible allergies left
                        if ($('.allergy-item:visible').length === 0) {
                            $('#noAllergiesMessage').show();
                        }
                        
                        Swal.fire(
                            'Removed!',
                            'The allergy has been marked for removal.',
                            'success'
                        );
                    }
                });
            });

            // Handle removing temporary allergies
            $(document).on('click', '.remove-temp-allergy', function() {
                $(this).closest('.allergy-item').remove();
                
                // Show no allergies message if no allergies left
                if ($('.allergy-item').length === 0) {
                    $('#noAllergiesMessage').show();
                }
            });

            // Handle allergies form submission
            $('#allergiesForm').on('submit', function(e) {
                e.preventDefault();
                var form = $(this);
                var submitBtn = form.find('button[type="submit"]');

                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Saving...');

                // Use regular form serialization instead of FormData for better compatibility
                var formData = form.serialize();
                
                // Add additional data for allergies
                var allergyData = [];
                var customAllergyData = [];
                var removedAllergyIds = [];
                
                $('.current-allergies-container .allergy-item').not('[data-marked-for-deletion]').each(function(index) {
                    var allergyItem = $(this);
                    var allergyId = allergyItem.find('input[name="AllergyIds"]').val();
                    var activeIngredientId = allergyItem.data('active-ingredient-id');

                    // Check if it's a newly added custom allergy
                    var isNewCustomAllergy = allergyItem.find('input[name="newAllergies"][value^="CUSTOM_"]').length > 0;
                    var isNewDbAllergy = allergyItem.find('input[name="newAllergies"][value^="DB_"]').length > 0;
                    
                    if (isNewCustomAllergy) {
                        var newAllergyValue = allergyItem.find('input[name="newAllergies"]').val();
                        var parts = newAllergyValue.split('|');
                        var customName = parts[0].replace("CUSTOM_", "");
                        var severity = parts[1];
                        var description = parts[2];

                        customAllergyData.push({
                            name: customName,
                            severity: severity,
                            description: description
                        });
                    } else if (isNewDbAllergy) {
                        var newAllergyValue = allergyItem.find('input[name="newAllergies"]').val();
                        var parts = newAllergyValue.split('|');
                        var dbIngredientId = parts[0].replace("DB_", "");
                        var severity = parts[1];
                        var description = parts[2];

                        allergyData.push({
                            ingredientId: parseInt(dbIngredientId),
                            severity: severity,
                            description: description
                        });
                    } else if (allergyId && allergyId !== '0') {
                        // Existing allergy from database
                        allergyData.push({
                            allergyId: parseInt(allergyId),
                            ingredientId: parseInt(activeIngredientId),
                            severity: allergyItem.find('select[name="AllergySeverities"]').val(),
                            description: allergyItem.find('input[name="AllergyDescriptions"]').val()
                        });
                    }
                });

                // Add IDs of allergies marked for deletion
                $('.current-allergies-container .allergy-item[data-marked-for-deletion]').each(function(index) {
                    var allergyId = $(this).data('marked-for-deletion');
                    if (allergyId) {
                        removedAllergyIds.push(parseInt(allergyId));
                    }
                });

                // Add the allergy data to the form data
                formData += '&AllergyData=' + encodeURIComponent(JSON.stringify(allergyData));
                formData += '&CustomAllergyData=' + encodeURIComponent(JSON.stringify(customAllergyData));
                formData += '&RemovedAllergyIds=' + encodeURIComponent(JSON.stringify(removedAllergyIds));

                $.ajax({
                    url: '@Url.Action("UpdateAllergies", "Account")',
                    type: 'POST',
                    data: formData,
                    success: function(response) {
                        console.log('AJAX Response:', response);
                        if (response && response.success) {
                            showSuccessMessage('Allergies updated successfully!');
                            $('#allergiesModal').modal('hide');
                            
                            // Update the display on the main profile page
                            updateAllergiesDisplay(response.data);
                            
                            // Reload the page to ensure data consistency
                            setTimeout(function() {
                                location.reload();
                            }, 1500);
                        } else {
                            showErrorMessage(response.message || 'Failed to update allergies');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('AJAX Error:', xhr.responseText);
                        showErrorMessage('An error occurred while updating allergies');
                    },
                    complete: function() {
                        submitBtn.prop('disabled', false).html('<i class="fas fa-save me-2"></i>Save Allergies');
                    }
                });
            });

            // Function to load/reload the allergies modal content (for after save or initial open)
            function loadAllergiesModalContent() {
                // This can be an AJAX call to get the updated profile data specifically for the modal
                // Or, if simpler, just reload the page for now (less ideal UX but ensures data consistency)
                location.reload(); 
            }

            // Function to update allergies display (global scope)
            window.updateAllergiesDisplay = function(allergies) {
                console.log('updateAllergiesDisplay called with:', allergies);
                var container = $('#allergiesDisplay'); // This is the display on the main profile page
                console.log('Container found:', container.length > 0);
                
                if (container.length === 0) {
                    console.error('Allergies container not found!');
                    return;
                }
                
                if (allergies && allergies.length > 0) {
                    console.log('Processing', allergies.length, 'allergies');
                    var html = '';
                    allergies.forEach(function(allergy) {
                        console.log('Processing allergy:', allergy);
                        html += `
                            <div class="allergy-badge">
                                <span class="badge ingredient-badge">${allergy.activeIngredientName || 'Unknown'}</span>
                                <span class="badge severity-badge">${allergy.severity || 'Unknown'}</span>
                                ${allergy.description ? `<small class="text-muted d-block mt-1">${allergy.description}</small>` : ''}
                            </div>
                        `;
                    });
                    console.log('Generated HTML for main display:', html);
                    container.html(html);
                } else {
                    console.log('No allergies found, showing default message on main display');
                    container.html('<span class="text-muted">No allergies recorded</span>');
                }
            }

            // Initial setup for allergy status radio buttons
            // This function is no longer needed as the content is always visible

            // Call on modal show to ensure correct state
            $('#allergiesModal').on('show.bs.modal', function() {
                setSeverityDropdowns(); // Call to set severity dropdowns
            });
            
            // Add loading states to buttons
            $('.btn-3d').on('click', function() {
                // This logic needs to be more specific to avoid interfering with form submissions
                // The submit buttons already have loading states handled in their respective AJAX calls.
            });
        });
        
        // Function to set the selected severity in dropdowns for existing allergies
        function setSeverityDropdowns() {
            $('.allergy-item').each(function() {
                var allergyItem = $(this);
                var severity = allergyItem.data('severity'); // Assuming you add data-severity attribute to allergy-item div
                if (severity) {
                    allergyItem.find('select[name="AllergySeverities"]').val(severity);
                }
            });
        }
    </script>
    
