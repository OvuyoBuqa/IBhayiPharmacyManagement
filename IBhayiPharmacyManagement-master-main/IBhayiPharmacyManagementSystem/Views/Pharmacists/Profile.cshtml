
@{ 
    ViewData["Title"] = "Manage Profile";
    Layout = "_LayoutPharmacist";
}

@model IBhayiPharmacyManagementSystem.Models.Pharmacist

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header text-white py-4" style="background: linear-gradient(135deg, #0a1f14 0%, #1b4332 50%, #28a745 100%); position: relative; overflow: hidden;">
                    <!-- Decorative elements -->
                    <div style="position: absolute; top: -20px; right: -20px; width: 100px; height: 100px; background: rgba(255, 255, 255, 0.1); border-radius: 50%;"></div>
                    <div style="position: absolute; bottom: -30px; left: -30px; width: 80px; height: 80px; background: rgba(40, 167, 69, 0.2); border-radius: 50%;"></div>
                    <div style="position: absolute; top: 50%; right: 10%; width: 60px; height: 60px; background: rgba(13, 110, 253, 0.15); border-radius: 50%;"></div>
                    
                    <div class="text-center position-relative">
                        <div class="d-flex justify-content-center align-items-center mb-3">
                            <div class="position-relative">
                                <i class="fas fa-user-circle fa-3x me-3" style="color: #fff; text-shadow: 0 2px 4px rgba(0,0,0,0.3);"></i>
                                <div style="position: absolute; top: -5px; right: 5px; width: 20px; height: 20px; background: #28a745; border-radius: 50%; border: 3px solid #fff;"></div>
                            </div>
                        </div>
                        <h1 class="mb-2" style="font-size: 2.5rem; font-weight: 700; text-shadow: 0 2px 4px rgba(0,0,0,0.3);">
                            @ViewData["Title"]
                        </h1>
                        <p class="mb-0 opacity-90" style="font-size: 1.1rem; font-weight: 300;">
                            Manage your personal information and security settings
                        </p>
                        
                        <!-- Status indicators -->
                        <div class="mt-3 d-flex justify-content-center gap-3">
                            <span class="badge bg-primary px-3 py-2" style="font-size: 0.9rem;">
                                <i class="fas fa-circle me-1"></i>Active
                            </span>
                            <span class="badge bg-secondary px-3 py-2" style="font-size: 0.9rem;">
                                <i class="fas fa-shield-alt me-1"></i>Secure
                            </span>
                            <span class="badge bg-info px-3 py-2" style="font-size: 0.9rem;">
                                <i class="fas fa-user-md me-1"></i>Pharmacist
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Profile Overview Card -->
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(145deg, #ffffff 0%, #f8f9fa 100%);">
                <div class="card-body text-center p-4">
                    <div class="position-relative d-inline-block mb-3">
                        <div style="position: relative; display: inline-block;">
                            <img src="/images/pharmacist_avatar.png" alt="Pharmacist Avatar" class="img-fluid rounded-circle" style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #0a1f14; box-shadow: 0 4px 15px rgba(0,0,0,0.1);" />
                            <!-- Status indicator with pulse animation -->
                            <div class="position-absolute bottom-0 end-0" style="animation: pulse 2s infinite;">
                                <span class="badge bg-primary rounded-pill p-2" style="border: 3px solid #fff; box-shadow: 0 2px 8px rgba(13, 110, 253, 0.3);">
                                    <i class="fas fa-user"></i>
                                </span>
                            </div>
                        </div>
                    </div>
                    <h4 class="mb-1" style="color: #0a1f14; font-weight: 600;">@Model.User.FullName</h4>
                    <p class="text-muted mb-2" style="font-size: 0.9rem;">Licensed Pharmacist</p>
                    
                    <!-- Enhanced status badges -->
                    <div class="d-flex justify-content-center align-items-center mb-3 flex-wrap gap-2">
                        <span class="badge bg-primary px-3 py-2" style="font-size: 0.85rem; box-shadow: 0 2px 4px rgba(13, 110, 253, 0.2);">
                            <i class="fas fa-id-card me-1"></i>ID: @Model.PharmacistId
                        </span>
                        <span class="badge bg-primary px-3 py-2" style="font-size: 0.85rem; box-shadow: 0 2px 4px rgba(13, 110, 253, 0.2);">
                            <i class="fas fa-circle me-1"></i>Active
                        </span>
                    </div>
                    
                    <hr class="my-3" style="border-color: #e9ecef;">
                    
                    <!-- Enhanced info section with icons and colors -->
                    <div class="text-start">
                        <div class="d-flex justify-content-between align-items-center mb-3 p-2" style="background: rgba(13, 110, 253, 0.05); border-radius: 8px; border-left: 3px solid #0d6efd;">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-calendar-plus text-primary me-2"></i>
                                <small class="text-muted fw-bold">Registration</small>
                            </div>
                            <small class="fw-bold text-primary">@DateTime.Now.ToString("MMM yyyy")</small>
                        </div>
                        <div class="d-flex justify-content-between align-items-center p-2" style="background: rgba(40, 167, 69, 0.05); border-radius: 8px; border-left: 3px solid #28a745;">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-clock text-success me-2"></i>
                                <small class="text-muted fw-bold">Last Updated</small>
                            </div>
                            <small class="fw-bold text-success">@DateTime.Now.ToString("MMM dd, yyyy")</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-8">
            <!-- Personal Information Card -->
            <div class="card border-0 shadow-sm mb-4" style="border-left: 4px solid #0d6efd;">
                <div class="card-header py-3" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); border-bottom: 1px solid #dee2e6;">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 text-dark">
                            <i class="fas fa-user me-2 text-primary"></i>Personal Information
                        </h5>
                        <button type="button" class="btn btn-outline-primary btn-sm" id="edit-personal-btn" style="border-radius: 20px; padding: 8px 16px;">
                            <i class="fas fa-edit me-1"></i>Edit Details
                        </button>
                    </div>
                </div>
        <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label fw-bold text-muted small">EMAIL ADDRESS</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0">
                                        <i class="fas fa-envelope text-muted"></i>
                                    </span>
                                    <input type="text" class="form-control border-0 bg-light" value="@Model.User.Email" readonly />
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label fw-bold text-muted small">FULL NAME</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0">
                                        <i class="fas fa-user text-muted"></i>
                                    </span>
                                    <span class="form-control border-0 bg-light" id="fullname-display">@Model.User.FullName</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label fw-bold text-muted small">PHONE NUMBER</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0">
                                        <i class="fas fa-phone text-muted"></i>
                                    </span>
                                    <span class="form-control border-0 bg-light" id="phone-display">@(Model.User.PhoneNumber ?? "Not provided")</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label fw-bold text-muted small">REGISTRATION NUMBER</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0">
                                        <i class="fas fa-id-card text-muted"></i>
                                    </span>
                                    <input type="text" class="form-control border-0 bg-light" value="@Model.RegistrationNumber" readonly />
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Action Buttons (Hidden by default) -->
                    <div class="mt-4 d-none" id="edit-actions">
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-success" id="save-personal-btn">
                                <i class="fas fa-save me-1"></i>Save Changes
                            </button>
                            <button type="button" class="btn btn-secondary" id="cancel-personal-btn">
                                <i class="fas fa-times me-1"></i>Cancel
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Security Settings Card -->
            <div class="card border-0 shadow-sm" style="border-left: 4px solid #6c757d;">
                <div class="card-header py-3" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); border-bottom: 1px solid #dee2e6;">
                    <h5 class="mb-0 text-dark">
                        <i class="fas fa-shield-alt me-2 text-secondary"></i>Security Settings
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    
                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                        
                        <div class="row g-3">
                            <div class="col-12">
                                <label for="OldPassword" class="form-label fw-bold">Current Password</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-lock"></i>
                                    </span>
                                    <input type="password" id="OldPassword" name="OldPassword" class="form-control" autocomplete="current-password" placeholder="Enter your current password" />
                                    <button type="button" class="btn btn-outline-secondary toggle-password" data-target="OldPassword">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label for="NewPassword" class="form-label fw-bold">New Password</label>
                            <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-key"></i>
                                    </span>
                                    <input type="password" id="NewPassword" name="NewPassword" class="form-control" autocomplete="new-password" placeholder="Enter new password" />
                                    <button type="button" class="btn btn-outline-secondary toggle-password" data-target="NewPassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label for="ConfirmNewPassword" class="form-label fw-bold">Confirm New Password</label>
                            <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-key"></i>
                                    </span>
                                    <input type="password" id="ConfirmNewPassword" name="ConfirmNewPassword" class="form-control" autocomplete="new-password" placeholder="Confirm new password" />
                                    <button type="button" class="btn btn-outline-secondary toggle-password" data-target="ConfirmNewPassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-4">
                            <button type="submit" class="btn btn-secondary btn-lg px-4">
                                <i class="fas fa-shield-alt me-2"></i>Update Password
                                </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hidden form for personal details update -->
<form id="personal-details-form" style="display: none;">
    @Html.AntiForgeryToken()
    <input type="text" id="fullname-input" name="FullName" />
    <input type="text" id="phone-input" name="PhoneNumber" />
</form>

@section Styles {
    <style>
        @@keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
        
        .card-header {
            position: relative;
        }
        
        .status-badge {
            transition: all 0.3s ease;
        }
        
        .status-badge:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Clear any pre-filled password values
            var oldPasswordField = document.getElementById('OldPassword');
            if (oldPasswordField) {
                oldPasswordField.value = '';
            }
            
            document.querySelectorAll('.toggle-password').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var targetId = btn.getAttribute('data-target');
                    var input = document.getElementById(targetId);
                    if (!input) return;
                    var icon = btn.querySelector('i');
                    if (input.type === 'password') {
                        input.type = 'text';
                        if (icon) { icon.classList.remove('fa-eye'); icon.classList.add('fa-eye-slash'); }
                    } else {
                        input.type = 'password';
                        if (icon) { icon.classList.remove('fa-eye-slash'); icon.classList.add('fa-eye'); }
                    }
                });
            });

            // Inline editing functionality
            let isEditing = false;
            let originalValues = {};

            const editBtn = document.getElementById('edit-personal-btn');
            const saveBtn = document.getElementById('save-personal-btn');
            const cancelBtn = document.getElementById('cancel-personal-btn');
            const fullnameDisplay = document.getElementById('fullname-display');
            const phoneDisplay = document.getElementById('phone-display');

            editBtn.addEventListener('click', function() {
                if (isEditing) return;
                
                isEditing = true;
                originalValues.fullname = fullnameDisplay.textContent;
                originalValues.phone = phoneDisplay.textContent === 'Not provided' ? '' : phoneDisplay.textContent;

                // Replace display with input fields
                fullnameDisplay.innerHTML = `<input type="text" id="fullname-edit" class="form-control" value="${originalValues.fullname}" placeholder="Enter your full name">`;
                phoneDisplay.innerHTML = `<input type="text" id="phone-edit" class="form-control" value="${originalValues.phone}" placeholder="e.g. 0712345678" maxlength="10" pattern="[0-9]{10}">`;

                // Add real-time validation for phone number input
                const phoneInput = document.getElementById('phone-edit');
                phoneInput.addEventListener('input', function(e) {
                    // Remove any non-numeric characters
                    let value = e.target.value.replace(/\D/g, '');
                    // Limit to 10 digits
                    if (value.length > 10) {
                        value = value.substring(0, 10);
                    }
                    e.target.value = value;
                });

                // Prevent pasting non-numeric content
                phoneInput.addEventListener('paste', function(e) {
                    e.preventDefault();
                    let paste = (e.clipboardData || window.clipboardData).getData('text');
                    let numericOnly = paste.replace(/\D/g, '').substring(0, 10);
                    e.target.value = numericOnly;
                });

                // Show/hide buttons
                editBtn.classList.add('d-none');
                document.getElementById('edit-actions').classList.remove('d-none');
            });

            cancelBtn.addEventListener('click', function() {
                if (!isEditing) return;
                
                // Restore original values
                fullnameDisplay.textContent = originalValues.fullname;
                phoneDisplay.textContent = originalValues.phone === '' ? 'Not provided' : originalValues.phone;

                // Show/hide buttons
                editBtn.classList.remove('d-none');
                document.getElementById('edit-actions').classList.add('d-none');
                
                isEditing = false;
            });

            saveBtn.addEventListener('click', function() {
                if (!isEditing) return;

                const fullnameValue = document.getElementById('fullname-edit').value.trim();
                const phoneValue = document.getElementById('phone-edit').value.trim();

                if (!fullnameValue) {
                    Swal.fire({
                        title: 'Validation Error',
                        text: 'Full name is required.',
                        icon: 'warning',
                        confirmButtonText: 'OK',
                        confirmButtonColor: '#6c757d'
                    });
                    return;
                }

                // Validate phone number (exactly 10 digits)
                if (phoneValue && !/^\d{10}$/.test(phoneValue)) {
                    Swal.fire({
                        title: 'Validation Error',
                        text: 'Phone number must be exactly 10 digits.',
                        icon: 'warning',
                        confirmButtonText: 'OK',
                        confirmButtonColor: '#6c757d'
                    });
                    return;
                }

                // Show loading state
                saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Saving...';
                saveBtn.disabled = true;

                // Prepare form data
                const formData = new FormData();
                formData.append('FullName', fullnameValue);
                formData.append('PhoneNumber', phoneValue);
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                // Send AJAX request
                fetch('@Url.Action("UpdatePersonalDetails", "Pharmacists")', {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: formData
                })
                .then(response => {
                    if (response.ok) {
                        return response.json();
                    }
                    throw new Error('Network response was not ok');
                })
                .then(data => {
                    if (data.success) {
                        // Update display values
                        fullnameDisplay.textContent = fullnameValue;
                        phoneDisplay.textContent = phoneValue === '' ? 'Not provided' : phoneValue;
                        
                        // Update the header name as well
                        const headerName = document.querySelector('h4');
                        if (headerName) {
                            headerName.textContent = fullnameValue;
                        }

                        // Show success message
                        Swal.fire({
                            title: 'Success!',
                            text: data.message || 'Personal details updated successfully!',
                            icon: 'success',
                            confirmButtonText: 'OK',
                            confirmButtonColor: '#28a745',
                            timer: 3000,
                            timerProgressBar: true
                        });

                        // Show/hide buttons
                        editBtn.classList.remove('d-none');
                        document.getElementById('edit-actions').classList.add('d-none');
                        
                        isEditing = false;
                    } else {
                        // Show error message
                        Swal.fire({
                            title: 'Error!',
                            text: data.message || 'An error occurred while updating your details. Please try again.',
                            icon: 'error',
                            confirmButtonText: 'OK',
                            confirmButtonColor: '#6c757d'
                        });
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    Swal.fire({
                        title: 'Error!',
                        text: 'An error occurred while updating your details. Please try again.',
                        icon: 'error',
                        confirmButtonText: 'OK',
                        confirmButtonColor: '#6c757d'
                    });
                })
                .finally(() => {
                    // Reset button state
                    saveBtn.innerHTML = '<i class="fas fa-save me-1"></i>Save Changes';
                    saveBtn.disabled = false;
                });
            });
        });
    </script>
}
