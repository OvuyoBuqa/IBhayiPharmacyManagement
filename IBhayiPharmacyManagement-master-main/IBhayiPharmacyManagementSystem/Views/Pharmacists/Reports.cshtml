@{
    ViewData["Title"] = "Pharmacist Reports";
    Layout = "~/Views/Shared/_LayoutPharmacist.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-chart-bar mr-2"></i>Pharmacist Reports
                    </h3>
                </div>
                <div class="card-body">
                    @if (TempData["InfoMessage"] != null)
                    {
                        <div class="alert alert-info alert-dismissible fade show" role="alert">
                            <i class="fas fa-info-circle mr-2"></i>@TempData["InfoMessage"]
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    }

                    <div class="row">
                        <!-- Prescriptions Report -->
                        <div class="col-lg-8">
                            <div class="card border-primary">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="card-title mb-0">
                                        <i class="fas fa-pills mr-2"></i>Prescriptions Dispensed Report
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <p class="card-text">Generate a PDF report for a specific date range of all medication dispensed by you for that date range. The report can be grouped by patient, medication, or schedule.</p>
                                    
                                    <form asp-action="GenerateReport" method="get" class="mt-3">
                                        <div class="form-group">
                                            <label for="startDate">Start Date:</label>
                                            <input type="date" id="startDate" name="startDate" class="form-control" 
                                                   value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")" required>
                                        </div>
                                        
                                        <div class="form-group">
                                            <label for="endDate">End Date:</label>
                                            <input type="date" id="endDate" name="endDate" class="form-control" 
                                                   value="@DateTime.Today.ToString("yyyy-MM-dd")" required>
                                        </div>
                                        
                                        <div class="form-group">
                                            <label for="groupBy">Group By:</label>
                                            <select id="groupBy" name="groupBy" class="form-control">
                                                <option value="patient">Patient</option>
                                                <option value="medication">Medication</option>
                                                <option value="schedule">Schedule</option>
                                            </select>
                                        </div>
                                        
                                        <button type="submit" class="btn btn-primary btn-block">
                                            <i class="fas fa-download mr-2"></i>Generate Report
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-lg-4">
                            <div class="card border-info">
                                <div class="card-header bg-info text-white">
                                    <h5 class="card-title mb-0">
                                        <i class="fas fa-info-circle mr-2"></i>Report Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <h6><i class="fas fa-pills mr-2"></i>Prescriptions Dispensed Report</h6>
                                    <ul class="list-unstyled">
                                        <li><i class="fas fa-check text-success mr-2"></i>Shows all prescriptions you dispensed</li>
                                        <li><i class="fas fa-check text-success mr-2"></i>Grouped by patient, medication, or schedule</li>
                                        <li><i class="fas fa-check text-success mr-2"></i>Includes quantities and instructions</li>
                                        <li><i class="fas fa-check text-success mr-2"></i>Shows sub-totals and grand totals</li>
                                        <li><i class="fas fa-check text-success mr-2"></i>Professional PDF format</li>
                                    </ul>
                                    <hr>
                                    <div class="text-center">
                                        <p class="text-muted mb-0">
                                            <i class="fas fa-file-pdf mr-2"></i>
                                            All reports are generated as professional PDF documents with proper formatting, headers, and page numbers.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Set default dates
            var defaultStartDate = '@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")';
            var defaultEndDate = '@DateTime.Today.ToString("yyyy-MM-dd")';
            
            $('#startDate').val(defaultStartDate);
            $('#endDate').val(defaultEndDate);
            
            // Auto-hide alerts after 5 seconds
            setTimeout(function () {
                $('.alert').fadeOut('slow');
            }, 5000);
        });
    </script>
}

