    <script src="https://code.highcharts.com/modules/series-label.js"></script>
    <script src="https://code.highcharts.com/modules/exporting.js"></script>
    <script src="https://code.highcharts.com/modules/export-data.js"></script>
    <script src="https://code.highcharts.com/modules/accessibility.js"></script>
    <script src="https://code.highcharts.com/highcharts-3d.js"></script>
    <script>
        $(function () {
            $("#example1").DataTable({
                "responsive": true, "lengthChange": false, "autoWidth": false,
            }).buttons().container().appendTo('#example1_wrapper .col-md-6:eq(0)');
            $('#example2').DataTable({
                "paging": true,
                "lengthChange": false,
                "searching": false,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
            });
        });
    </script>

    <!-- Logout Loading Overlay -->
    <div class="logout-overlay" id="logoutOverlay">
        <div class="logout-overlay-content">
            <div class="logout-overlay-spinner">
                <i class="fas fa-spinner fa-spin"></i>
            </div>
            <div class="logout-overlay-text">Signing out...</div>
        </div>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize sidebar treeview
        $('[data-widget="treeview"]').Treeview('init');
        
        // Ensure sidebar is visible and functional
        $('.sidebar').show();
        $('.main-sidebar').show();
        
        // Debug: Log sidebar elements
        console.log('Sidebar elements found:', $('.sidebar .nav-item').length);
        console.log('Reports section found:', $('.sidebar .nav-item:contains("Reports")').length);
        
        // Ensure Reports section is visible
        $('.sidebar .nav-item:contains("Reports")').show();
        $('.sidebar .nav-item:contains("Reports")').next('.nav-treeview').show();
        
        // Force show the Reports section specifically
        $('.sidebar .nav-item').each(function() {
            if ($(this).text().includes('Reports')) {
                $(this).show();
                $(this).find('.nav-treeview').show();
            }
        });
        
        // Scroll to show all sidebar content
        $('.sidebar').scrollTop(0);
        
        // Additional check for Reports visibility
        setTimeout(function() {
            const reportsSection = $('.sidebar .nav-item').filter(function() {
                return $(this).text().trim().includes('Reports');
            });
            if (reportsSection.length > 0) {
                console.log('Reports section is visible:', reportsSection.is(':visible'));
                reportsSection.show();
            }
        }, 100);
        
        const logoutForms = document.querySelectorAll('.logout-form');
        
        logoutForms.forEach(function(form) {
            form.addEventListener('submit', function(e) {
                e.preventDefault(); // Prevent immediate form submission
                
                const button = form.querySelector('.logout-btn');
                const text = button.querySelector('.logout-text');
                const spinner = button.querySelector('.logout-spinner');
                const overlay = document.getElementById('logoutOverlay');
                
                // Show loading state
                button.disabled = true;
                button.classList.add('logout-loading');
                text.style.display = 'none';
                spinner.style.display = 'inline-block';
                overlay.classList.add('show');
                
                // Show loading for 2 seconds, then submit
                setTimeout(function() {
                    form.submit();
                }, 2000);
            });
        });
    });
    </script>

    @await Html.PartialAsync("_ValidationScriptsPartial")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>