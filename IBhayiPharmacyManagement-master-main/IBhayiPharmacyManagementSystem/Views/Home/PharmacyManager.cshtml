@using Microsoft.AspNetCore.Identity
@using IBhayiPharmacyManagementSystem.Models
@using IBhayiPharmacyManagementSystem.ViewModels
@model PharmacyManagerDashboardViewModel
@inject UserManager<Users> UserManager

@{
    ViewData["Title"] = "Pharmacy Manager Dashboard";
    Layout = "_LayoutPharmacyManger";

    // Get current user info
    var currentUser = await UserManager.GetUserAsync(User);
    var currentUserFullName = currentUser?.FullName ?? "Pharmacy Manager";

    // Safe model property access
    var selectedTimeframe = Model?.SelectedTimeframe ?? "This Week";
    var medications = Model?.Medications ?? new List<Medication>();
    var totalItems = Model?.TotalItems ?? 0;
    var totalItemsChange = Model?.TotalItemsChange ?? "0%";
    var lowStockItems = Model?.LowStockItems ?? 0;
    var lowStockChange = Model?.LowStockChange ?? "0%";
    var ordersCount = Model?.OrdersCount ?? 0;
    var ordersChange = Model?.OrdersChange ?? "0%";
    var inventoryValue = Model?.InventoryValue ?? 0;
    var inventoryValueChange = Model?.InventoryValueChange ?? "0%";
    var pendingOrders = Model?.PendingOrders ?? 0;
    var activePharmacists = Model?.ActivePharmacists ?? 0;
    var stockOverview = Model?.StockOverview ?? new List<StockOverviewItemViewModel>();
}

@section Styles {
    <style>
        
        .bg-brown {
            background-color: #3e2a1f !important;
        }

        .text-brown {
            color: #3e2a1f !important;
        }

        .btn-brown {
            background-color: #3e2a1f !important;
            border-color: #3e2a1f !important;
            color: white !important;
        }

        .btn-brown:hover {
            background-color: #5d4e37 !important;
            border-color: #5d4e37 !important;
        }

        .btn-outline-brown {
            color: #3e2a1f !important;
            border-color: #3e2a1f !important;
        }

        .btn-outline-brown:hover {
            background-color: #3e2a1f !important;
            color: white !important;
        }

        /* Modern 3D Card Effects - EXACT MATCH */
        .stat-card-3d {
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            transform-style: preserve-3d;
            perspective: 1000px;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .stat-card-3d:hover {
            transform: translateY(-10px) rotateX(5deg) rotateY(5deg);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
        }

        .stat-card-3d::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 100%);
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
        }

        .stat-card-3d:hover::before {
            opacity: 1;
        }

        /* Glassmorphism Effects - EXACT MATCH */
        .info-box {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 15px;
            overflow: hidden;
        }

        .info-box-icon {
            border-radius: 15px 0 0 15px;
        }

        /* Smooth Animations - EXACT MATCH */
        .info-box-number {
            font-size: 2.5rem;
            font-weight: 700;
            transition: all 0.3s ease;
        }

        .stat-card-3d:hover .info-box-number {
            transform: scale(1.1);
            color: #3e2a1f;
        }

        /* Progress Bar Enhancement - EXACT MATCH */
        .progress {
            height: 8px;
            border-radius: 10px;
            background: rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .progress-bar {
            background: linear-gradient(90deg, #3e2a1f 0%, #5d4e37 100%);
            border-radius: 10px;
            transition: width 1s ease;
        }

        /* Modern Card Styling - EXACT MATCH */
        .modern-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            transition: all 0.3s ease;
            overflow: hidden;
        }

        .modern-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
        }

        .modern-card .card-header {
            background: linear-gradient(135deg, #3e2a1f 0%, #5d4e37 100%);
            color: white;
            border-bottom: none;
            border-radius: 15px 15px 0 0;
        }

        .modern-card .card-header .card-title {
            color: white;
            font-weight: 600;
        }

        /* Button Enhancements - EXACT MATCH */
        .btn {
            border-radius: 10px;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        /* Table Enhancements - EXACT MATCH */
        .table {
            border-radius: 10px;
            overflow: hidden;
        }

        .table thead th {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border: none;
            font-weight: 600;
            color: #495057;
        }

        /* Responsive Enhancements - EXACT MATCH */
        @@media (max-width: 768px) {
            .stat-card-3d:hover {
                transform: translateY(-5px);
            }

            .modern-card:hover {
                transform: translateY(-3px);
            }
        }

        /* Alert Styling - EXACT MATCH with Customer theme */
        .alert {
            border-radius: 12px;
            border: none;
            box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        }

        .alert .icon {
            margin-right: .5rem;
        }

        .alert-success {
            background: linear-gradient(135deg, #e6f4ea 0%, #d4efdf 100%);
            color: #0a1f14;
        }

        .alert-danger {
            background: linear-gradient(135deg, #fdecea 0%, #f8d7da 100%);
            color: #58151c;
        }

        .alert-warning {
            background: linear-gradient(135deg, #fff4e5 0%, #ffe8cc 100%);
            color: #663c00;
        }

        .alert-info {
            background: linear-gradient(135deg, #e7f3ff 0%, #d0e7ff 100%);
            color: #0a2a66;
        }

        .alert-dismissible .close {
            color: inherit;
            text-shadow: none;
            opacity: .6;
        }

        .alert-dismissible .close:hover {
            opacity: 1;
        }
    </style>
}

<!-- Content Header (Page header) -->
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Pharmacy Manager Dashboard</h1>
            </div>
            <div class="col-sm-6 d-flex align-items-center justify-content-end">
                <div class="d-flex align-items-center ml-auto gap-3">
                    <button id="btnScanBarcode" class="btn btn-outline-success btn-sm">
                        <i class="fas fa-barcode mr-1"></i>Scan Barcode
                    </button>

                    <div class="dropdown">
                        <button class="btn btn-outline-secondary dropdown-toggle btn-sm" id="timeframeDropdown" data-toggle="dropdown" aria-expanded="false" data-selected-timeframe="@selectedTimeframe">
                            <i class="fas fa-calendar-alt mr-1"></i> <span>@selectedTimeframe</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-right" aria-labelledby="timeframeDropdown">
                            <h6 class="dropdown-header">Select Timeframe</h6>
                            <a class="dropdown-item timeframe-item @(selectedTimeframe == "Today" ? "active" : "")" href="#" data-timeframe="Today">Today <i class="fas fa-check-lg float-right @(selectedTimeframe == "Today" ? "" : "d-none")"></i></a>
                            <a class="dropdown-item timeframe-item @(selectedTimeframe == "This Week" ? "active" : "")" href="#" data-timeframe="This Week">This Week <i class="fas fa-check-lg float-right @(selectedTimeframe == "This Week" ? "" : "d-none")"></i></a>
                            <a class="dropdown-item timeframe-item @(selectedTimeframe == "Last Week" ? "active" : "")" href="#" data-timeframe="Last Week">Last Week <i class="fas fa-check-lg float-right @(selectedTimeframe == "Last Week" ? "" : "d-none")"></i></a>
                            <a class="dropdown-item timeframe-item @(selectedTimeframe == "This Month" ? "active" : "")" href="#" data-timeframe="This Month">This Month <i class="fas fa-check-lg float-right @(selectedTimeframe == "This Month" ? "" : "d-none")"></i></a>
                            <a class="dropdown-item timeframe-item @(selectedTimeframe == "Last 3 Months" ? "active" : "")" href="#" data-timeframe="Last 3 Months">Last 3 Months <i class="fas fa-check-lg float-right @(selectedTimeframe == "Last 3 Months" ? "" : "d-none")"></i></a>
                            <a class="dropdown-item timeframe-item @(selectedTimeframe == "This Year" ? "active" : "")" href="#" data-timeframe="This Year">This Year <i class="fas fa-check-lg float-right @(selectedTimeframe == "This Year" ? "" : "d-none")"></i></a>
                        </div>
                    </div>


                    <!-- User Profile Dropdown -->
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary dropdown-toggle btn-sm d-flex align-items-center" data-toggle="dropdown">
                            <i class="fas fa-user-circle mr-1"></i>
                            @currentUserFullName
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <h6 class="dropdown-header">Signed in as @User.Identity?.Name</h6>
                            <a class="dropdown-item" href="@Url.Action("Profile", "PharmacyManagerProfile")"><i class="fas fa-user mr-2"></i>My Profile</a>
                            <div class="dropdown-divider"></div>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item"><i class="fas fa-sign-out-alt mr-2"></i>Logout</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Main content -->
<section class="content">
    <div class="container-fluid">
        <!-- Info boxes with 3D effects and real counts -->
        <div class="row">
            <div class="col-12 col-sm-6 col-md-3">
                <div class="info-box stat-card-3d">
                    <span class="info-box-icon bg-brown elevation-1"><i class="fas fa-capsules"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Total Medications</span>
                        <span class="info-box-number" id="totalItemsCount">@totalItems</span>
                        <div class="progress">
                            <div class="progress-bar" style="width: 0%"></div>
                        </div>
                        <span class="progress-description">
                            <span class="total-medications-change @(totalItemsChange.StartsWith("+") ? "text-success" : totalItemsChange.StartsWith("-") ? "text-danger" : "text-muted") fw-bold">@totalItemsChange</span>
                            since last period
                        </span>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-md-3">
                <div class="info-box stat-card-3d">
                    <span class="info-box-icon bg-dark elevation-1"><i class="fas fa-exclamation-triangle"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Low Stock Items</span>
                        <span class="info-box-number" id="lowStockItemsCount">@lowStockItems</span>
                        <div class="progress">
                            <div class="progress-bar" style="width: 0%"></div>
                        </div>
                        <span class="progress-description">
                            <span class="low-stock-change @(lowStockChange.StartsWith("+") ? "text-danger" : lowStockChange.StartsWith("-") ? "text-success" : "text-muted") fw-bold">@lowStockChange</span>
                            since last period
                        </span>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-md-3">
                <div class="info-box stat-card-3d">
                    <span class="info-box-icon bg-brown elevation-1"><i class="fas fa-clipboard-list"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Pending Orders</span>
                        <span class="info-box-number" id="pendingOrdersCount">@pendingOrders</span>
                        <div class="progress">
                            <div class="progress-bar" style="width: 0%"></div>
                        </div>
                        <span class="progress-description">
                            <span class="orders-change @(ordersChange.StartsWith("+") ? "text-success" : ordersChange.StartsWith("-") ? "text-danger" : "text-muted") fw-bold">@ordersChange</span>
                            since last period
                        </span>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-md-3">
                <div class="info-box stat-card-3d">
                    <span class="info-box-icon bg-dark elevation-1"><i class="fas fa-dollar-sign"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Inventory Value</span>
                        <span class="info-box-number" id="inventoryValueCount">@inventoryValue.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("en-ZA"))</span>
                        <div class="progress">
                            <div class="progress-bar" style="width: 0%"></div>
                        </div>
                        <span class="progress-description">
                            <span class="inventory-value-change @(inventoryValueChange.StartsWith("+") ? "text-success" : inventoryValueChange.StartsWith("-") ? "text-danger" : "text-muted") fw-bold">@inventoryValueChange</span>
                            since last period
                        </span>
                    </div>
                </div>
            </div>
        </div>
        <!-- Quick Access / Management Links -->
        <div class="row">
            <!-- Left col -->
            <div class="col-md-8">
                <!-- TABLE: LATEST STOCK ALERTS -->
                <div class="card modern-card">
                    <div class="card-header border-transparent">
                        <h3 class="card-title">Stock Overview</h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                                <i class="fas fa-minus"></i>
                            </button>
                            <button type="button" class="btn btn-tool" data-card-widget="maximize">
                                <i class="fas fa-expand"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table m-0">
                                <thead>
                                    <tr>
                                        <th>Dosage Form</th>
                                        <th class="text-end">Item Count</th>
                                    </tr>
                                </thead>
                                <tbody id="stockOverviewTableBody">
                                    @if (stockOverview.Any())
                                    {
                                        @foreach (var item in stockOverview)
                                        {
                                            <tr>
                                                <td>@item.DosageForm</td>
                                                <td class="text-end">@item.ItemCount items</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="2" class="text-muted text-center">No stock overview data</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer clearfix">
                        <a href="@Url.Action("LowStock", "StockManagements")" class="btn btn-sm btn-brown float-left">View Low Stock Items</a>
                        <a href="@Url.Action("MedicationHistory", "Medications")" class="btn btn-sm btn-dark float-right">View All Medications</a>
                    </div>
                </div>

                <!-- Orders Trend Chart -->
                <div class="card modern-card">
                    <div class="card-header border-transparent">
                        <h3 class="card-title">Orders Trend</h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                                <i class="fas fa-minus"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <canvas id="ordersChart" style="height: 250px;"></canvas>
                    </div>
                </div>
            </div>

            <!-- Right col -->
            <div class="col-md-4">
                <!-- Quick Actions -->
                <div class="card modern-card">
                    <div class="card-header">
                        <h3 class="card-title">Quick Actions</h3>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a href="@Url.Action("AddMedication", "Medications")" class="btn btn-outline-brown btn-block">
                                <i class="fas fa-plus-circle mr-2"></i>Add New Medication
                            </a>
                            <a href="@Url.Action("Create", "StockOrders")" class="btn btn-outline-brown btn-block">
                                <i class="fas fa-cart-plus mr-2"></i>Create New Order
                            </a>
                            <a href="@Url.Action("StockTake", "StockManagements")" class="btn btn-outline-brown btn-block">
                                <i class="fas fa-clipboard-data mr-2"></i>Conduct Stock Take
                            </a>
                            <a href="@Url.Action("Index", "Pharmacists")" class="btn btn-outline-brown btn-block">
                                <i class="fas fa-users-cog mr-2"></i>Manage Pharmacists
                            </a>
                            <a href="@Url.Action("SupplierList", "Suppliers")" class="btn btn-outline-brown btn-block">
                                <i class="fas fa-truck mr-2"></i>Manage Suppliers
                            </a>
                            <a href="@Url.Action("GenerateStockReport", "StockManagements")" class="btn btn-outline-brown btn-block">
                                <i class="fas fa-file-alt mr-2"></i>Stock Reports
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Recent Medications -->
                <div class="card modern-card">
                    <div class="card-header">
                        <h3 class="card-title">Recent Medications</h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                                <i class="fas fa-minus"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <ul class="products-list product-list-in-card pl-2 pr-2" id="medicationsList">
                            @if (medications != null && medications.Any())
                            {
                                @foreach (var medication in medications.Take(5))
                                {
                                    <li class="item">
                                        <div class="product-info">
                                            <a href="javascript:void(0)" class="product-title">@medication.Name</a>
                                            <span class="product-description">
                                                @medication.Description
                                            </span>
                                        </div>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="item">
                                    <div class="product-info">
                                        <a href="javascript:void(0)" class="product-title">No medications available</a>
                                        <span class="product-description">
                                            Start by adding medications to your inventory
                                        </span>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                    <div class="card-footer text-center">
                        <a href="@Url.Action("MedicationHistory", "Medications")" class="uppercase">View All Medications</a>
                    </div>
                </div>

                <!-- Recent Activity -->
                <div class="card modern-card">
                    <div class="card-header">
                        <h3 class="card-title">Recent Activity</h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                                <i class="fas fa-minus"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <ul class="products-list product-list-in-card pl-2 pr-2" id="recentActivityList">
                            @if (Model.RecentActivities != null && Model.RecentActivities.Any())
                            {
                                @foreach (var activity in Model.RecentActivities.Take(5))
                                {
                                    <li class="item">
                                        <div class="product-info">
                                            <a href="@activity.Link" class="product-title">
                                                @activity.Title
                                            </a>
                                            <span class="product-description">
                                                @activity.Description - @activity.Timestamp.ToString("g")
                                            </span>
                                        </div>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="item">
                                    <div class="product-info">
                                        <a href="javascript:void(0)" class="product-title">No recent activity</a>
                                        <span class="product-description">No recent actions to display.</span>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                    <div class="card-footer text-center">
                        <a href="@Url.Action("StockMovementHistory", "StockManagements")" class="uppercase">View All Activity</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Barcode Scan Modal -->
<div class="modal fade" id="barcodeScanModal" tabindex="-1" aria-labelledby="barcodeScanModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="barcodeScanModalLabel">Scan Barcode</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="barcodeInput" class="form-label">Enter Barcode</label>
                    <input type="text" class="form-control" id="barcodeInput" placeholder="Scan or enter barcode">
                </div>
                <div id="scanResult" class="mt-3"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="submitBarcode">Search</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Sparkline -->
    <script src="~/AdminLTE/plugins/sparklines/sparkline.js"></script>
    <!-- AdminLTE dashboard demo (This is only for demo purposes) -->
    <script src="~/AdminLTE/dist/js/pages/dashboard.js"></script>
    <script>
        $(document).ready(function () {
            // Load dashboard data initially and then update via dropdown
            loadDashboardData($('#timeframeDropdown').attr('data-selected-timeframe'));

            // Initialize orders chart
            initializeOrdersChart();

            function loadDashboardData(timeframe) {
                $.ajax({
                    url: '@Url.Action("Dashboard", "PharmacyManager")',
                    type: 'GET',
                    data: { timeframe: timeframe },
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }, // Indicate AJAX request
                    success: function (data) {
                        // Update Timeframe display
                        $('#timeframeDropdown span').text(data.selectedTimeframe);
                        $('#timeframeDropdown').attr('data-selected-timeframe', data.selectedTimeframe); // Update data attribute

                        // Update active state in dropdown menu
                        $('.timeframe-item').removeClass('active'); // Remove active from all
                        $('.timeframe-item .fa-check-lg').addClass('d-none'); // Hide all checkmarks

                        // Add active to the newly selected item
                        $(`.timeframe-item[data-timeframe="${data.selectedTimeframe}"]`).addClass('active');
                        $(`.timeframe-item[data-timeframe="${data.selectedTimeframe}"] .fa-check-lg`).removeClass('d-none'); // Show checkmark

                        // Update Stats Cards
                        $('#totalItemsCount').text(data.totalItems);
                        updateProgressBar('totalItemsCount', data.totalItems, 100); // Assuming max for progress bar
                        $('.total-medications-change').text(data.totalItemsChange).removeClass("text-success text-danger text-muted").addClass(data.totalItemsChange.startsWith("+") ? "text-success" : data.totalItemsChange.startsWith("-") ? "text-danger" : "text-muted");

                        $('#lowStockItemsCount').text(data.lowStockItems);
                        updateProgressBar('lowStockItemsCount', data.lowStockItems, 50);
                        $('.low-stock-change').text(data.lowStockChange).removeClass("text-success text-danger text-muted").addClass(data.lowStockChange.startsWith("+") ? "text-danger" : data.lowStockChange.startsWith("-") ? "text-success" : "text-muted");

                        $('#pendingOrdersCount').text(data.pendingOrders);
                        updateProgressBar('pendingOrdersCount', data.pendingOrders, 50);
                        $('.orders-change').text(data.ordersChange).removeClass("text-success text-danger text-muted").addClass(data.ordersChange.startsWith("+") ? "text-success" : data.ordersChange.startsWith("-") ? "text-danger" : "text-muted");

                        $('#inventoryValueCount').text(data.inventoryValue.toLocaleString('en-ZA', { style: 'currency', currency: 'ZAR' }));
                        updateProgressBar('inventoryValueCount', data.inventoryValue, 10000);
                        $('.inventory-value-change').text(data.inventoryValueChange).removeClass("text-success text-danger text-muted").addClass(data.inventoryValueChange.startsWith("+") ? "text-success" : data.inventoryValueChange.startsWith("-") ? "text-danger" : "text-muted");

                        // Update Stock Overview Table
                        var stockOverviewHtml = '';
                        if (data.stockOverview.length > 0) {
                            $.each(data.stockOverview, function (index, item) {
                                stockOverviewHtml += '<tr><td>' + item.dosageForm + '</td><td class="text-end">' + item.itemCount + ' items</td></tr>';
                            });
                        } else {
                            stockOverviewHtml += '<tr><td colspan="2" class="text-muted text-center">No stock overview data</td></tr>';
                        }
                        $('#stockOverviewTableBody').html(stockOverviewHtml);

                        // Update Recent Notifications
                        var notificationListHtml = '';
                        if (data.notifications.length > 0) {
                            $.each(data.notifications, function (index, notification) {
                                if (index < 5) { // Limit to 5 notifications
                                    var isReadClass = notification.isRead ? '' : 'bg-light';
                                    var typeClass = 'badge-' + notification.type.toLowerCase();
                                    notificationListHtml += '<li class="item"><div class="product-info"><a href="' + notification.link + '" class="product-title">' + notification.title + '<span class="badge ' + typeClass + ' float-right">' + notification.type + '</span></a><span class="product-description">' + notification.message + '</span></div></li>';
                                }
                            });
                        } else {
                            notificationListHtml += '<li class="item"><div class="product-info"><a href="javascript:void(0)" class="product-title">No recent notifications</a><span class="product-description">All clear!</span></div></li>';
                        }
                        $('#notificationList').html(notificationListHtml);
                        $('#notificationsCountBadge').text(data.notificationsCount);

                        // Update Recent Medications
                        var medicationsListHtml = '';
                        if (data.medications.length > 0) {
                            $.each(data.medications, function (index, medication) {
                                if (index < 5) { // Limit to 5 medications
                                    medicationsListHtml += '<li class="item"><div class="product-info"><a href="javascript:void(0)" class="product-title">' + medication.medicationName + '</a><span class="product-description">' + (medication.description || 'No description available') + '</span></div></li>';
                                }
                            });
                        } else {
                            medicationsListHtml += '<li class="item"><div class="product-info"><a href="javascript:void(0)" class="product-title">No medications available</a><span class="product-description">Start by adding medications to your inventory</span></div></li>';
                        }
                        $('#medicationsList').html(medicationsListHtml);

                        // Update Recent Activities
                        var recentActivityListHtml = '';
                        if (data.recentActivities.length > 0) {
                            $.each(data.recentActivities, function (index, activity) {
                                if (index < 5) { // Limit to 5 activities
                                    var timestamp = new Date(activity.timestamp).toLocaleString();
                                    recentActivityListHtml += '<li class="item"><div class="product-info"><a href="' + activity.link + '" class="product-title">' + activity.title + '</a><span class="product-description">' + activity.description + ' - ' + timestamp + '</span></div></li>';
                                }
                            });
                        } else {
                            recentActivityListHtml += '<li class="item"><div class="product-info"><a href="javascript:void(0)" class="product-title">No recent activity</a><span class="product-description">No recent actions to display.</span></div></li>';
                        }
                        $('#recentActivityList').html(recentActivityListHtml);

                        // Update Orders Chart (example data, replace with actual data from backend)
                        updateOrdersChart(data.ordersTrendData || [12, 19, 3, 5, 2, 3, 7]);
                    },
                    error: function (xhr, status, error) {
                        console.error('AJAX Error:', status, error);
                        // Optionally update UI to show error message
                    }
                });
            }

            function updateProgressBar(elementId, count, max) {
                const maxCount = Math.max(count, max); // Set a reasonable max for progress bar
                const percentage = Math.min((count / maxCount) * 100, 100);
                $(`#${elementId}`).closest('.info-box').find('.progress-bar').css('width', percentage + '%');
            }

            function initializeOrdersChart() {
                const ctx = document.getElementById('ordersChart').getContext('2d');
                window.ordersChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                        datasets: [{
                            label: 'Orders',
                            data: [0, 0, 0, 0, 0, 0, 0], // Initial empty data
                            borderColor: '#0a1f14',
                            backgroundColor: 'rgba(10, 31, 20, 0.2)',
                            tension: 0.4,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });
            }

            function updateOrdersChart(newData) {
                window.ordersChart.data.datasets[0].data = newData;
                window.ordersChart.update();
            }

            // Timeframe Dropdown functionality
            $('.timeframe-item').on('click', function (e) {
                e.preventDefault();
                var selectedTimeframe = $(this).data('timeframe');
                loadDashboardData(selectedTimeframe);
            });

            // Scan Barcode button functionality
            $('#btnScanBarcode').on('click', function (e) {
                e.preventDefault();
                $('#barcodeInput').val(''); // Clear previous input
                $('#scanResult').empty(); // Clear previous results
                $('#barcodeScanModal').modal('show');
            });

            $('#submitBarcode').on('click', function () {
                var medicationId = $('#barcodeInput').val(); // Assuming input is now Medication ID
                if (medicationId) {
                    $.ajax({
                        url: '@Url.Action("ScanBarcode", "PharmacyManager")',
                        type: 'GET',
                        data: { medicationId: medicationId }, // Send as medicationId
                        success: function (response) {
                            var resultHtml = '';
                            if (response.success) {
                                var medication = response.medication;
                                resultHtml = '<div class="alert alert-success">' +
                                             '<h5>Medication Found: ' + medication.name + '</h5>' +
                                             '<p><strong>Description:</strong> ' + medication.description + '</p>' +
                                             '<p><strong>Dosage Form:</strong> ' + medication.dosageFormDescription + '</p>' +
                                             '<p><strong>Strength:</strong> ' + medication.strength + '</p>' +
                                             '<p><strong>Price:</strong> ' + medication.price.toLocaleString('en-ZA', { style: 'currency', currency: 'ZAR' }) + '</p>' +
                                             '<p><strong>Quantity In Stock:</strong> ' + medication.quantityInStock + '</p>\r\n                                             <p><strong>Min Stock Level:</strong> ' + medication.minStockLevel + '</p>\r\n                                             <p><strong>Supplier:</strong> ' + medication.supplier + '</p>' +
                                             '</div>';
                            } else {
                                resultHtml = '<div class="alert alert-danger">' + response.message + '</div>';
                            }
                            $('#scanResult').html(resultHtml);
                        },
                        error: function (xhr, status, error) {
                            $('#scanResult').html('<div class="alert alert-danger">Error searching for medication.</div>');
                            console.error('AJAX Error:', status, error);
                        }
                    });
                } else {
                    $('#scanResult').html('<div class="alert alert-warning">Please enter a Medication ID.</div>');
                }
            });

            // Clear modal content when closed
            $('#barcodeScanModal').on('hidden.bs.modal', function () {
                $('#barcodeInput').val('');
                $('#scanResult').empty();
            });
        });
    </script>
}

