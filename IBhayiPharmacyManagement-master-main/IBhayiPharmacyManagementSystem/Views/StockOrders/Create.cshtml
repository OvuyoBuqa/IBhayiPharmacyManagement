        console.log('Setting up event handlers for medications table');

        $(document).on('click', '.btn-add-single', function() {
            console.log('Add to Order button clicked!');
            const button = $(this);
            const medicationId = button.data('medication-id');
            
            if (!medicationId) {
                console.error('No medication ID found');
                showToast('Error: No medication ID found', 'error');
                return;
            }

            // Brief feedback while we fetch details, but do not permanently block further actions
            const originalHtml = button.html();
            button.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Adding...');

            // Make AJAX call to add medication to order
            $.ajax({
                url: '@Url.Action("AddMedicationToOrder", "StockOrders")',
                type: 'POST',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                data: {
                    medicationId: medicationId,
                    quantity: 1,
                    notes: ''
                },
                success: function(response) {
                    console.log('AJAX response:', response);
                    if (response.success) {
                        addMedicationToOrderFromAjax(response.medication);
                        showToast(`"${response.medication.Name}" added to order`, 'success');
                        
                        // Update button to show it was added
                        button.removeClass('btn-primary').addClass('btn-success');
                        button.html('<i class="fas fa-check"></i> Added');
                        
                        // Re-enable after 2 seconds
                        setTimeout(function() {
                            button.prop('disabled', false);
                            button.removeClass('btn-success').addClass('btn-primary');
                            button.html('<i class="fas fa-plus"></i> Add to Order');
                        }, 2000);
                    } else {
                        showToast(response.message || 'Error adding medication to order', 'error');
                        button.prop('disabled', false).html(originalHtml);
                    }
                },
                error: function(xhr, status, error) {
                    console.error('AJAX error:', error);
                    showToast('Error adding medication to order', 'error');
                    button.prop('disabled', false).html(originalHtml);
                }
            });
        });

        // Function to add medication to order from AJAX response
        function addMedicationToOrderFromAjax(medication) {
            console.log('Adding medication to order from AJAX:', medication);

            // Normalize property names to support both camelCase and PascalCase payloads
            const medId = medication.MedicationId ?? medication.medicationId;
            const medName = medication.Name ?? medication.name;
            const description = medication.Description ?? medication.description ?? '';
            const schedule = medication.Schedule ?? medication.schedule ?? 1;
            const minStockLevel = medication.MinStockLevel ?? medication.minStockLevel ?? 1;
            const currentStock = medication.CurrentStock ?? medication.currentStock ?? 1;
            const dosageFormId = medication.DosageFormId ?? medication.dosageFormId ?? 1;
            const activeIngredients = medication.ActiveIngredients ?? medication.activeIngredients ?? [];
            const suggestedQty = Math.max(1, medication.SuggestedQuantity ?? medication.suggestedQuantity ?? 1);

            // Check if medication is already in the order
            const existingMedicationIds = [];
            $('input[name$=".MedicationId"]').each(function() {
                const value = $(this).val();
                if (value && value !== '0') {
                    existingMedicationIds.push(value);
                }
            });

            if (medId && existingMedicationIds.includes(medId.toString())) {
                showToast(`"${medName}" is already in the order`, 'warning');
                return;
            }

            const medicationItem = {
                MedicationId: medId,
                IsNewMedication: false,
                Name: medName,
                QuantityOrdered: suggestedQty,
                Description: description,
                Schedule: schedule,
                MinStockLevel: minStockLevel,
                QuantityInStock: Math.max(1, currentStock),
                DosageFormId: dosageFormId,
                ActiveIngredients: activeIngredients
            };

            console.log('Medication item to add:', medicationItem);
            addMedicationItemRow(medicationItem);
            
            // Hide the "no items" message
            $('#noItemsMessage').hide();
            
            // Scroll to the order items section to show the added item
            $('html, body').animate({
                scrollTop: $('#stockOrderItemsContainer').offset().top - 100
            }, 500);
        }

        // Function to add medication to order
        function addMedicationToOrder(medication) {
            console.log('Adding medication to order:', medication);
            
            // Check if medication is already in the order
            const existingMedicationIds = [];
            $('input[name$=".MedicationId"]').each(function() {
                const value = $(this).val();
                if (value && value !== '0') {
                    existingMedicationIds.push(value);
                }
            });

            if (existingMedicationIds.includes(medication.medicationId.toString())) {
                showToast(`"${medication.name}" is already in the order`, 'warning');
                return;
            }

            // Calculate suggested quantity based on stock levels
            let suggestedQuantity = 1;
            if (medication.currentStock <= medication.minStockLevel) {
                // If stock is at or below minimum, suggest ordering enough to reach minimum + buffer
                suggestedQuantity = Math.max(1, medication.minStockLevel + 10 - medication.currentStock);
            } else if (medication.currentStock <= medication.minStockLevel + 10) {
                // If stock is low, suggest ordering a small amount
                suggestedQuantity = Math.max(1, medication.minStockLevel + 5 - medication.currentStock);
            } else {
                // If stock is adequate, suggest ordering 1 unit
                suggestedQuantity = 1;
            }

            const medicationItem = {
                MedicationId: medication.medicationId,
                IsNewMedication: false,
                Name: medication.name,
                QuantityOrdered: suggestedQuantity,
                Description: medication.description || '',
                Schedule: medication.schedule || 1,
                MinStockLevel: medication.minStockLevel || 1,
                QuantityInStock: Math.max(1, medication.currentStock || 1), // Ensure it's at least 1
                DosageFormId: medication.dosageFormId || 1, // Default to 1 if not provided
                ActiveIngredients: medication.activeIngredients || []
            };

            console.log('Medication item to add:', medicationItem);
            addMedicationItemRow(medicationItem);
            
            // Hide the "no items" message
            $('#noItemsMessage').hide();
            
            // Scroll to the order items section to show the added item
            $('html, body').animate({
                scrollTop: $('#stockOrderItemsContainer').offset().top - 100
            }, 500);
        }

        // Initial population if there are items from model (e.g., validation failed)
        if (rowIndex > 0) {
            
        }

        function loadMedicationsForSupplier(supplierId) {
            $.ajax({
                url: '@Url.Action("GetMedicationsBySupplier", "StockOrders")',
                type: 'GET',
                data: { supplierId: supplierId },
                success: function (data) {
                    medications = data; // Update the global medications array
                    // Update all existing medication dropdowns
                    $('.medication-select').each(function () {
                        const currentMedicationId = $(this).val(); // Preserve selected value if possible
                        $(this).html('<option value="">-- Select Medication --</option>' + medications.map(m => `<option value="${m.value}">${m.text}</option>`).join(''));
                        $(this).val(currentMedicationId); // Attempt to re-select previous value
                        // Trigger change to update unit price and totals if a medication was re-selected
                        if (currentMedicationId) {
                            $(this).trigger('change');
                        }
                    });
                },
                error: function (xhr, status, error) {
                    console.error("Failed to load medications for supplier:", error);
                    medications = [];
                    $('.medication-select').html('<option value="">-- Select Medication --</option>');
                    
                }
            });
        }
    </script>
}

