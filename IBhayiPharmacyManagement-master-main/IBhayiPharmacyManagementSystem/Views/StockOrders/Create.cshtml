        // Validation function for new medication fields
        function validateNewMedicationFields() {
            let isValid = true;
            
            // Clear previous validation messages
            $('#newMedicationFields .text-danger').text('');
            
            // Validate medication name
            const name = $('#NewMedicationName').val().trim();
            if (!name) {
                $('#NewMedicationName').next('.text-danger').text('Medication name is required.');
                isValid = false;
            }
            
            // Validate schedule
            const schedule = $('#NewMedicationSchedule').val();
            if (!schedule || isNaN(schedule) || parseInt(schedule) < 0) {
                $('#NewMedicationSchedule').next('.text-danger').text('Schedule is required and must be a non-negative number.');
                isValid = false;
            }
            
            // Validate dosage form
            const dosageFormId = $('#NewMedicationDosageFormId').val();
            if (!dosageFormId) {
                $('#NewMedicationDosageFormId').next('.text-danger').text('Dosage form is required.');
                isValid = false;
            }
            
            // Validate min stock level
            const minStockLevel = $('#NewMedicationMinStockLevel').val();
            if (!minStockLevel || isNaN(minStockLevel) || parseInt(minStockLevel) < 0) {
                $('#NewMedicationMinStockLevel').next('.text-danger').text('Min stock level is required and must be a non-negative number.');
                isValid = false;
            }
            
            // Validate quantity in stock
            const quantityInStock = $('#NewMedicationQuantityInStock').val();
            if (!quantityInStock || isNaN(quantityInStock) || parseInt(quantityInStock) < 1) {
                $('#NewMedicationQuantityInStock').next('.text-danger').text('Initial stock quantity is required and must be at least 1.');
                isValid = false;
            }
            
            // Validate at least one active ingredient
            const activeIngredientRows = $('#newMedicationActiveIngredientsContainer .active-ingredient-row');
            if (activeIngredientRows.length === 0) {
                $('#newMedicationActiveIngredientsContainer').append('<div class="text-danger">At least one active ingredient is required.</div>');
                isValid = false;
            } else {
                let hasValidIngredient = false;
                activeIngredientRows.each(function() {
                    const ingredientId = $(this).find('.active-ingredient-select').val();
                    const strength = $(this).find('.active-ingredient-strength').val().trim();
                    if (ingredientId && strength) {
                        hasValidIngredient = true;
                    }
                });
                if (!hasValidIngredient) {
                    $('#newMedicationActiveIngredientsContainer').append('<div class="text-danger">At least one active ingredient with strength is required.</div>');
                    isValid = false;
                }
            }
            
            // Log validation result for debugging
            console.log('New medication validation result:', isValid);
            
            return isValid;
        }

        // Toast notification function
        function showToast(message, type = 'info') {
            let bgClass = 'info';
            if (type === 'success') bgClass = 'success';
            else if (type === 'error') bgClass = 'danger';
            else if (type === 'warning') bgClass = 'warning';
            
            const toastHtml = `
                <div class="toast align-items-center text-white bg-${bgClass} border-0" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body">
                            ${message}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>
            `;
            
            // Create toast container if it doesn't exist
            if ($('#toast-container').length === 0) {
                $('body').append('<div id="toast-container" class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1055;"></div>');
            }
            
            const $toast = $(toastHtml);
            $('#toast-container').append($toast);
            
            const toast = new bootstrap.Toast($toast[0]);
            toast.show();
            
            // Remove toast element after it's hidden
            $toast.on('hidden.bs.toast', function() {
                $(this).remove();
            });
        }

