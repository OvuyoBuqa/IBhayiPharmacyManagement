        // Function to populate the medications table
        function populateMedicationsTable(medications) {
            console.log('Populating medications table with:', medications);
            
            // Store all medications for search and pagination
            allMedications = medications || [];
            currentPage = 1; // Reset to first page
            currentSearchTerm = ''; // Reset search
            
            // Clear search input
            $('#medicationSearchInput').val('');
            $('#clearSearchBtn').hide();
            $('#searchResultsCount').text('');
            
            // Filter and display medications
            filterMedications();
        }

        // Function to filter medications based on search term
        function filterMedications() {
            if (!currentSearchTerm) {
                filteredMedications = [...allMedications];
            } else {
                filteredMedications = allMedications.filter(function(med) {
                    const searchableText = [
                        med.name || '',
                        med.description || '',
                        med.dosageForm || '',
                        med.activeIngredients ? med.activeIngredients.map(ai => `${ai.name} ${ai.strength}`).join(' ') : ''
                    ].join(' ').toLowerCase();
                    
                    return searchableText.includes(currentSearchTerm);
                });
            }
            
            // Update search UI
            if (currentSearchTerm) {
                $('#clearSearchBtn').show();
                $('#searchResultsCount').text(`Found ${filteredMedications.length} medication(s)`);
            } else {
                $('#clearSearchBtn').hide();
                $('#searchResultsCount').text('');
            }
            
            // Reset to first page and display
            currentPage = 1;
            displayMedications();
        }

        // Function to display medications with pagination
        function displayMedications() {
            const tbody = $('#medicationsTableBody');
            tbody.empty();

            if (!filteredMedications || filteredMedications.length === 0) {
                const message = currentSearchTerm 
                    ? `<i class="fas fa-search me-2"></i>No medications found matching "${currentSearchTerm}"`
                    : '<i class="fas fa-info-circle me-2"></i>No medications found for this supplier';
                tbody.append(`<tr><td colspan="9" class="text-center text-muted py-4">${message}</td></tr>`);
                $('#paginationControls').hide();
                return;
            }

            // Calculate pagination
            const totalPages = Math.ceil(filteredMedications.length / itemsPerPage);
            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = Math.min(startIndex + itemsPerPage, filteredMedications.length);
            const pageMedications = filteredMedications.slice(startIndex, endIndex);

            // Display medications for current page
            pageMedications.forEach(function(med) {
                const activeIngredientsText = med.activeIngredients && med.activeIngredients.length > 0 
                    ? med.activeIngredients.map(ai => `${ai.name} ${ai.strength}`).join(', ')
                    : 'None';

                const stockStatus = getStockStatus(med.currentStock, med.minStockLevel);
                const statusClass = stockStatus.class;
                const statusText = stockStatus.text;

                const row = $(`
                    <tr data-medication-id="${med.medicationId}">
                        <td><strong>${med.name}</strong></td>
                        <td>${med.description || 'N/A'}</td>
                        <td>${med.schedule}</td>
                        <td>${med.dosageForm}</td>
                        <td>${med.currentStock}</td>
                        <td>${med.minStockLevel}</td>
                        <td class="active-ingredients-list">${activeIngredientsText}</td>
                        <td><span class="stock-status ${statusClass}">${statusText}</span></td>
                        <td>
                            <button type="button" class="btn btn-sm btn-primary btn-add-single" 
                                    data-medication-id="${med.medicationId}">
                                <i class="fas fa-plus"></i> Add to Order
                            </button>
                        </td>
                    </tr>
                `);
                tbody.append(row);
            });

            // Update pagination controls
            updatePaginationControls(totalPages);
        }

        // Function to update pagination controls
        function updatePaginationControls(totalPages) {
            if (totalPages <= 1) {
                $('#paginationControls').hide();
                return;
            }

            $('#paginationControls').show();
            
            // Update page info
            $('#pageInfo').text(`Page ${currentPage} of ${totalPages}`);
            
            // Update Previous button
            const prevBtn = $('#prevPageBtn button');
            if (currentPage <= 1) {
                prevBtn.prop('disabled', true);
            } else {
                prevBtn.prop('disabled', false);
            }
            
            // Update Next button
            const nextBtn = $('#nextPageBtn button');
            if (currentPage >= totalPages) {
                nextBtn.prop('disabled', true);
            } else {
                nextBtn.prop('disabled', false);
            }
        }

        // Function to get stock status
        function getStockStatus(currentStock, minStockLevel) {
            if (currentStock <= minStockLevel) {
                return { class: 'critical', text: 'Critical' };
            } else if (currentStock <= minStockLevel + 10) {
                return { class: 'low', text: 'Low' };
            } else {
                return { class: 'adequate', text: 'Adequate' };
            }
        }

