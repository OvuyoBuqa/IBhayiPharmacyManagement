<!-- Quantity Picker Modal -->
<div class="modal fade" id="quantityPickerModal" tabindex="-1" aria-labelledby="quantityPickerLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="quantityPickerLabel"><i class="fas fa-sort-numeric-up-alt me-2"></i>Select Quantity</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2 text-muted" id="quantityPickerMedName"></div>
                <div class="form-floating">
                    <input type="number" id="quantityPickerInput" class="form-control" min="1" value="1" />
                    <label for="quantityPickerInput">Quantity</label>
                </div>
                <small class="text-muted d-block mt-2" id="quantityPickerHint"></small>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="quantityPickerConfirm"><i class="fas fa-check me-2"></i>Add Item</button>
            </div>
        </div>
    </div>
    </div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Attach a light-weight submit logger to help debug submission issues
        $(document).on('submit', 'form', function () {
            console.log('Stock Order form submitting...');
            
            // Log all form data for debugging
            const formData = new FormData(this);
            console.log('Form data:');
            for (let [key, value] of formData.entries()) {
                console.log(`${key}: ${value}`);
            }
            
            // Log stock order items specifically
            const stockOrderItems = [];
            let itemIndex = 0;
            while (formData.has(`StockOrderItems[${itemIndex}].MedicationId`)) {
                const item = {
                    MedicationId: formData.get(`StockOrderItems[${itemIndex}].MedicationId`),
                    IsNewMedication: formData.get(`StockOrderItems[${itemIndex}].IsNewMedication`),
                    Name: formData.get(`StockOrderItems[${itemIndex}].Name`),
                    QuantityOrdered: formData.get(`StockOrderItems[${itemIndex}].QuantityOrdered`),
                    Schedule: formData.get(`StockOrderItems[${itemIndex}].Schedule`),
                    Description: formData.get(`StockOrderItems[${itemIndex}].Description`),
                    MinStockLevel: formData.get(`StockOrderItems[${itemIndex}].MinStockLevel`),
                    QuantityInStock: formData.get(`StockOrderItems[${itemIndex}].QuantityInStock`),
                    DosageFormId: formData.get(`StockOrderItems[${itemIndex}].DosageFormId`)
                };
                stockOrderItems.push(item);
                itemIndex++;
            }
            console.log('Stock Order Items found:', stockOrderItems.length);
            console.log('Stock Order Items:', stockOrderItems);
            
            // Also log the current rowIndex
            console.log('Current rowIndex at form submission:', rowIndex);
            
            // Log the actual form elements to see what's being submitted
            console.log('Form elements with StockOrderItems:');
            $('input[name*="StockOrderItems"]').each(function() {
                console.log('Input:', $(this).attr('name'), 'Value:', $(this).val());
            });
        });
        let rowIndex = @(Model.StockOrderItems?.Count ?? 0);
        let medications = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Medications ?? new List<SelectListItem>()));
        console.log("Medications data:", medications); // Add this line to inspect the data

        // Search and pagination variables
        let allMedications = []; // Store all medications from server
        let filteredMedications = []; // Store filtered medications after search
        let currentPage = 1;
        const itemsPerPage = 10;
        let currentSearchTerm = '';

        $(document).ready(function () {
            // totals removed for quote-based system

            // Event listener for Supplier dropdown change
            $('#SupplierId').on('change', function () {
                const supplierId = $(this).val();
                if (supplierId) {
                    loadMedicationsForSupplier(supplierId);
                    loadMedicationsTable(supplierId);
                } else {
                    // Clear medications if no supplier is selected
                    medications = [];
                    $('.medication-select').html('<option value="">-- Select Medication --</option>');
                    $('#medicationsTableSection').hide();
                    $('#medicationsTableBody').empty();
                }
            });

            // Add Order Item button removed - now using table selection

            // Event delegation for dynamically added rows
            $('#stockOrderItemsContainer').on('change', 'select[name$="MedicationId"]', function () {
                // no unit price calculation needed
                updateMedicationDropdowns(); // Prevent duplicate selections
            });

            // Prevent duplicate medication selections
            function updateMedicationDropdowns() {
                const selectedMedications = [];
                
                // Collect all currently selected medication IDs
                $('.medication-select').each(function() {
                    const selectedValue = $(this).val();
                    if (selectedValue && selectedValue !== '') {
                        selectedMedications.push(selectedValue);
                    }
                });
                
