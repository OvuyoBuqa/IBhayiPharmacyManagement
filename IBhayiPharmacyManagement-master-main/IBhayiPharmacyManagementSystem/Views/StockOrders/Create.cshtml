                                    <i class="fas fa-search me-2"></i>Search Medications
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <button type="button" id="clearSearchBtn" class="btn btn-outline-secondary me-2" style="display: none;">
                                <i class="fas fa-times me-2"></i>Clear Search
                            </button>
                            <small class="text-muted" id="searchResultsCount"></small>
                        </div>
                    </div>
                    
                    <div class="table-responsive">
                        <table class="table table-striped table-hover" id="medicationsTable">
                            <thead class="table-dark">
                                <tr>
                                    <th>Medication Name</th>
                                    <th>Description</th>
                                    <th>Schedule</th>
                                    <th>Dosage Form</th>
                                    <th>Current Stock</th>
                                    <th>Min Stock Level</th>
                                    <th>Active Ingredients</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody id="medicationsTableBody">
                                <!-- Medications will be populated here via JavaScript -->
                            </tbody>
                        </table>
                    </div>
                    
                    <!-- Pagination Controls -->
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div>
                            <p class="text-muted mb-0">
                                <i class="fas fa-info-circle me-2"></i>Click "Add to Order" next to each medication you want to include in your stock order.
                            </p>
                        </div>
                        <div id="paginationControls" style="display: none;">
                            <nav aria-label="Medications pagination">
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item" id="prevPageBtn">
                                        <button class="page-link" type="button" disabled>
                                            <i class="fas fa-chevron-left"></i> Previous
                                        </button>
                                    </li>
                                    <li class="page-item">
                                        <span class="page-link" id="pageInfo">Page 1 of 1</span>
                                    </li>
                                    <li class="page-item" id="nextPageBtn">
                                        <button class="page-link" type="button" disabled>
                                            Next <i class="fas fa-chevron-right"></i>
                                        </button>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                    <hr class="my-4" />
                </div>

