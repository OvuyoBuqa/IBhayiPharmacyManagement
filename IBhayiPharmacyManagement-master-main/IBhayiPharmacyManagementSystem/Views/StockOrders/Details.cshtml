@model IBhayiPharmacyManagementSystem.Models.StockOrder

@{
    ViewData["Title"] = "Stock Order Details";
    Layout = "_LayoutPharmacyManger";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Stock Order Details - Order #@Model.StockOrderId</h2>
        <a asp-action="Index" class="btn btn-secondary d-flex align-items-center">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-pharmacy-primary text-white py-3">
            <h5 class="mb-0">Order Information</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Order #:</dt>
                <dd class="col-sm-9">@Model.StockOrderId</dd>

                <dt class="col-sm-3">Supplier:</dt>
                <dd class="col-sm-9">@Model.Supplier?.Name</dd>

                <dt class="col-sm-3">Order Date:</dt>
                <dd class="col-sm-9">@Model.StockOrderDate.ToShortDateString()</dd>

                <dt class="col-sm-3">Status:</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-@(Model.StockOrderStatus == IBhayiPharmacyManagementSystem.Enums.StockOrderStatusEnum.Pending ? "warning" :
                                       Model.StockOrderStatus == IBhayiPharmacyManagementSystem.Enums.StockOrderStatusEnum.Confirmed ? "success" : "info")">
                        @Model.StockOrderStatus
                    </span>
                </dd>

                <dt class="col-sm-3">Total Amount:</dt>
                <dd class="col-sm-9">@(Model.QuoteAmount?.ToString("C") ?? "Pending Quote")</dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-pharmacy-info text-white py-3">
            <h5 class="mb-0">Order Items</h5>
        </div>
        <div class="card-body">
            @if (Model.StockOrderItems != null && Model.StockOrderItems.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Medication</th>
                                <th>Quantity Ordered</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.StockOrderItems)
                            {
                                <tr>
                                    <td>@item.Medication?.Name</td>
                                    <td>@item.QuantityOrdered</td>
                                    <td>@item.Notes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted text-center">No items found for this order.</p>
            }
        </div>
    </div>

    <div class="d-flex justify-content-end mt-4">
        @if (Model.StockOrderStatus == IBhayiPharmacyManagementSystem.Enums.StockOrderStatusEnum.Pending)
        {
            <form asp-action="Receive" asp-route-id="@Model.StockOrderId" method="post">
                <button type="submit" class="btn btn-pharmacy-success me-2" onclick="return confirm('Are you sure you want to mark this order as received? This will update stock levels.');">
                    <i class="fas fa-box-open"></i> Receive Order
                </button>
            </form>
        }
        else if (Model.StockOrderStatus == IBhayiPharmacyManagementSystem.Enums.StockOrderStatusEnum.Received)
        {
            <button class="btn btn-pharmacy-secondary me-2" disabled>
                <i class="fas fa-check-circle"></i> Order Received
            </button>
        }
        <form asp-action="Delete" asp-route-id="@Model.StockOrderId" method="post">
            <button type="submit" class="btn btn-pharmacy-danger" onclick="return confirm('Are you sure you want to delete this order?');">
                <i class="fas fa-trash-alt"></i> Delete Order
            </button>
        </form>
    </div>

</div>
