                        currentAllergyConflictData.quantity,
                        currentAllergyConflictData.instructions,
                        currentAllergyConflictData.frequency,
                        currentAllergyConflictData.repeats
                    );
                    
                    // Show warning alert
                    showAlert('warning', 'Medication added despite allergy conflicts. Please ensure customer is aware.');
                    
