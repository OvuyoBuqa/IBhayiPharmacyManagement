                    var alertClass = alert.alertLevel === 'DANGER' ? 'text-danger' :
                                   alert.alertLevel === 'WARNING' ? 'text-warning' : 'text-info';
                    var iconClass = alert.alertLevel === 'DANGER' ? 'fa-exclamation-triangle' :
                                  alert.alertLevel === 'WARNING' ? 'fa-exclamation-circle' : 'fa-info-circle';

                    messagesHtml += `
                        <div class="mb-2 p-2 border-start border-${alert.alertLevel === 'DANGER' ? 'danger' :
                                                                    alert.alertLevel === 'WARNING' ? 'warning' : 'info'} border-3">
                            <div class="fw-bold ${alertClass}">
                                <i class="fas ${iconClass} me-2"></i>
                                ${alert.medicationName} - ${alert.activeIngredientName}
