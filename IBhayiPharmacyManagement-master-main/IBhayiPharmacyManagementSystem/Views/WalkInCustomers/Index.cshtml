                console.log("=== PREPARING FORM FOR SUBMISSION ===");
                
                // Find add item row elements
                var addItemElements = $('#addItemRow').find('select, input, textarea');
                console.log("Found add item row elements:", addItemElements.length);
                
                // Disable and remove validation from add item row to prevent HTML5 validation errors
                addItemElements.each(function(index) {
                    console.log("Processing element", index, ":", this.tagName, this.name || this.id);
                    $(this).prop('disabled', true)
