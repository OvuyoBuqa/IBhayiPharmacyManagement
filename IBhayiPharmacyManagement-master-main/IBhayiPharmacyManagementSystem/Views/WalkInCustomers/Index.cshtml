                            <div class="card-body">
                                <h6 class="text-danger">Conflicting Ingredients:</h6>
                                <ul class="list-unstyled mb-0">
                                    ${conflictingIngredients.map(function(ingredient) {
                                        return `<li class="mb-1">
                                            <span class="badge bg-danger me-2">${ingredient.severity}</span>
                                            <strong>${ingredient.ingredientName}</strong>
                                            ${ingredient.description ? `<br><small class="text-muted">${ingredient.description}</small>` : ''}
