                console.log("FormData entries:");
                for (let [key, value] of formData.entries()) {
                    console.log(`${key}: ${value}`);
                }
                console.log("Total form data entries:", [...formData.entries()].length);
                console.log("=== END JAVASCRIPT DEBUG ===");

                $.ajax({
