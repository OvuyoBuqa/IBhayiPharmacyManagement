                        key1: `NewCustomerAllergies[${index}].ActiveIngredientId`,
                        val1: finalIngredientId,
                        key2: `NewCustomerAllergies[${index}].Severity`,
                        val2: finalSeverity,
                        key3: `NewCustomerAllergies[${index}].Description`,
                        val3: finalDescription
                    });

                    formData.append(`NewCustomerAllergies[${index}].ActiveIngredientId`, finalIngredientId);
                    formData.append(`NewCustomerAllergies[${index}].Severity`, finalSeverity);
                    formData.append(`NewCustomerAllergies[${index}].Description`, finalDescription);
