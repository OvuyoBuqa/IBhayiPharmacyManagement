            // Prescription file validation and auto-preview
            $('#PrescriptionFile').change(function () {
                const file = this.files[0];
                if (file) {
                    const allowedTypes = ['application/pdf', 'image/jpeg', 'image/jpg', 'image/png', 'image/heic'];
                    const maxSize = 10 * 1024 * 1024; // 10MB

                    if (!allowedTypes.includes(file.type)) {
                        alert('Please select a valid file type (PDF, JPG, PNG, HEIC)');
                        this.value = '';
                        return;
                    }

                    if (file.size > maxSize) {
                        alert('File size must be less than 10MB');
                        this.value = '';
                        return;
                    }

                    // Auto-preview the file
                    previewPrescriptionFile(file);
                }
            });

            // Function to preview prescription file
            function previewPrescriptionFile(file) {
                const reader = new FileReader();
                const fileExtension = file.name.split('.').pop().toLowerCase();

                reader.onload = function(e) {
                    let previewHtml = '';

                    if (fileExtension === 'pdf') {
                        previewHtml = `
                            <div class="text-center mb-3">
                                <i class="fas fa-file-pdf fa-3x text-danger mb-3"></i>
                                <h5 class="text-primary">${file.name}</h5>
                                <p class="text-muted">PDF Document - ${(file.size / 1024 / 1024).toFixed(2)} MB</p>
                                <div class="pdf-container border rounded p-2">
                                    <iframe src="${e.target.result}"
                                            style="width: 100%; height: 400px; border: none;"
                                            title="Prescription PDF Preview">
                                        <p>Your browser does not support PDF viewing.
                                        <a href="${e.target.result}" target="_blank" class="btn btn-primary btn-sm">Click here to open PDF</a></p>
                                    </iframe>
                                </div>
                            </div>
                        `;
                    } else if (['jpg', 'jpeg', 'png', 'heic'].includes(fileExtension)) {
                        previewHtml = `
                            <div class="text-center mb-3">
                                <i class="fas fa-file-image fa-3x text-success mb-3"></i>
                                <h5 class="text-primary">${file.name}</h5>
                                <p class="text-muted">Image - ${(file.size / 1024 / 1024).toFixed(2)} MB</p>
                                <div class="image-preview-container">
                                    <img src="${e.target.result}" class="img-fluid rounded border shadow-sm"
                                         alt="Prescription preview" style="max-height: 500px;" />
                                </div>
                            </div>
                        `;
                    }

                    $('#prescriptionPreviewContent').html(previewHtml);
                };

                if (fileExtension === 'pdf') {
                    reader.readAsDataURL(file);
                } else {
                    reader.readAsDataURL(file);
                }
            }

            // Store allergy conflict data for modal
            let currentAllergyConflictData = null;

            // Handle prescription item addition (local)
            $('#addItemBtn').on('click', function(e) {
                console.log("Add Item button clicked!");
                e.preventDefault();
                var submitBtn = $(this);

                // Basic validation
                const medicationId = $('#medicationSelect').val();
                const quantity = $('#medicationQuantity').val();
                const instructions = $('#medicationInstructions').val();
                const frequency = $('#medicationFrequency').val();
                const repeats = $('#medicationRepeats').val();

                if (!medicationId || !quantity || !instructions || !frequency) {
                    showAlert('danger', 'Please fill in all required fields');
                    return;
                }

                // Check for duplicate medication
                const medicationText = $('#medicationSelect option:selected').text();
                let isDuplicate = false;
                $('#prescriptionItemsTable tbody tr:not(#addItemRow)').each(function() {
                    const existingMedication = $(this).find('td:first strong').text();
                    if (existingMedication === medicationText) {
                        isDuplicate = true;
                        return false; // Break out of loop
                    }
                });

                if (isDuplicate) {
                    showAlert('warning', 'This medication has already been added to the prescription. Please select a different medication.');
                    return;
                }

                // Get customer ID
                const customerId = $('#SelectedCustomerId').val();
                
                // Check for allergies if customer is selected
                if (customerId) {
                    submitBtn.prop('disabled', true);
                    submitBtn.html('<i class="fas fa-spinner fa-spin me-1"></i> Checking allergies...');

                    // Check for allergy conflicts
                    $.ajax({
                        url: '@Url.Action("CheckMedicationAllergies", "WalkInCustomers")',
                        type: 'POST',
                        data: { 
                            customerId: customerId, 
                            medicationId: medicationId 
                        },
                        headers: {
                            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            submitBtn.prop('disabled', false);
                            submitBtn.html('<i class="fas fa-plus me-1"></i>Add Item');

                            if (response.success && response.hasConflict) {
                                // Store conflict data
                                currentAllergyConflictData = {
                                    medicationId: medicationId,
                                    medicationName: response.medicationName,
                                    medicationText: medicationText,
                                    quantity: quantity,
                                    instructions: instructions,
                                    frequency: frequency,
                                    repeats: repeats,
                                    conflictingIngredients: response.conflictingIngredients,
                                    safeAlternatives: response.safeAlternatives
                                };

                                // Show allergy conflict modal
                                showAllergyConflictModal(response.medicationName, response.conflictingIngredients, response.safeAlternatives);
                            } else {
                                // No conflicts, add the medication
                                addMedicationToTable(medicationText, quantity, instructions, frequency, repeats);
                            }
                        },
                        error: function(xhr) {
                            submitBtn.prop('disabled', false);
                            submitBtn.html('<i class="fas fa-plus me-1"></i>Add Item');
                            console.log('Allergy check error:', xhr);
                            // If error occurs, still add the medication but log the error
                            addMedicationToTable(medicationText, quantity, instructions, frequency, repeats);
                        }
                    });
                } else {
                    // No customer selected, proceed without checking allergies
                    addMedicationToTable(medicationText, quantity, instructions, frequency, repeats);
                }
            });

            // Function to add medication to table
            function addMedicationToTable(medicationText, quantity, instructions, frequencyText, repeats) {
                const frequencyDisplay = $('#medicationFrequency option:selected').text();

                // Create new row
                const newRow = `
                    <tr class="fade-in">
                        <td><strong>${medicationText}</strong></td>
                        <td><span class="badge bg-primary">${quantity}</span></td>
                        <td>${instructions}</td>
                        <td><span class="badge bg-info">${frequencyDisplay}</span></td>
                        <td><span class="badge bg-secondary">${repeats || 0}</span></td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-danger remove-item">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </td>
                    </tr>
                `;

                // Insert before the add-form row
                $('#addItemRow').before(newRow);

                // Update items count
                updateItemsCount();

                // Reset form and reinitialize Select2
                $('#medicationSelect').val('').trigger('change.select2');
                $('#medicationQuantity').val('');
                $('#medicationInstructions').val('');
                $('#medicationFrequency').val('').trigger('change.select2');
                $('#medicationRepeats').val('0');

                // Reinitialize Select2 dropdowns after reset
                setTimeout(function() {
                    initializeSelect2Dropdowns();
                    updateMedicationDropdowns(); // Update dropdown to disable selected medications
                }, 100);

                showAlert('success', 'Prescription item added successfully');
