                }

                // Show loading state
                console.log("Setting loading state...");
                $('#submitPrescriptionBtn').prop('disabled', true);
                $('#submitPrescriptionBtn').html('<i class="fas fa-spinner fa-spin me-2"></i>Submitting...');

                // Show success message
                console.log("Showing success message...");
                showAlert('success', 'Prescription submitted successfully! Processing your request...');
                
                // Disable HTML5 validation to prevent browser interference
                console.log("Disabling HTML5 validation...");
                $(this).attr('novalidate', 'novalidate');
                
                console.log("=== FORM SUBMISSION HANDLER COMPLETE - FORM SHOULD NOW SUBMIT ===");
            });

            // Update step indicators based on progress
            function updateStepIndicators() {
                const customerSelected = $('#SelectedCustomerId').val() !== '';
                const fileUploaded = $('#PrescriptionFile')[0].files.length > 0;
                const hasItems = $('#prescriptionItemsTable tbody tr').length > 1; // More than just the form row

                // Reset all progress steps
                $('.progress-step').removeClass('completed');

                // Step 1: Customer
                if (customerSelected) {
                    $('.step-indicator').eq(0).find('.step-circle').removeClass('bg-secondary bg-primary').addClass('bg-success');
                    $('.step-indicator').eq(0).addClass('completed');
                    $('.progress-step').eq(0).addClass('completed');
                }

                // Step 2: Upload & Review
                if (fileUploaded) {
                    $('.step-indicator').eq(1).find('.step-circle').removeClass('bg-secondary').addClass('bg-success');
                    $('.step-indicator').eq(1).addClass('completed');
                    $('.progress-step').eq(1).addClass('completed');
                }

                // Step 3: Process Items
                if (hasItems) {
                    $('.step-indicator').eq(2).find('.step-circle').removeClass('bg-secondary').addClass('bg-success');
                    $('.step-indicator').eq(2).addClass('completed');
                }
            }

            // Update step indicators on relevant changes
            $('#SelectedCustomerId, #PrescriptionFile').change(function() {
                updateStepIndicators();
            });

            // Initialize counts and indicators on page load
            updateItemsCount();
            updateStepIndicators();

        });
    </script>
}
