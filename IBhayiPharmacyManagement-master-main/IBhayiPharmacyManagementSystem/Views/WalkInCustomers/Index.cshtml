            // Function to handle selecting an alternative medication
            window.selectAlternativeMedication = function(medicationId, medicationName) {
                // Close the modal
                $('#allergyConflictModal').modal('hide');

                // Update the medication select dropdown with the alternative
                $('#medicationSelect option[value="' + medicationId + '"]').prop('selected', true);
                $('#medicationSelect').trigger('change');

