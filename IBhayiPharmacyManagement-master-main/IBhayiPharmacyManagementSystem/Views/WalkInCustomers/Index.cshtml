                                <strong>Allergy Level:</strong> ${alert.allergySeverity}<br>
                                <strong>Description:</strong> ${alert.allergyDescription}
                            </div>
                        </div>
                    `;
                });

                $('#allergyAlertMessages').html(messagesHtml);
                $('#allergyAlertsContainer').show();
