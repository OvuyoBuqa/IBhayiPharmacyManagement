@model IEnumerable<IBhayiPharmacyManagementSystem.Models.CustomerAllergy>

@{
    ViewData["Title"] = "Customer Allergies";
    Layout = "_LayoutPharmacist";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center py-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">
                <i class="fas fa-allergies text-primary me-2"></i>Customer Allergies
            </h1>
            <p class="mb-0 text-muted">Manage patient allergy records and reactions</p>
        </div>
        <a asp-action="AddCustomerAllergies" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus-circle me-2"></i>Add New Allergy
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" role="alert">
            <div class="d-flex align-items-center">
                <i class="fas fa-check-circle me-2 fs-4"></i>
                <div>@TempData["SuccessMessage"]</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom-0 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Allergy Records</h5>
                <div class="input-group" style="max-width: 300px;">
                    <input type="text" class="form-control form-control-sm" placeholder="Search allergies...">
                    <button class="btn btn-sm btn-outline-secondary" type="button">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Customer</th>
                            <th>Active Ingredient</th>
                            <th>Severity</th>
                            <th>Description</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="align-middle">
                                <td class="ps-4 fw-medium">@item.Customer?.Name</td>
                                <td>
                                    <span class="d-inline-block text-truncate" style="max-width: 150px;">
                                        @item.ActiveIngredient?.Name
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @GetSeverityBadgeClass(item.Severity) rounded-pill py-2 px-3">
                                        @item.Severity
                                    </span>
                                </td>
                                <td>
                                    <span class="d-inline-block text-truncate" style="max-width: 200px;">
                                        @(string.IsNullOrEmpty(item.Description) ? "N/A" : item.Description)
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                      
                                        <a asp-action="EditCustomerAllergies" asp-route-id="@item.AllergyId" class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.AllergyId" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white border-top-0 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-muted small">
                    Showing <span class="fw-bold">@Model.Count()</span> records
                </div>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item disabled">
                            <a class="page-link" href="#" tabindex="-1" aria-disabled="true">Previous</a>
                        </li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item">
                            <a class="page-link" href="#">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

@functions {
    public string GetSeverityBadgeClass(string severity)
    {
        return severity switch
        {
            "Mild" => "bg-info bg-opacity-10 text-info",
            "Moderate" => "bg-warning bg-opacity-10 text-warning",
            "Severe" => "bg-danger bg-opacity-10 text-danger",
            _ => "bg-secondary bg-opacity-10 text-secondary"
        };
    }
}

@section Styles {
    <style>
        body {
            background-color: #f8fafc;
        }

        .card {
            border-radius: 0.5rem;
            border: 1px solid rgba(0, 0, 0, 0.05);
            overflow: hidden;
        }

        .card-header {
            background-color: #fff;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            padding: 1rem 1.25rem;
        }

        .table {
            margin-bottom: 0;
        }

            .table thead th {
                font-weight: 600;
                text-transform: uppercase;
                font-size: 0.75rem;
                letter-spacing: 0.5px;
                color: #6c757d;
                border-bottom-width: 1px;
                padding: 0.75rem 1.25rem;
            }

            .table tbody td {
                padding: 1rem 1.25rem;
                vertical-align: middle;
                border-top: 1px solid rgba(0, 0, 0, 0.03);
            }

            .table tbody tr:hover {
                background-color: rgba(13, 110, 253, 0.03);
            }

        .badge {
            font-weight: 500;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
        }

        .btn-group .btn {
            border-radius: 0.25rem !important;
            margin: 0 2px;
        }

        .btn-sm {
            padding: 0.35rem 0.5rem;
            font-size: 0.8rem;
        }

        .pagination .page-item .page-link {
            font-size: 0.8rem;
            padding: 0.25rem 0.5rem;
            border-color: rgba(0, 0, 0, 0.05);
        }

        .pagination .page-item.active .page-link {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }

        .alert {
            border: none;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.05);
        }
    </style>
}